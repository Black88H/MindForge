<Window x:Class="MindForge.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="MindForge — Login"
        Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="PlaceholderTextBox" TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="materialDesign:HintAssist.Foreground" Value="{DynamicResource TextMutedBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        </Style>
    </Window.Resources>

    <Border CornerRadius="16" ClipToBounds="True">
        <Grid>
            <!-- Gradient Background -->
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0D1117" Offset="0"/>
                    <GradientStop Color="#161B2E" Offset="0.5"/>
                    <GradientStop Color="#0D1117" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <!-- Decorative Glow -->
            <Ellipse Width="500" Height="500" HorizontalAlignment="Right" VerticalAlignment="Top"
                     Margin="0,-200,-100,0" Opacity="0.06">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#6C63FF" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="400"/>
                </Grid.ColumnDefinitions>

                <!-- Left Panel: Branding -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="60,0,40,0">
                    <TextBlock Text="🧠" FontSize="56" HorizontalAlignment="Left" Margin="0,0,0,16"/>
                    <TextBlock Text="MindForge" FontSize="42" FontWeight="Bold" Foreground="White"
                               FontFamily="Segoe UI"/>
                    <TextBlock Text="Deine KI-gestützte" FontSize="18" Foreground="{DynamicResource TextMutedBrush}" Margin="0,8,0,0"/>
                    <TextBlock Text="Lernplattform." FontSize="18" Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold"/>

                    <StackPanel Margin="0,40,0,0">
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBlock Text="✨" FontSize="16" Margin="0,0,10,0"/>
                            <TextBlock Text="KI-Tutor mit Ollama Integration" Foreground="{DynamicResource TextMutedBrush}" FontSize="14"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBlock Text="🔄" FontSize="16" Margin="0,0,10,0"/>
                            <TextBlock Text="Spaced Repetition (SM-2 Algorithmus)" Foreground="{DynamicResource TextMutedBrush}" FontSize="14"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBlock Text="🏆" FontSize="16" Margin="0,0,10,0"/>
                            <TextBlock Text="Gamification &amp; Level-System" Foreground="{DynamicResource TextMutedBrush}" FontSize="14"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBlock Text="🧩" FontSize="16" Margin="0,0,10,0"/>
                            <TextBlock Text="Wissensgraph &amp; Feynman-Methode" Foreground="{DynamicResource TextMutedBrush}" FontSize="14"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Right Panel: Login Form -->
                <Border Grid.Column="1" CornerRadius="12" Margin="0,40,40,40">
                    <Border.Background>
                        <SolidColorBrush Color="#161B2E" Opacity="0.95"/>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect Color="#6C63FF" BlurRadius="30" ShadowDepth="0" Opacity="0.15"/>
                    </Border.Effect>

                    <StackPanel Margin="36,40,36,40" VerticalAlignment="Center">

                        <!-- Tab: Login / Register -->
                        <Grid Margin="0,0,0,32">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="BtnLoginTab" Grid.Column="0" Content="Anmelden"
                                    Click="OnLoginTabClick"
                                    Background="Transparent" BorderThickness="0,0,0,2"
                                    BorderBrush="{DynamicResource AccentBrush}" Foreground="White"
                                    FontSize="15" FontWeight="SemiBold" Height="40"/>
                            <Button x:Name="BtnRegisterTab" Grid.Column="1" Content="Registrieren"
                                    Click="OnRegisterTabClick"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{DynamicResource TextMutedBrush}"
                                    FontSize="15" Height="40"/>
                        </Grid>

                        <!-- Login Panel -->
                        <StackPanel x:Name="LoginPanel">
                            <TextBox x:Name="TxtEmail"
                                     materialDesign:HintAssist.Hint="E-Mail"
                                     Style="{StaticResource PlaceholderTextBox}"
                                     Margin="0,0,0,16" Height="48"/>

                            <PasswordBox x:Name="PwdPassword"
                                         materialDesign:HintAssist.Hint="Passwort"
                                         Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                         Foreground="White" BorderBrush="{DynamicResource BorderBrush}"
                                         materialDesign:HintAssist.Foreground="{DynamicResource TextMutedBrush}"
                                         Margin="0,0,0,8" Height="48"/>

                            <CheckBox x:Name="ChkRememberMe" Content="Angemeldet bleiben" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,16"/>

                            <TextBlock x:Name="TxtError" Foreground="#FF4C61" FontSize="12"
                                       Margin="0,4,0,16" TextWrapping="Wrap" Visibility="Collapsed"/>

                            <Button x:Name="BtnLogin" Content="Anmelden" IsDefault="True"
                                    Click="OnLoginClick"
                                    Height="48" FontSize="16" FontWeight="Bold"
                                    Background="{DynamicResource AccentBrush}" Foreground="White"
                                    BorderThickness="0" Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            CornerRadius="8">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#7B74FF"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>

                        <!-- Register Panel -->
                        <StackPanel x:Name="RegisterPanel" Visibility="Collapsed">
                            <TextBox x:Name="TxtRegUsername"
                                     materialDesign:HintAssist.Hint="Benutzername"
                                     Style="{StaticResource PlaceholderTextBox}"
                                     Margin="0,0,0,16" Height="48"/>
                            <TextBox x:Name="TxtRegEmail"
                                     materialDesign:HintAssist.Hint="E-Mail"
                                     Style="{StaticResource PlaceholderTextBox}"
                                     Margin="0,0,0,16" Height="48"/>
                            <PasswordBox x:Name="PwdRegPassword"
                                         materialDesign:HintAssist.Hint="Passwort (min. 8 Zeichen)"
                                         Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                         Foreground="White" BorderBrush="{DynamicResource BorderBrush}"
                                         materialDesign:HintAssist.Foreground="{DynamicResource TextMutedBrush}"
                                         Margin="0,0,0,8" Height="48"/>

                            <TextBlock x:Name="TxtRegError" Foreground="#FF4C61" FontSize="12"
                                       Margin="0,4,0,16" TextWrapping="Wrap" Visibility="Collapsed"/>

                            <Button x:Name="BtnRegister" Content="Konto erstellen"
                                    Click="OnRegisterClick"
                                    Height="48" FontSize="16" FontWeight="Bold"
                                    Background="{DynamicResource AccentBrush}" Foreground="White"
                                    BorderThickness="0" Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            CornerRadius="8">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#7B74FF"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>

                        <!-- Footer -->
                        <TextBlock Text="MindForge v2.0 — KI-Lernplattform"
                                   Foreground="{DynamicResource BorderBrush}" FontSize="11"
                                   HorizontalAlignment="Center" Margin="0,32,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Drag Handle -->
            <Border Background="Transparent" MouseLeftButtonDown="OnDragWindow"
                    Height="40" VerticalAlignment="Top"/>
        </Grid>
    </Border>
</Window>


