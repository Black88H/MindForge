<UserControl x:Class="MindForge.Views.StudyCoachView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="🎓 KI-Lerncoach" Foreground="{DynamicResource TextBrush}"
                       FontSize="28" FontWeight="Bold"/>
            <TextBlock Text="Personalisierte Empfehlungen basierend auf deinen Lernmustern"
                       Foreground="{DynamicResource TextMutedBrush}" FontSize="14" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Quick Tip + Summary Cards -->
        <Grid Grid.Row="1" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Burnout Risk -->
            <Border Grid.Column="0" Background="{DynamicResource BgSecondaryBrush}"
                    CornerRadius="10" Padding="16" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="🔥 Burnout-Risiko" Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                    <TextBlock x:Name="TxtBurnout" Text="—"
                               Foreground="{DynamicResource AccentBrush}"
                               FontSize="20" FontWeight="Bold" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Daily Minutes -->
            <Border Grid.Column="1" Background="{DynamicResource BgSecondaryBrush}"
                    CornerRadius="10" Padding="16" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="⏱ Empf. Min/Tag" Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                    <TextBlock x:Name="TxtDailyMin" Text="—"
                               Foreground="{DynamicResource AccentBrush}"
                               FontSize="20" FontWeight="Bold" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Weekly Goal -->
            <Border Grid.Column="2" Background="{DynamicResource BgSecondaryBrush}"
                    CornerRadius="10" Padding="16" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="🎯 Wochenziel" Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                    <TextBlock x:Name="TxtWeeklyGoal" Text="—"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="12" TextWrapping="Wrap" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Encouragement -->
            <Border Grid.Column="3" Background="{DynamicResource BgSecondaryBrush}"
                    CornerRadius="10" Padding="16">
                <StackPanel>
                    <TextBlock Text="💬 Motivation" Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                    <TextBlock x:Name="TxtEncouragement" Text="—"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="12" TextWrapping="Wrap" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Main content: Recommendations list + Tip panel -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- Recommendations -->
            <Border Grid.Column="0" Background="{DynamicResource BgSecondaryBrush}"
                    CornerRadius="12" Padding="24" Margin="0,0,24,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock Text="📋 Empfehlungen" Foreground="{DynamicResource TextBrush}"
                                   FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Button x:Name="BtnRefresh" Content="🔄 Aktualisieren"
                                Click="OnRefresh" HorizontalAlignment="Right"
                                Background="{DynamicResource AccentBrush}" Foreground="White"
                                BorderThickness="0" Height="36" Padding="16,0" FontSize="13"/>
                    </Grid>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="RecsPanel">
                            <TextBlock x:Name="TxtLoading" Text="⏳ KI analysiert deine Lerndaten..."
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       FontSize="14" HorizontalAlignment="Center" Margin="0,40,0,0"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Tip panel -->
            <Border Grid.Column="1" Background="{DynamicResource BgSecondaryBrush}"
                    CornerRadius="12" Padding="24" VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock Text="💡 Tipp des Tages" Foreground="{DynamicResource TextBrush}"
                               FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>
                    <TextBlock x:Name="TxtTip" Text="Lade..."
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="13" TextWrapping="Wrap" LineHeight="20"/>
                    <Button Content="Neuer Tipp" Click="OnNewTip"
                            Background="{DynamicResource BgTertiaryBrush}"
                            Foreground="{DynamicResource TextMutedBrush}"
                            BorderThickness="0" Height="36" Margin="0,16,0,0" FontSize="13"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
