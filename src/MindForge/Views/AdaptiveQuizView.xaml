<UserControl x:Class="MindForge.Views.AdaptiveQuizView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="Transparent">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="🧠 Adaptiver Quiz" Foreground="{DynamicResource TextBrush}"
                       FontSize="28" FontWeight="Bold"/>
            <TextBlock Text="KI-generierte Fragen, die sich deinem Wissensstand anpassen"
                       Foreground="{DynamicResource TextMutedBrush}" FontSize="14" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- ── Setup Panel ─────────────────────────────────────────────────── -->
        <Border x:Name="SetupPanel" Grid.Row="1"
                Background="{DynamicResource BgSecondaryBrush}" CornerRadius="12" Padding="32">
            <StackPanel MaxWidth="560" HorizontalAlignment="Center">
                <TextBlock Text="Quiz konfigurieren" Foreground="{DynamicResource TextBrush}"
                           FontSize="22" FontWeight="SemiBold" Margin="0,0,0,24"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Notizbuch auswählen:" Foreground="{DynamicResource TextMutedBrush}"
                           FontSize="13" Margin="0,0,0,8"/>
                <ComboBox x:Name="CboNotebook"
                          Style="{StaticResource MaterialDesignComboBox}"
                          Foreground="{DynamicResource TextBrush}"
                          Height="44" Margin="0,0,0,20"
                          DisplayMemberPath="Name"/>

                <TextBlock Text="Schwierigkeitsgrad:" Foreground="{DynamicResource TextMutedBrush}"
                           FontSize="13" Margin="0,0,0,8"/>
                <ComboBox x:Name="CboDifficulty"
                          Style="{StaticResource MaterialDesignComboBox}"
                          Foreground="{DynamicResource TextBrush}"
                          SelectedIndex="1" Height="44" Margin="0,0,0,20">
                    <ComboBoxItem Content="Leicht"/>
                    <ComboBoxItem Content="Mittel"/>
                    <ComboBoxItem Content="Schwer"/>
                </ComboBox>

                <TextBlock Text="Anzahl Fragen:" Foreground="{DynamicResource TextMutedBrush}"
                           FontSize="13" Margin="0,0,0,8"/>
                <Slider x:Name="SlCount" Minimum="3" Maximum="20" Value="10"
                        TickFrequency="1" IsSnapToTickEnabled="True"
                        Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,4"/>
                <TextBlock x:Name="TxtCount" Text="10 Fragen"
                           Foreground="{DynamicResource AccentBrush}" FontSize="12"
                           HorizontalAlignment="Right" Margin="0,0,0,28"/>

                <Button Content="🚀 Quiz starten" x:Name="BtnStart"
                        Click="OnStartQuiz"
                        Background="{DynamicResource AccentBrush}" Foreground="White"
                        BorderThickness="0" Height="52" FontSize="16" FontWeight="SemiBold"/>

                <TextBlock x:Name="TxtSetupStatus" Text="" Margin="0,16,0,0"
                           Foreground="{DynamicResource TextMutedBrush}"
                           FontSize="13" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ── Quiz Panel ──────────────────────────────────────────────────── -->
        <Grid x:Name="QuizPanel" Grid.Row="1" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <!-- Question area -->
            <Border Grid.Column="0" Background="{DynamicResource BgSecondaryBrush}"
                    CornerRadius="12" Padding="32" Margin="0,0,24,0">
                <StackPanel>
                    <!-- Progress -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ProgressBar x:Name="PrgQuiz" Height="8"
                                     Foreground="{DynamicResource AccentBrush}"
                                     Background="{DynamicResource BgTertiaryBrush}"
                                     BorderThickness="0" Maximum="1" Value="0"/>
                        <TextBlock x:Name="TxtQNum" Grid.Column="1"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="13" Margin="16,0,0,0" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Question -->
                    <TextBlock x:Name="TxtQuestion"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="18" TextWrapping="Wrap"
                               LineHeight="28" Margin="0,0,0,28"/>

                    <!-- Options -->
                    <StackPanel x:Name="OptionsPanel"/>

                    <!-- Explanation (shown after answer) -->
                    <Border x:Name="ExplanationBorder" Visibility="Collapsed"
                            Background="{DynamicResource BgBrush}" CornerRadius="8"
                            Padding="16" Margin="0,20,0,0">
                        <StackPanel>
                            <TextBlock x:Name="TxtResult" FontSize="15" FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>
                            <TextBlock x:Name="TxtExplanation"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       FontSize="13" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Next button -->
                    <Button x:Name="BtnNext" Content="Nächste Frage ➜"
                            Click="OnNext"
                            Background="{DynamicResource AccentBrush}" Foreground="White"
                            BorderThickness="0" Height="48" Padding="24,0"
                            FontSize="15" HorizontalAlignment="Right"
                            Margin="0,20,0,0" Visibility="Collapsed"/>
                </StackPanel>
            </Border>

            <!-- Side panel: score tracker -->
            <Border Grid.Column="1" Background="{DynamicResource BgSecondaryBrush}"
                    CornerRadius="12" Padding="24" VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock Text="📈 Fortschritt" Foreground="{DynamicResource TextBrush}"
                               FontSize="16" FontWeight="SemiBold" Margin="0,0,0,20"/>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Richtig" Foreground="{DynamicResource TextMutedBrush}" FontSize="13"/>
                        <TextBlock x:Name="TxtCorrect" Text="0" Grid.Column="1"
                                   Foreground="#22C55E" FontSize="20" FontWeight="Bold"/>
                    </Grid>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Falsch" Foreground="{DynamicResource TextMutedBrush}" FontSize="13"/>
                        <TextBlock x:Name="TxtWrong" Text="0" Grid.Column="1"
                                   Foreground="#EF4444" FontSize="20" FontWeight="Bold"/>
                    </Grid>

                    <Separator Background="{DynamicResource BorderBrush}" Margin="0,8,0,12"/>

                    <TextBlock Text="Aktuelle Genauigkeit" Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="12" Margin="0,0,0,4"/>
                    <TextBlock x:Name="TxtAccuracy" Text="—"
                               Foreground="{DynamicResource AccentBrush}"
                               FontSize="24" FontWeight="Bold" Margin="0,0,0,16"/>

                    <Button Content="🏁 Quiz beenden" Click="OnAbort"
                            Background="{DynamicResource BgTertiaryBrush}"
                            Foreground="{DynamicResource TextMutedBrush}"
                            BorderThickness="0" Height="40" FontSize="13"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ── Result Panel ────────────────────────────────────────────────── -->
        <Border x:Name="ResultPanel" Grid.Row="1"
                Background="{DynamicResource BgSecondaryBrush}" CornerRadius="12" Padding="48"
                Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" MaxWidth="480">
                <TextBlock x:Name="TxtResultEmoji" Text="🏆" FontSize="64"
                           HorizontalAlignment="Center" Margin="0,0,0,16"/>
                <TextBlock x:Name="TxtFinalScore" Text="80%"
                           Foreground="{DynamicResource AccentBrush}"
                           FontSize="48" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock x:Name="TxtFinalCorrect" Text=""
                           Foreground="{DynamicResource TextMutedBrush}"
                           FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                <TextBlock x:Name="TxtFeedback" Text=""
                           Foreground="{DynamicResource TextBrush}"
                           FontSize="16" TextWrapping="Wrap"
                           HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock x:Name="TxtXP" Text="+50 XP"
                           Foreground="#22C55E" FontSize="18" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0,0,0,32"/>
                <Button Content="🔄 Nochmal Quiz starten" Click="OnRestartQuiz"
                        Background="{DynamicResource AccentBrush}" Foreground="White"
                        BorderThickness="0" Height="52" FontSize="16" FontWeight="SemiBold"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
