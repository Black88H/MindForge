<UserControl x:Class="MindForge.Views.MaterialsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="Transparent">
    
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <StackPanel HorizontalAlignment="Left">
                <TextBlock Text="Materialien" Foreground="White" FontSize="28" FontWeight="Bold"/>
                <TextBlock Text="Dokumente, PDFs und Notizen hochladen &amp; verwalten" Foreground="#8892B0" FontSize="14" Margin="0,4,0,0"/>
            </StackPanel>
            
            <Button HorizontalAlignment="Right" VerticalAlignment="Top" 
                    Content="📤 Datei hochladen" Height="40" Padding="16,0"
                    Background="#6C63FF" Foreground="White" BorderThickness="0" Cursor="Hand" FontWeight="SemiBold">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>

        <!-- List -->
        <Border Grid.Row="1" Background="#161B2E" CornerRadius="12" Padding="20">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="DATEINAME" Foreground="#8892B0" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1" Text="FACH" Foreground="#8892B0" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="2" Text="HOCHGELADEN AM" Foreground="#8892B0" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="3" Text="AKTIONEN" Foreground="#8892B0" FontSize="12" FontWeight="SemiBold" Width="80"/>
                    </Grid>
                    
                    <Separator Background="#252D45" Margin="0,0,0,16"/>

                    <!-- Item 1 -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBlock Text="📄" Margin="0,0,12,0"/>
                            <TextBlock Text="Skript_Informatik_1.pdf" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="Informatik" Foreground="#B0B8D1" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="Heute, 14:30" Foreground="#B0B8D1" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="3" Orientation="Horizontal" Width="80">
                            <Button Content="🔍" Background="Transparent" BorderThickness="0" Padding="4" Margin="0,0,8,0" ToolTip="Ansehen"/>
                            <Button Content="🗑️" Background="Transparent" BorderThickness="0" Padding="4" ToolTip="Löschen"/>
                        </StackPanel>
                    </Grid>

                    <Separator Background="#252D45" Margin="0,0,0,16"/>
                    
                    <!-- Item 2 -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBlock Text="📄" Margin="0,0,12,0"/>
                            <TextBlock Text="Zellteilung_Zusammenfassung.pdf" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="Biologie" Foreground="#B0B8D1" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="Gestern, 09:15" Foreground="#B0B8D1" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="3" Orientation="Horizontal" Width="80">
                            <Button Content="🔍" Background="Transparent" BorderThickness="0" Padding="4" Margin="0,0,8,0" ToolTip="Ansehen"/>
                            <Button Content="🗑️" Background="Transparent" BorderThickness="0" Padding="4" ToolTip="Löschen"/>
                        </StackPanel>
                    </Grid>

                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>