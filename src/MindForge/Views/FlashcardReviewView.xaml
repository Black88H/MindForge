<UserControl x:Class="MindForge.Views.FlashcardReviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <StackPanel>
                <TextBlock Text="🃏 Karteikarten-Review (SM-17)" Foreground="{DynamicResource TextBrush}"
                           FontSize="28" FontWeight="Bold"/>
                <TextBlock Text="Spaced Repetition mit adaptivem Schwierigkeitslevel"
                           Foreground="{DynamicResource TextMutedBrush}" FontSize="14" Margin="0,4,0,0"/>
            </StackPanel>
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock x:Name="TxtProgress" Text="0 / 0 Karten"
                           Foreground="{DynamicResource TextMutedBrush}" FontSize="13"
                           VerticalAlignment="Center" Margin="0,0,16,0"/>
                <TextBlock x:Name="TxtStreak" Text="🔥 0"
                           Foreground="#F97316" FontSize="15" FontWeight="Bold"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Content -->
        <Grid Grid.Row="1">

            <!-- Empty state -->
            <Border x:Name="EmptyPanel"
                    Background="{DynamicResource BgSecondaryBrush}" CornerRadius="12" Padding="48">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="🎉" FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    <TextBlock x:Name="TxtEmptyMsg" Text="Keine Karten fällig!"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="22" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock x:Name="TxtEmptySub" Text="Komm morgen wieder zum nächsten Review."
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="14" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Review panel -->
            <Grid x:Name="ReviewPanel" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="280"/>
                </Grid.ColumnDefinitions>

                <!-- Card -->
                <StackPanel Grid.Column="0" Margin="0,0,24,0">
                    <!-- Progress bar -->
                    <ProgressBar x:Name="PrgCards" Height="6" Maximum="1" Value="0"
                                 Foreground="{DynamicResource AccentBrush}"
                                 Background="{DynamicResource BgTertiaryBrush}"
                                 BorderThickness="0" Margin="0,0,0,20"/>

                    <!-- Front of card -->
                    <Border Background="{DynamicResource BgSecondaryBrush}"
                            CornerRadius="12" Padding="32" MinHeight="200"
                            Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="FRAGE" Foreground="{DynamicResource AccentBrush}"
                                       FontSize="11" FontWeight="Bold" Margin="0,0,0,16"/>
                            <TextBlock x:Name="TxtFront"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="20" TextWrapping="Wrap" LineHeight="30"/>
                        </StackPanel>
                    </Border>

                    <!-- Flip / Back -->
                    <Border x:Name="BackBorder" Background="{DynamicResource BgSecondaryBrush}"
                            CornerRadius="12" Padding="32" MinHeight="160" Visibility="Collapsed"
                            Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="ANTWORT" Foreground="#22C55E"
                                       FontSize="11" FontWeight="Bold" Margin="0,0,0,16"/>
                            <TextBlock x:Name="TxtBack"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="16" TextWrapping="Wrap" LineHeight="24"/>
                        </StackPanel>
                    </Border>

                    <!-- Show answer button -->
                    <Button x:Name="BtnFlip" Content="Antwort anzeigen 👁"
                            Click="OnFlip"
                            Background="{DynamicResource BgSecondaryBrush}"
                            Foreground="{DynamicResource TextBrush}"
                            BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}"
                            Height="48" FontSize="15"/>

                    <!-- Grade buttons (hidden until flipped) -->
                    <Border x:Name="GradePanel" Visibility="Collapsed" Margin="0,16,0,0">
                        <StackPanel>
                            <TextBlock Text="Wie gut hast du dich erinnert?"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       FontSize="13" Margin="0,0,0,12" HorizontalAlignment="Center"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Tag="1" Grid.Column="0" Click="OnGrade"
                                        Content="1&#10;Wieder" Height="60"
                                        Background="#7F1D1D" Foreground="White"
                                        BorderThickness="0" Margin="0,0,4,0"
                                        FontSize="12" FontWeight="SemiBold"/>
                                <Button Tag="2" Grid.Column="1" Click="OnGrade"
                                        Content="2&#10;Schwer" Height="60"
                                        Background="#7C2D12" Foreground="White"
                                        BorderThickness="0" Margin="0,0,4,0"
                                        FontSize="12" FontWeight="SemiBold"/>
                                <Button Tag="3" Grid.Column="2" Click="OnGrade"
                                        Content="3&#10;Ok" Height="60"
                                        Background="#713F12" Foreground="White"
                                        BorderThickness="0" Margin="0,0,4,0"
                                        FontSize="12" FontWeight="SemiBold"/>
                                <Button Tag="4" Grid.Column="3" Click="OnGrade"
                                        Content="4&#10;Gut" Height="60"
                                        Background="#14532D" Foreground="White"
                                        BorderThickness="0" Margin="0,0,4,0"
                                        FontSize="12" FontWeight="SemiBold"/>
                                <Button Tag="5" Grid.Column="4" Click="OnGrade"
                                        Content="5&#10;Perfekt" Height="60"
                                        Background="#052E16" Foreground="White"
                                        BorderThickness="0"
                                        FontSize="12" FontWeight="SemiBold"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Stats panel -->
                <Border Grid.Column="1" Background="{DynamicResource BgSecondaryBrush}"
                        CornerRadius="12" Padding="24" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="📊 SM-17 Info" Foreground="{DynamicResource TextBrush}"
                                   FontSize="16" FontWeight="SemiBold" Margin="0,0,0,20"/>

                        <TextBlock Text="Stabilität" Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                        <TextBlock x:Name="TxtStability" Text="—"
                                   Foreground="{DynamicResource AccentBrush}"
                                   FontSize="18" FontWeight="Bold" Margin="0,2,0,12"/>

                        <TextBlock Text="Wiederholbarkeit" Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                        <TextBlock x:Name="TxtRetrieval" Text="—"
                                   Foreground="{DynamicResource AccentBrush}"
                                   FontSize="18" FontWeight="Bold" Margin="0,2,0,12"/>

                        <TextBlock Text="Schwierigkeit" Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                        <TextBlock x:Name="TxtDifficulty" Text="—"
                                   Foreground="{DynamicResource AccentBrush}"
                                   FontSize="18" FontWeight="Bold" Margin="0,2,0,12"/>

                        <TextBlock Text="Nächste Wiederholung" Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                        <TextBlock x:Name="TxtNextReview" Text="—"
                                   Foreground="{DynamicResource AccentBrush}"
                                   FontSize="14" FontWeight="SemiBold" Margin="0,2,0,12"/>

                        <Separator Background="{DynamicResource BorderBrush}" Margin="0,8,0,16"/>

                        <TextBlock Text="Session" Foreground="{DynamicResource TextMutedBrush}" FontSize="12" FontWeight="SemiBold"/>
                        <Grid Margin="0,8,0,4">
                            <TextBlock Text="Korrekt" Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                            <TextBlock x:Name="TxtSessionCorrect" Text="0"
                                       Foreground="#22C55E" FontSize="14" FontWeight="Bold"
                                       HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid>
                            <TextBlock Text="Falsch" Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                            <TextBlock x:Name="TxtSessionWrong" Text="0"
                                       Foreground="#EF4444" FontSize="14" FontWeight="Bold"
                                       HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
