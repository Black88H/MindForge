<UserControl x:Class="MindForge.Views.MaterialLibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="Transparent"
             Loaded="OnLoaded">

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="📚 Material Library" Foreground="{DynamicResource TextBrush}"
                       FontSize="28" FontWeight="Bold"/>
            <TextBlock Text="Add, manage, and analyze your study materials with AI"
                       Foreground="{DynamicResource TextMutedBrush}" FontSize="14" Margin="0,4,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="340"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Subjects + Upload -->
            <Border Grid.Column="0" Background="{DynamicResource BgSecondaryBrush}" CornerRadius="12"
                    Padding="16" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Subject" Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <ComboBox x:Name="CboSubjects" ItemsSource="{Binding Subjects}"
                              SelectedItem="{Binding SelectedSubject}"
                              DisplayMemberPath="Name"
                              Style="{StaticResource MaterialDesignComboBox}"
                              Foreground="{DynamicResource TextBrush}"
                              Margin="0,0,0,16" Height="40"/>

                    <Separator Background="{DynamicResource BorderBrush}" Margin="0,0,0,16"/>

                    <TextBlock Text="Add Material" Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>

                    <Button Content="📁  Upload (PDF / Bild / TXT / …)" Click="OnUploadFileClick"
                            Background="{DynamicResource AccentBrush}" Foreground="White"
                            BorderThickness="0" Height="40" Margin="0,0,0,8">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#7B74FF"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtWebUrl"
                                 materialDesign:HintAssist.Hint="https://..."
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Foreground="{DynamicResource TextBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 Height="40" Margin="0,0,8,0"/>
                        <Button Grid.Column="1" Content="🌐" Click="OnAddUrlClick"
                                Background="{DynamicResource BgTertiaryBrush}"
                                Foreground="{DynamicResource TextBrush}"
                                BorderThickness="0" Width="44" Height="40"
                                ToolTip="Add web page"/>
                    </Grid>

                    <!-- Status shown in the page footer (Grid.Row=2) — no duplicate here -->
                </StackPanel>
            </Border>

            <!-- Center: Material List -->
            <Border Grid.Column="1" Background="{DynamicResource BgSecondaryBrush}"
                    CornerRadius="12" Padding="16" Margin="0,0,12,0"
                    AllowDrop="True"
                    x:Name="DropZoneBorder"
                    DragEnter="OnDragEnter" DragLeave="OnDragLeave" Drop="OnDrop">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBox Grid.Row="0" x:Name="TxtFilter"
                             materialDesign:HintAssist.Hint="🔍  Filter materials..."
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                             Foreground="{DynamicResource TextBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             Height="40" Margin="0,0,0,12"/>

                    <ListBox Grid.Row="1" x:Name="LstMaterials"
                             ItemsSource="{Binding Materials}"
                             SelectedItem="{Binding SelectedMaterial}"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12,8" Margin="0,0,0,4"
                                        Background="{DynamicResource BgTertiaryBrush}"
                                        CornerRadius="8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding OriginalFileName}"
                                                       Foreground="{DynamicResource TextBrush}"
                                                       FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Foreground="{DynamicResource TextMutedBrush}" FontSize="11">
                                                <Run Text="{Binding OriginalFormat}"/>
                                                <Run Text=" · "/>
                                                <Run Text="{Binding CreatedAt, StringFormat='{}{0:MMM dd, yyyy}'}"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1"
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   FontSize="11" VerticalAlignment="Center">
                                            <Run Text="{Binding TokenCount}"/>
                                            <Run Text=" tokens"/>
                                        </TextBlock>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Right: AI Panel — Grid so AI output fills all remaining height -->
            <Border Grid.Column="2" Background="{DynamicResource BgSecondaryBrush}"
                    CornerRadius="12" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- buttons -->
                        <RowDefinition Height="Auto"/>  <!-- separator -->
                        <RowDefinition Height="Auto"/>  <!-- "AI Output" label + busy bar -->
                        <RowDefinition Height="*"/>     <!-- AI output fills remaining space -->
                    </Grid.RowDefinitions>

                    <!-- Action buttons -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="AI Aktionen" Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="12" FontWeight="SemiBold" Margin="0,0,0,12"/>

                        <Button Content="📝  Zusammenfassen" Click="OnSummarizeClick"
                                Background="{DynamicResource AccentBrush}" Foreground="White"
                                BorderThickness="0" Height="40" Margin="0,0,0,8">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="🏷️  Themen extrahieren" Click="OnTopicsClick"
                                Background="{DynamicResource BgTertiaryBrush}" Foreground="{DynamicResource TextBrush}"
                                BorderThickness="0" Height="40" Margin="0,0,0,8">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="🗑️  Material löschen" Click="OnDeleteClick"
                                Background="#FF4C4C" Foreground="White"
                                BorderThickness="0" Height="40">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>

                    <Separator Grid.Row="1" Background="{DynamicResource BorderBrush}" Margin="0,0,0,12"/>

                    <!-- Label + busy indicator -->
                    <Grid Grid.Row="2" Margin="0,0,0,8">
                        <TextBlock Text="KI-Ausgabe" Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <ProgressBar x:Name="PrgBusy" IsIndeterminate="True" Height="3"
                                     Foreground="{DynamicResource AccentBrush}"
                                     VerticalAlignment="Bottom"
                                     Visibility="{Binding IsBusy,
                                         Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </Grid>

                    <!-- AI output — ScrollViewer fills star row, no hard MaxHeight cap -->
                    <Border Grid.Row="3" Background="{DynamicResource BgBrush}" CornerRadius="8" Padding="12">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="TxtAiOutput" Text="{Binding AiOutput}"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="13" TextWrapping="Wrap" LineHeight="20"/>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- Status bar -->
        <TextBlock Grid.Row="2" Text="{Binding StatusMessage}"
                   Foreground="{DynamicResource TextMutedBrush}" FontSize="12"
                   Margin="0,8,0,0"/>
    </Grid>
</UserControl>
