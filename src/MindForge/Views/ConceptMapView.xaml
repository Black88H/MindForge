<UserControl x:Class="MindForge.Views.ConceptMapView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="🕸 Konzept-Netzwerk" Foreground="{DynamicResource TextBrush}"
                           FontSize="28" FontWeight="Bold"/>
                <TextBlock Text="KI-generierte Wissenskarte deiner Lernmaterialien"
                           Foreground="{DynamicResource TextMutedBrush}" FontSize="14" Margin="0,4,0,0"/>
            </StackPanel>
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="BtnGenerate" Content="🔄 Neu generieren"
                        Click="OnGenerate"
                        Background="{DynamicResource AccentBrush}" Foreground="White"
                        BorderThickness="0" Height="40" Padding="16,0" FontSize="13" Margin="0,0,12,0"/>
                <Button Content="🔍 Neu anordnen" Click="OnRelayout"
                        Background="{DynamicResource BgSecondaryBrush}"
                        Foreground="{DynamicResource TextBrush}"
                        BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}"
                        Height="40" Padding="16,0" FontSize="13"/>
            </StackPanel>
        </Grid>

        <!-- Notebook selector -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Notizbuch:" Foreground="{DynamicResource TextMutedBrush}"
                       FontSize="13" VerticalAlignment="Center" Margin="0,0,12,0"/>
            <ComboBox x:Name="CboNotebook" Grid.Column="1"
                      Style="{StaticResource MaterialDesignComboBox}"
                      Foreground="{DynamicResource TextBrush}"
                      Height="40" DisplayMemberPath="Name"
                      SelectionChanged="OnNotebookChanged"/>
            <TextBlock x:Name="TxtNodeInfo" Grid.Column="3"
                       Foreground="{DynamicResource TextMutedBrush}"
                       FontSize="12" VerticalAlignment="Center"/>
        </Grid>

        <!-- Graph canvas area -->
        <Border Grid.Row="2" Background="{DynamicResource BgSecondaryBrush}"
                CornerRadius="12" ClipToBounds="True">
            <Grid>
                <!-- Status overlay -->
                <TextBlock x:Name="TxtStatus"
                           Text="Wähle ein Notizbuch und klicke 'Neu generieren'"
                           Foreground="{DynamicResource TextMutedBrush}"
                           FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="Visible"/>

                <!-- Force-directed canvas -->
                <Canvas x:Name="GraphCanvas"
                        MouseMove="OnCanvasMouseMove"
                        MouseLeftButtonDown="OnCanvasMouseDown"
                        MouseLeftButtonUp="OnCanvasMouseUp"
                        Background="Transparent"/>

                <!-- Legend -->
                <Border HorizontalAlignment="Right" VerticalAlignment="Bottom"
                        Background="{DynamicResource BgTertiaryBrush}"
                        CornerRadius="8" Padding="12" Margin="16">
                    <StackPanel>
                        <TextBlock Text="Legende" Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Ellipse Width="12" Height="12" Fill="#6366F1" Margin="0,0,8,0"/>
                            <TextBlock Text="Konzept" Foreground="{DynamicResource TextMutedBrush}" FontSize="11"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Ellipse Width="12" Height="12" Fill="#10B981" Margin="0,0,8,0"/>
                            <TextBlock Text="Definition" Foreground="{DynamicResource TextMutedBrush}" FontSize="11"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Ellipse Width="12" Height="12" Fill="#F59E0B" Margin="0,0,8,0"/>
                            <TextBlock Text="Prozess" Foreground="{DynamicResource TextMutedBrush}" FontSize="11"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="12" Height="12" Fill="#EF4444" Margin="0,0,8,0"/>
                            <TextBlock Text="Prinzip" Foreground="{DynamicResource TextMutedBrush}" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
