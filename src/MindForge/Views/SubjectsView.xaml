<UserControl x:Class="MindForge.Views.SubjectsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="Transparent">
    
    <Grid>
        <Grid Margin="32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,24">
                <StackPanel HorizontalAlignment="Left">
                    <TextBlock Text="Deine Fächer" Foreground="White" FontSize="28" FontWeight="Bold"/>
                    <TextBlock Text="Verwalte deine Lernbereiche und Module" Foreground="#8892B0" FontSize="14" Margin="0,4,0,0"/>
                </StackPanel>
                
                <Button HorizontalAlignment="Right" VerticalAlignment="Top" Click="OnAddSubjectClick"
                        Content="+ Neues Fach" Height="40" Padding="16,0"
                        Background="#6C63FF" Foreground="White" BorderThickness="0" Cursor="Hand" FontWeight="SemiBold">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="SubjectsList">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="12" Padding="20" Margin="0,0,20,20" Width="280" BorderThickness="1">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#161B2E"/>
                                        <Setter Property="BorderBrush" Value="#161B2E"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="BorderBrush" Value="#6C63FF"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <!-- Delete Button -->
                                    <Button HorizontalAlignment="Right" VerticalAlignment="Top" 
                                            Content="✕" Foreground="#FF4C61" Background="Transparent" 
                                            BorderThickness="0" Padding="0" Margin="0,-10,-10,0"
                                            Click="OnDeleteSubjectClick" Tag="{Binding Id}">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Opacity" Value="0"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=IsMouseOver}" Value="True">
                                                        <Setter Property="Opacity" Value="1"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                    <StackPanel>
                                        <Border Background="#1E2640" CornerRadius="8" Width="48" Height="48" HorizontalAlignment="Left" Margin="0,0,0,16">
                                            <TextBlock Text="{Binding Icon}" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="{Binding Name}" Foreground="White" FontSize="20" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Subtitle}" Foreground="#8892B0" FontSize="12" Margin="0,4,0,16"/>
                                        
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Fortschritt" Foreground="#8892B0" FontSize="11"/>
                                                <!-- Dynamic color based on progress can be done with value converters, sticking to accent for simplicity -->
                                                <ProgressBar Value="{Binding Progress}" Maximum="100" Height="6" Margin="0,4,16,0" Foreground="#6C63FF" Background="#1E2640" BorderThickness="0"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding Progress, StringFormat={}{0:0.0000}%}" Foreground="White" FontSize="12" VerticalAlignment="Bottom" FontWeight="SemiBold"/>
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- Modal Overlay -->
        <Border x:Name="ModalOverlay" Background="#99000000" Visibility="Collapsed">
            <Border Background="#161B2E" CornerRadius="12" Padding="32" Width="400" HorizontalAlignment="Center" VerticalAlignment="Center" BorderBrush="#3A4060" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Neues Fach" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,0,0,24"/>
                    
                    <TextBlock Text="Name des Fachs" Foreground="#8892B0" FontSize="12" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtSubjectName" Background="#0D1117" Foreground="White" BorderBrush="#3A4060" Height="40" Padding="8,0" Margin="0,0,0,16"/>
                    
                    <TextBlock Text="Untertitel / Thema" Foreground="#8892B0" FontSize="12" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtSubjectSubtitle" Background="#0D1117" Foreground="White" BorderBrush="#3A4060" Height="40" Padding="8,0" Margin="0,0,0,16"/>
                    
                    <TextBlock Text="Icon (Emoji)" Foreground="#8892B0" FontSize="12" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtSubjectIcon" Text="📚" Background="#0D1117" Foreground="White" BorderBrush="#3A4060" Height="40" Padding="8,0" Margin="0,0,0,24"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Abbrechen" Click="OnCancelModalClick" Background="Transparent" Foreground="#8892B0" BorderThickness="0" Margin="0,0,8,0"/>
                        <Button Grid.Column="1" Content="Speichern" Click="OnSaveSubjectClick" Background="#6C63FF" Foreground="White" BorderThickness="0"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>