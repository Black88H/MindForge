<UserControl x:Class="MindForge.Views.SubjectsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>

        <!-- ── Shared TextBox template ── -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background"               Value="{DynamicResource BgBrush}"/>
            <Setter Property="Foreground"               Value="White"/>
            <Setter Property="CaretBrush"               Value="{DynamicResource AccentBrush}"/>
            <Setter Property="SelectionBrush"           Value="{DynamicResource AccentBrush}"/>
            <Setter Property="SelectionOpacity"         Value="0.35"/>
            <Setter Property="BorderBrush"              Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="Padding"                  Value="12,0"/>
            <Setter Property="Height"                   Value="44"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize"                 Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#55FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush"    Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="bd" Property="BorderThickness" Value="1.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Multiline TextBox ── -->
        <Style x:Key="ModernTextBoxMulti" TargetType="TextBox" BasedOn="{StaticResource ModernTextBox}">
            <Setter Property="Height"                   Value="Auto"/>
            <Setter Property="AcceptsReturn"            Value="True"/>
            <Setter Property="TextWrapping"             Value="Wrap"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="Padding"                  Value="12,8"/>
            <Setter Property="VerticalContentAlignment" Value="Top"/>
        </Style>

        <!-- ── Emoji button ── -->
        <Style x:Key="EmojiBtn" TargetType="Button">
            <Setter Property="Width"           Value="36"/>
            <Setter Property="Height"          Value="36"/>
            <Setter Property="FontSize"        Value="19"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{DynamicResource BgBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Primary button ── -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="24,0"/>
            <Setter Property="Height"          Value="42"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Opacity" Value="0.65"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bg" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Ghost button ── -->
        <Style x:Key="GhostBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextMutedBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Padding"         Value="20,0"/>
            <Setter Property="Height"          Value="42"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#14FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Close (×) button ── -->
        <Style x:Key="CloseBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextMutedBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width"           Value="32"/>
            <Setter Property="Height"          Value="32"/>
            <Setter Property="FontSize"        Value="15"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="Transparent" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#22FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Pill / tool button ── -->
        <Style x:Key="ToolBtn" TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource BgTertiaryBrush}"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="Height"          Value="40"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="8"
                                Padding="14,0">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Opacity" Value="0.75"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bg" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Icon button (small square) ── -->
        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextMutedBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width"           Value="30"/>
            <Setter Property="Height"          Value="30"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="Transparent" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#22FFFFFF"/>
                                <Setter Property="Foreground" Value="#FF4C61"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Card button (transparent, fills entire area) ── -->
        <Style x:Key="CardBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment"   Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <!-- ═══════════════════════════════════════════════════════════════════════
         ROOT GRID — all overlays stacked here (last = on top)
         ═══════════════════════════════════════════════════════════════════════ -->
    <Grid>

        <!-- ── Level 1: Subjects grid ── -->
        <Grid Margin="32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,24">
                <StackPanel HorizontalAlignment="Left">
                    <TextBlock Text="Deine Fächer" Foreground="White" FontSize="28" FontWeight="Bold"/>
                    <TextBlock Text="Verwalte deine Lernbereiche — klicke ein Fach um Notizbücher zu öffnen"
                               Foreground="{DynamicResource TextMutedBrush}" FontSize="14" Margin="0,4,0,0"/>
                </StackPanel>
                <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                        Click="OnAddSubjectClick" Height="40" Padding="16,0"
                        Background="{DynamicResource AccentBrush}" Foreground="White"
                        BorderThickness="0" Cursor="Hand" FontWeight="SemiBold">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="8">
                                            <StackPanel Orientation="Horizontal" Margin="16,0" VerticalAlignment="Center">
                                                <TextBlock Text="+" FontSize="18" FontWeight="Bold" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="Neues Fach" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bg" Property="Opacity" Value="0.82"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <!-- Subject cards -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="SubjectsList">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- Entire card is a transparent button → fires OnSubjectCardClick -->
                            <Button Style="{StaticResource CardBtn}"
                                    Tag="{Binding}"
                                    Click="OnSubjectCardClick"
                                    Margin="0,0,20,20">
                                <Border CornerRadius="12" Padding="20" Width="280" BorderThickness="1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background"  Value="{DynamicResource BgSecondaryBrush}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource BgSecondaryBrush}"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <!-- Delete button (top-right) -->
                                        <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                                                Content="✕" Foreground="#FF4C61" Background="Transparent"
                                                BorderThickness="0" Padding="0" Margin="0,-10,-10,0"
                                                Click="OnDeleteSubjectClick" Tag="{Binding Id}">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Opacity" Value="0"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=IsMouseOver}" Value="True">
                                                            <Setter Property="Opacity" Value="1"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <StackPanel>
                                            <Border Background="{DynamicResource BgTertiaryBrush}" CornerRadius="8"
                                                    Width="48" Height="48" HorizontalAlignment="Left" Margin="0,0,0,16">
                                                <TextBlock Text="{Binding Icon}" FontSize="24"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="{Binding Name}" Foreground="White" FontSize="20" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Subtitle}" Foreground="{DynamicResource TextMutedBrush}"
                                                       FontSize="12" Margin="0,4,0,16"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Fortschritt" Foreground="{DynamicResource TextMutedBrush}" FontSize="11"/>
                                                    <ProgressBar Value="{Binding Progress}" Maximum="100" Height="6" Margin="0,4,16,0"
                                                                 Foreground="{DynamicResource AccentBrush}"
                                                                 Background="{DynamicResource BgTertiaryBrush}" BorderThickness="0"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Progress, StringFormat={}{0:0}%}"
                                                           Foreground="White" FontSize="12" VerticalAlignment="Bottom" FontWeight="SemiBold"/>
                                            </Grid>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- ══════════════════════════════════════════════════════════════════
             NEUES FACH modal
             ══════════════════════════════════════════════════════════════════ -->
        <Border x:Name="ModalOverlay" Background="#BB000000" Visibility="Collapsed"
                PreviewKeyDown="OnModalKeyDown">
            <Border Background="{DynamicResource BgSecondaryBrush}" CornerRadius="16" Width="480"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" BlurRadius="48" ShadowDepth="0" Opacity="0.55"/>
                </Border.Effect>
                <StackPanel>
                    <Grid Margin="28,24,20,0">
                        <StackPanel>
                            <TextBlock Text="Neues Fach erstellen" Foreground="White" FontSize="20" FontWeight="Bold"/>
                            <TextBlock Text="Füge ein Fach hinzu und wähle ein passendes Icon"
                                       Foreground="{DynamicResource TextMutedBrush}" FontSize="13" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Button Style="{StaticResource CloseBtn}" HorizontalAlignment="Right" VerticalAlignment="Top"
                                Content="✕" Click="OnCancelModalClick"/>
                    </Grid>
                    <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,16,0,0"/>
                    <StackPanel Margin="28,20,28,0">
                        <TextBlock Text="FACHNAME" Foreground="{DynamicResource TextMutedBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                        <TextBox x:Name="TxtSubjectName" Style="{StaticResource ModernTextBox}" Margin="0,0,0,4"/>
                        <TextBlock x:Name="TxtNameError" Text="Bitte gib einen Namen ein."
                                   Foreground="#FF4C61" FontSize="11" Margin="2,0,0,12" Visibility="Collapsed"/>
                        <TextBlock Text="BESCHREIBUNG" Foreground="{DynamicResource TextMutedBrush}" FontSize="11" FontWeight="Bold" Margin="0,4,0,6"/>
                        <TextBox x:Name="TxtSubjectSubtitle" Style="{StaticResource ModernTextBox}" Margin="0,0,0,20"/>
                        <TextBlock Text="FACH-ICON" Foreground="{DynamicResource TextMutedBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="64"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" CornerRadius="10" Background="{DynamicResource BgBrush}"
                                    BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1.5"
                                    Width="64" Height="64">
                                <TextBlock x:Name="TxtEmojiPreview" Text="📚" FontSize="30"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border Grid.Column="2" Background="{DynamicResource BgBrush}" CornerRadius="8"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="4">
                                <ScrollViewer MaxHeight="148" VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <WrapPanel x:Name="EmojiPalette" Orientation="Horizontal"/>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                        <TextBox x:Name="TxtSubjectIcon" Visibility="Collapsed" Text="📚"/>
                    </StackPanel>
                    <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,20,0,0"/>
                    <Grid Margin="28,16,28,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Style="{StaticResource GhostBtn}" Content="Abbrechen" Click="OnCancelModalClick"/>
                        <Button Grid.Column="2" Style="{StaticResource PrimaryBtn}" Click="OnSaveSubjectClick">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="✓" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Fach erstellen" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>
        </Border>

        <!-- ══════════════════════════════════════════════════════════════════
             LEVEL 2: NOTEBOOKS OVERLAY  (slide-in from right)
             ══════════════════════════════════════════════════════════════════ -->
        <Grid x:Name="NotebooksOverlay" Visibility="Collapsed">
            <!-- Dark backdrop — click to close -->
            <Rectangle Fill="#88000000" MouseLeftButtonDown="OnNotebooksBackdropClick"/>

            <!-- Slide-in panel -->
            <Border x:Name="NotebooksPanel" Width="680" HorizontalAlignment="Right"
                    Background="{DynamicResource BgSecondaryBrush}">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="NotebooksPanelTransform" X="0"/>
                </Border.RenderTransform>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0" Background="{DynamicResource BgBrush}" Padding="28,20">
                        <Grid>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock x:Name="TxtNbSubjectIcon" Text="📚" FontSize="28" Margin="0,0,12,0"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock x:Name="TxtNbSubjectName" Text="Fach"
                                                   Foreground="White" FontSize="22" FontWeight="Bold"/>
                                        <TextBlock x:Name="TxtNbSubjectSubtitle" Text=""
                                                   Foreground="{DynamicResource TextMutedBrush}" FontSize="13"/>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Gesamtfortschritt:" Foreground="{DynamicResource TextMutedBrush}" FontSize="12" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TxtNbSubjectProgress" Text="0%"
                                               Foreground="{DynamicResource AccentBrush}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                            <Button Style="{StaticResource CloseBtn}" HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Content="✕" Click="OnCloseNotebooksClick" Width="36" Height="36" FontSize="16"/>
                        </Grid>
                    </Border>

                    <!-- Notebooks list -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="28,20">
                        <StackPanel>
                            <!-- Empty state -->
                            <StackPanel x:Name="NbEmptyState" HorizontalAlignment="Center" Margin="0,60,0,0">
                                <TextBlock Text="📓" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                                <TextBlock Text="Noch keine Notizbücher" Foreground="White" FontSize="16"
                                           FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                <TextBlock Text="Erstelle dein erstes Notizbuch, um mit dem Lernen zu beginnen."
                                           Foreground="{DynamicResource TextMutedBrush}" FontSize="13"
                                           HorizontalAlignment="Center" TextAlignment="Center" Margin="0,8,0,0"/>
                            </StackPanel>

                            <!-- Notebooks -->
                            <ItemsControl x:Name="NotebooksList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource CardBtn}"
                                                Tag="{Binding}"
                                                Click="OnNotebookCardClick"
                                                Margin="0,0,0,12">
                                            <Border CornerRadius="10" Padding="18,14" BorderThickness="1">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background"  Value="{DynamicResource BgTertiaryBrush}"/>
                                                        <Setter Property="BorderBrush" Value="{DynamicResource BgTertiaryBrush}"/>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <!-- Delete -->
                                                    <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                                                            Content="✕" Foreground="#FF4C61" Background="Transparent"
                                                            BorderThickness="0" Padding="0"
                                                            Click="OnDeleteNotebookClick" Tag="{Binding Id}">
                                                        <Button.Style>
                                                            <Style TargetType="Button">
                                                                <Setter Property="Opacity" Value="0"/>
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="Button">
                                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=IsMouseOver}" Value="True">
                                                                        <Setter Property="Opacity" Value="1"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Name}" Foreground="White"
                                                                   FontSize="16" FontWeight="SemiBold"/>
                                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,10">
                                                            <TextBlock Text="Zuletzt bearbeitet: " Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                                                            <TextBlock Text="{Binding LastModifiedLabel}" Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                                                        </StackPanel>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <ProgressBar Value="{Binding Progress}" Maximum="100" Height="5"
                                                                         Foreground="{DynamicResource AccentBrush}"
                                                                         Background="{DynamicResource BgBrush}" BorderThickness="0"/>
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding Progress, StringFormat={}{0:0}%}"
                                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                                       FontSize="11" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Footer: + New Notebook -->
                    <Border Grid.Row="2" Background="{DynamicResource BgBrush}" Padding="28,16">
                        <Button Style="{StaticResource PrimaryBtn}" HorizontalAlignment="Left"
                                Click="OnAddNotebookClick">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="+" FontSize="18" FontWeight="Bold" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Neues Notizbuch" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- ══════════════════════════════════════════════════════════════════
             LEVEL 3: NOTEBOOK DETAIL (full-screen overlay)
             ══════════════════════════════════════════════════════════════════ -->
        <Grid x:Name="NotebookDetailOverlay" Visibility="Collapsed"
              Background="{DynamicResource BgBrush}">
            <Grid.RenderTransform>
                <TranslateTransform x:Name="DetailPanelTransform" X="0"/>
            </Grid.RenderTransform>
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>    <!-- Header bar -->
                <RowDefinition Height="Auto"/>  <!-- Ollama warning -->
                <RowDefinition Height="Auto"/>  <!-- Settings panel (collapsible) -->
                <RowDefinition Height="*"/>     <!-- Main content -->
            </Grid.RowDefinitions>

            <!-- ── Header bar ── -->
            <Border Grid.Row="0" Background="{DynamicResource BgSecondaryBrush}" Padding="20,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Back -->
                    <Button Grid.Column="0" Style="{StaticResource GhostBtn}" Height="36"
                            Padding="14,0" Click="OnDetailBack" Margin="0,0,16,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="←" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Zurück" VerticalAlignment="Center" FontSize="13"/>
                        </StackPanel>
                    </Button>

                    <!-- Breadcrumb -->
                    <TextBlock Grid.Column="1" x:Name="TxtDetailBreadcrumb"
                               Text="Fach › Notizbuch" Foreground="White"
                               FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>

                    <!-- Progress -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                        <ProgressBar x:Name="PrgDetailProgress" Width="120" Height="6" Value="0" Maximum="100"
                                     Foreground="{DynamicResource AccentBrush}"
                                     Background="{DynamicResource BgTertiaryBrush}"
                                     BorderThickness="0" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock x:Name="TxtDetailProgress" Text="0%"
                                   Foreground="{DynamicResource AccentBrush}" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Settings toggle button -->
                    <Button Grid.Column="3" x:Name="BtnToggleSettings"
                            Style="{StaticResource GhostBtn}"
                            Height="36" Padding="12,0" Click="OnToggleSettings"
                            Content="⚙ Einstellungen" FontSize="13"/>
                </Grid>
            </Border>

            <!-- ── Ollama warning bar ── -->
            <Border Grid.Row="1" x:Name="OllamaStatusBar" Visibility="Collapsed"
                    Background="#CC3D1A" Padding="20,10">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="❌ Keine Verbindung zu Ollama" Foreground="White" FontWeight="Bold" FontSize="13"/>
                        <TextBlock FontSize="11" Foreground="#FFCCAA" Margin="0,4,0,0">
                            So beheben: 1) Ollama installieren (ollama.ai)  2) ollama serve  3) ollama pull llama3.2
                        </TextBlock>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource GhostBtn}" Height="32" Padding="12,0" FontSize="12"
                                Content="🔄 Erneut versuchen" Click="OnRetryOllamaClick" Margin="0,0,8,0"/>
                        <Button Style="{StaticResource CloseBtn}" Content="✕"
                                Click="OnRetryOllamaClick"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Settings panel (collapsible, hidden by default) ── -->
            <Border Grid.Row="2" x:Name="SettingsContent" Visibility="Collapsed"
                    Background="{DynamicResource BgSecondaryBrush}" Padding="20,16"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="LERNLEVEL" Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                        <ComboBox x:Name="CboLearningLevel" Height="36"
                                  SelectionChanged="OnLearningLevelChanged"
                                  Foreground="{DynamicResource TextBrush}"
                                  Background="{DynamicResource BgBrush}">
                            <ComboBoxItem Content="Anfänger"/>
                            <ComboBoxItem Content="Fortgeschritten" IsSelected="True"/>
                            <ComboBoxItem Content="Experte"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="ERKLÄRUNGSSTIL" Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                        <ComboBox x:Name="CboExplanationStyle" Height="36"
                                  SelectionChanged="OnExplanationStyleChanged"
                                  Foreground="{DynamicResource TextBrush}"
                                  Background="{DynamicResource BgBrush}">
                            <ComboBoxItem Content="Normal" IsSelected="True"/>
                            <ComboBoxItem Content="Wie für 5-Jährige"/>
                            <ComboBoxItem Content="Technisch/Präzise"/>
                            <ComboBoxItem Content="Mit Beispielen"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Text="SPRACHE" Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                        <ComboBox x:Name="CboLanguage" Height="36"
                                  Foreground="{DynamicResource TextBrush}"
                                  Background="{DynamicResource BgBrush}"
                                  SelectionChanged="OnLanguageChanged">
                            <ComboBoxItem Content="Deutsch" IsSelected="True"/>
                            <ComboBoxItem Content="English"/>
                            <ComboBoxItem Content="Français"/>
                            <ComboBoxItem Content="Español"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Main content: 2-column layout with vertical GridSplitter ── -->
            <Grid Grid.Row="3" Margin="20,16,20,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="400"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition x:Name="RightToolColDef" Width="300" MinWidth="200" MaxWidth="520"/>
                </Grid.ColumnDefinitions>

                <!-- Vertical splitter: left ↔ right -->
                <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              Background="{DynamicResource BgTertiaryBrush}"
                              ShowsPreview="True" Cursor="SizeWE"/>

                <!-- ╔══════════════════════════════╗
                     ║  LEFT: Materials + Chat      ║
                     ╚══════════════════════════════╝ -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="190" MinHeight="80"/>  <!-- Materials (resizable) -->
                        <RowDefinition Height="5"/>                   <!-- Horizontal splitter -->
                        <RowDefinition Height="*" MinHeight="180"/>   <!-- Chat history -->
                        <RowDefinition Height="Auto"/>                <!-- Chat input -->
                    </Grid.RowDefinitions>

                    <!-- Horizontal splitter: materials ↔ chat -->
                    <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch"
                                  Background="{DynamicResource BgTertiaryBrush}"
                                  ShowsPreview="True" Cursor="SizeNS"/>

                    <!-- Materials section (card grid) with drag-and-drop -->
                    <Border Grid.Row="0" Background="{DynamicResource BgSecondaryBrush}"
                            CornerRadius="10" Padding="14" Margin="0,0,12,0"
                            AllowDrop="True" Drop="OnMaterialDrop" DragEnter="OnMaterialDragEnter"
                            DragLeave="OnMaterialDragLeave"
                            x:Name="MaterialsDropZone">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="📎 Materialien" Foreground="White" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TxtDropHint" Text="  — Dateien hierher ziehen"
                                               Foreground="{DynamicResource TextMutedBrush}" FontSize="11"
                                               VerticalAlignment="Center" Visibility="Collapsed"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Style="{StaticResource GhostBtn}"
                                            Height="30" Padding="10,0" FontSize="11" Margin="0,0,6,0"
                                            Content="🌐 URL" Click="OnImportUrlClick" ToolTip="Webseite importieren"/>
                                    <Button Style="{StaticResource PrimaryBtn}"
                                            Height="30" Padding="10,0" FontSize="11" Margin="0,0,6,0"
                                            Content="📁 Hochladen" Click="OnUploadFileClick"/>
                                    <Button Style="{StaticResource PrimaryBtn}"
                                            Height="30" Padding="10,0" FontSize="11"
                                            Content="+ Text" Click="OnPasteTextClick"/>
                                </StackPanel>
                            </Grid>
                            <!-- Material cards (WrapPanel grid, scrollable) -->
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <WrapPanel x:Name="DetailMaterialsWrap" Orientation="Horizontal">
                                    <ItemsControl x:Name="DetailMaterialsList">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource BgBrush}" CornerRadius="8"
                                                        Padding="10,8" Margin="0,0,8,8" Width="150"
                                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                                    <StackPanel>
                                                        <Grid Margin="0,0,0,4">
                                                            <TextBlock Text="{Binding Icon}" FontSize="22" VerticalAlignment="Center"/>
                                                            <Button Style="{StaticResource IconBtn}"
                                                                    HorizontalAlignment="Right" VerticalAlignment="Top"
                                                                    Content="✕" Click="OnDeleteMaterialClick" Tag="{Binding Id}"
                                                                    FontSize="10" Width="20" Height="20" Padding="0"/>
                                                        </Grid>
                                                        <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextBrush}"
                                                                   FontSize="12" TextWrapping="Wrap"
                                                                   TextTrimming="CharacterEllipsis" MaxHeight="36"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </WrapPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <!-- Chat history (Row 2, after GridSplitter Row 1) -->
                    <Border Grid.Row="2" Background="{DynamicResource BgSecondaryBrush}"
                            CornerRadius="10" Margin="0,6,12,6" Padding="14">
                        <ScrollViewer x:Name="ChatScrollViewer" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <!-- Welcome message -->
                                <Border Background="{DynamicResource BgTertiaryBrush}" CornerRadius="10"
                                        Padding="12,10" Margin="0,0,80,12" HorizontalAlignment="Left">
                                    <StackPanel>
                                        <TextBlock Text="🤖 KI-Assistent" Foreground="{DynamicResource AccentBrush}"
                                                   FontWeight="SemiBold" FontSize="12" Margin="0,0,0,4"/>
                                        <TextBlock Text="Hallo! Ich bin dein Lernassistent. Stelle mir Fragen zu deinen Materialien oder bitte mich, Konzepte zu erklären."
                                                   Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap" FontSize="13" LineHeight="20"/>
                                    </StackPanel>
                                </Border>

                                <!-- Chat messages -->
                                <ItemsControl x:Name="DetailChatHistory">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,12">
                                                <!-- User bubble (right-aligned, accent) -->
                                                <Border x:Name="UserBubble"
                                                        HorizontalAlignment="Right" MaxWidth="480"
                                                        Background="{DynamicResource AccentBrush}"
                                                        CornerRadius="16,16,4,16" Padding="14,10" Margin="80,0,0,0">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Content}" Foreground="White"
                                                                   TextWrapping="Wrap" FontSize="13" LineHeight="20"/>
                                                        <TextBlock Text="{Binding Time}"
                                                                   Foreground="#AAFFFFFF" FontSize="10"
                                                                   HorizontalAlignment="Right" Margin="0,4,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                                <!-- AI bubble (left-aligned, drop shadow) -->
                                                <Border x:Name="AiBubble"
                                                        HorizontalAlignment="Left" MaxWidth="540"
                                                        Background="{DynamicResource BgTertiaryBrush}"
                                                        CornerRadius="4,16,16,16" Padding="14,10" Margin="0,0,80,0">
                                                    <Border.Effect>
                                                        <DropShadowEffect BlurRadius="10" ShadowDepth="2"
                                                                          Opacity="0.18" Color="#000000"/>
                                                    </Border.Effect>
                                                    <StackPanel>
                                                        <TextBlock Text="🤖 KI-Assistent" Foreground="{DynamicResource AccentBrush}"
                                                                   FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                                        <TextBlock Text="{Binding Content}" Foreground="{DynamicResource TextBrush}"
                                                                   TextWrapping="Wrap" FontSize="13" LineHeight="20"/>
                                                        <TextBlock Text="{Binding Time}"
                                                                   Foreground="{DynamicResource TextMutedBrush}" FontSize="10"
                                                                   HorizontalAlignment="Right" Margin="0,4,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                    <Setter TargetName="AiBubble"  Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsUser}" Value="False">
                                                    <Setter TargetName="UserBubble" Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Streaming bubble (typing indicator) -->
                                <Border x:Name="StreamingBubble" Visibility="Collapsed"
                                        HorizontalAlignment="Left" MaxWidth="540"
                                        Background="{DynamicResource BgTertiaryBrush}"
                                        CornerRadius="4,16,16,16" Padding="14,10" Margin="0,0,80,12">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="10" ShadowDepth="2"
                                                          Opacity="0.18" Color="#000000"/>
                                    </Border.Effect>
                                    <StackPanel>
                                        <TextBlock Text="🤖 KI-Assistent" Foreground="{DynamicResource AccentBrush}"
                                                   FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                        <TextBlock x:Name="TxtStreamingContent" Foreground="{DynamicResource TextBrush}"
                                                   TextWrapping="Wrap" FontSize="13" LineHeight="20"/>
                                        <TextBlock Text="● ● ●" Foreground="{DynamicResource AccentBrush}"
                                                   FontSize="10" Margin="0,6,0,0" Opacity="0.6"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <!-- Chat input (Row 3, after chat area) -->
                    <Grid Grid.Row="3" Margin="0,0,12,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <!-- Clear chat history -->
                        <Button Grid.Column="0" Style="{StaticResource GhostBtn}"
                                Width="44" Height="44" Padding="0" FontSize="16"
                                Content="🗑" Click="OnClearChatClick"
                                ToolTip="Chat-Verlauf leeren"/>
                        <TextBox Grid.Column="2" x:Name="TxtChatInput"
                                 Height="44"
                                 KeyDown="OnChatKeyDown">
                            <TextBox.Style>
                                <Style TargetType="TextBox" BasedOn="{StaticResource ModernTextBox}">
                                    <Setter Property="Tag" Value="Frage stellen… (Enter zum Senden)"/>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                        <Button Grid.Column="4" x:Name="BtnStopChat"
                                Style="{StaticResource PrimaryBtn}"
                                Background="#FF4C4C" Width="44" Height="44" Padding="0"
                                Content="⏹" FontSize="16" Visibility="Collapsed"
                                Click="OnStopChatClick"/>
                        <Button Grid.Column="6" x:Name="BtnSendChat"
                                Style="{StaticResource PrimaryBtn}"
                                Width="90" Height="44" Padding="0"
                                Click="OnSendChatClick">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Senden" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="↑" FontSize="16" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>

                <!-- ╔═══════════════════════════╗
                     ║  RIGHT: Learning Tools    ║
                     ╚═══════════════════════════╝ -->
                <Grid Grid.Column="2" Margin="12,0,0,0">
                    <!-- Collapsed strip: narrow pill, expand arrow (shown when sidebar hidden) -->
                    <Border x:Name="ToolbarCollapsedStrip"
                            Width="32" HorizontalAlignment="Left"
                            Background="{DynamicResource BgSecondaryBrush}"
                            CornerRadius="10" Visibility="Collapsed">
                        <Button Content="›" FontSize="18" FontWeight="Bold"
                                VerticalAlignment="Top" Margin="0,12,0,0"
                                Style="{StaticResource GhostBtn}"
                                ToolTip="Werkzeuge einblenden"
                                Click="OnToggleToolSidebar"/>
                    </Border>

                    <!-- Expanded content -->
                    <ScrollViewer x:Name="RightToolScrollViewer"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- Header with collapse toggle -->
                            <Grid Margin="0,0,0,14">
                                <TextBlock Text="🛠 Lernwerkzeuge" Foreground="White"
                                           FontSize="16" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <Button Content="‹" FontSize="16" FontWeight="Bold"
                                        HorizontalAlignment="Right"
                                        Style="{StaticResource GhostBtn}"
                                        ToolTip="Werkzeuge ausblenden"
                                        Click="OnToggleToolSidebar"/>
                            </Grid>

                        <StackPanel x:Name="PanelToolButtons">
                            <Button Style="{StaticResource ToolBtn}" Margin="0,0,0,8"
                                    Click="OnSummaryClick">
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="#1A6EFF" CornerRadius="7"
                                            Width="30" Height="30" Margin="0,0,10,0">
                                        <TextBlock Text="📄" FontSize="14"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Zusammenfassung" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource ToolBtn}" Margin="0,0,0,8"
                                    Click="OnELI5Click">
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="#FF8C00" CornerRadius="7"
                                            Width="30" Height="30" Margin="0,0,10,0">
                                        <TextBlock Text="👶" FontSize="14"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Einfach erklärt" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource ToolBtn}" Margin="0,0,0,8"
                                    Click="OnStudyGuideClick">
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="#00A878" CornerRadius="7"
                                            Width="30" Height="30" Margin="0,0,10,0">
                                        <TextBlock Text="📚" FontSize="14"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Lernleitfaden" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource ToolBtn}" Margin="0,0,0,8"
                                    Click="OnFlashcardsClick">
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="#9B5DE5" CornerRadius="7"
                                            Width="30" Height="30" Margin="0,0,10,0">
                                        <TextBlock Text="🎴" FontSize="14"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Lernkarten erstellen" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource ToolBtn}" Margin="0,0,0,16"
                                    Click="OnQuizClick">
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="#F72585" CornerRadius="7"
                                            Width="30" Height="30" Margin="0,0,10,0">
                                        <TextBlock Text="❓" FontSize="14"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Quiz generieren" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- ── Analyse ─────────────────────────────── -->
                            <Separator Background="{DynamicResource BorderBrush}" Margin="0,0,0,12"/>
                            <TextBlock Text="ANALYSE" Foreground="{DynamicResource TextMutedBrush}"
                                       FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>

                            <Button Style="{StaticResource ToolBtn}" Margin="0,0,0,8"
                                    Click="OnSmartMergeClick">
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="#7B2FBE" CornerRadius="7"
                                            Width="30" Height="30" Margin="0,0,10,0">
                                        <TextBlock Text="🧬" FontSize="14"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Smart Merge" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource ToolBtn}" Margin="0,0,0,8"
                                    Click="OnExtractFormulasClick">
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="#E040FB" CornerRadius="7"
                                            Width="30" Height="30" Margin="0,0,10,0">
                                        <TextBlock Text="∑" FontSize="16" FontWeight="Bold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Formeln extrahieren" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource ToolBtn}" Margin="0,0,0,8"
                                    Click="OnAudioOverviewClick">
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="#00BCD4" CornerRadius="7"
                                            Width="30" Height="30" Margin="0,0,10,0">
                                        <TextBlock Text="🎙" FontSize="14"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Audio-Überblick" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- ── Aktionen ─────────────────────────────── -->
                            <Separator Background="{DynamicResource BorderBrush}" Margin="0,0,0,12"/>
                            <TextBlock Text="AKTIONEN" Foreground="{DynamicResource TextMutedBrush}"
                                       FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>

                            <Button Style="{StaticResource ToolBtn}" Margin="0,0,0,8"
                                    Click="OnInteractiveQuizClick">
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="#E91E63" CornerRadius="7"
                                            Width="30" Height="30" Margin="0,0,10,0">
                                        <TextBlock Text="▶" FontSize="13"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Quiz-Modus starten" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource ToolBtn}" Margin="0,0,0,8"
                                    Click="OnExportZipClick">
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="#0097A7" CornerRadius="7"
                                            Width="30" Height="30" Margin="0,0,10,0">
                                        <TextBlock Text="📦" FontSize="13"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Als ZIP exportieren" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource ToolBtn}" Margin="0,0,0,8"
                                    Click="OnImportZipClick">
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="#00796B" CornerRadius="7"
                                            Width="30" Height="30" Margin="0,0,10,0">
                                        <TextBlock Text="📥" FontSize="13"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="ZIP importieren" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource ToolBtn}" Margin="0,0,0,8"
                                    Click="OnExportNotebookClick">
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="#22AA55" CornerRadius="7"
                                            Width="30" Height="30" Margin="0,0,10,0">
                                        <TextBlock Text="💾" FontSize="14"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Notizbuch exportieren" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource ToolBtn}" Margin="0,0,0,8"
                                    Click="OnSaveSnapshotClick">
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="#4CAF50" CornerRadius="7"
                                            Width="30" Height="30" Margin="0,0,10,0">
                                        <TextBlock Text="📸" FontSize="14"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Version speichern" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource ToolBtn}" Margin="0,0,0,8"
                                    Click="OnViewHistoryClick">
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="#607D8B" CornerRadius="7"
                                            Width="30" Height="30" Margin="0,0,10,0">
                                        <TextBlock Text="🕐" FontSize="14"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Versionshistorie" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- Status -->
                        <TextBlock x:Name="TxtToolStatus" Text="" Visibility="Collapsed"
                                   Foreground="{DynamicResource AccentBrush}"
                                   FontSize="12" Margin="0,12,0,0" TextWrapping="Wrap"/>

                        <!-- Text result panel -->
                        <Border x:Name="ToolResultPanel" Visibility="Collapsed"
                                Background="{DynamicResource BgSecondaryBrush}"
                                CornerRadius="10" Padding="14" Margin="0,14,0,0">
                            <StackPanel>
                                <TextBlock x:Name="TxtToolTitle" Text="" Foreground="{DynamicResource AccentBrush}"
                                           FontSize="13" FontWeight="Bold" Margin="0,0,0,10"/>
                                <ScrollViewer MaxHeight="280" VerticalScrollBarVisibility="Auto">
                                    <TextBlock x:Name="TxtToolResult" Text="" Foreground="{DynamicResource TextBrush}"
                                               TextWrapping="Wrap" FontSize="12" LineHeight="20"/>
                                </ScrollViewer>
                                <!-- Result action row -->
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Content="📥 Als .md speichern"
                                            Click="OnExportResultMdClick"
                                            Height="30" FontSize="11" BorderThickness="0"
                                            Background="{DynamicResource BgTertiaryBrush}"
                                            Foreground="{DynamicResource TextMutedBrush}"
                                            Margin="0,0,4,0" ToolTip="Ergebnis als Markdown-Datei speichern"/>
                                    <Button Grid.Column="1" Content="➕ Als Material speichern"
                                            Click="OnSaveResultAsMaterialClick"
                                            Height="30" FontSize="11" BorderThickness="0"
                                            Background="{DynamicResource AccentBrush}" Foreground="White"
                                            Margin="4,0,0,0" ToolTip="Ergebnis als neues Notizbuch-Material hinzufügen"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Flashcards panel -->
                        <Border x:Name="FlashcardsPanel" Visibility="Collapsed"
                                Background="{DynamicResource BgSecondaryBrush}"
                                CornerRadius="10" Padding="14" Margin="0,14,0,0">
                            <StackPanel>
                                <Grid Margin="0,0,0,10">
                                    <TextBlock Text="🎴 Lernkarten" Foreground="{DynamicResource AccentBrush}"
                                               FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <Button Content="📊" Click="OnFlashcardStatsClick"
                                                Background="Transparent" BorderThickness="0"
                                                FontSize="14" Width="28" Height="28"
                                                ToolTip="Lernkarten-Statistiken" Margin="0,0,6,0"/>
                                        <TextBlock x:Name="TxtFlashcardCounter" Text="0 / 0"
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   FontSize="12" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Card front -->
                                <Border x:Name="FlashcardFront"
                                        Background="{DynamicResource BgBrush}" CornerRadius="8"
                                        Padding="16" MinHeight="100" Cursor="Hand"
                                        MouseLeftButtonDown="OnFlipCard">
                                    <StackPanel>
                                        <TextBlock Text="FRAGE" Foreground="{DynamicResource TextMutedBrush}"
                                                   FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
                                        <TextBlock x:Name="TxtFlashcardQuestion" Text=""
                                                   Foreground="White" FontSize="14" TextWrapping="Wrap"/>
                                        <TextBlock Text="Klicken zum Umdrehen" Foreground="{DynamicResource TextMutedBrush}"
                                                   FontSize="10" Margin="0,12,0,0" HorizontalAlignment="Right"/>
                                    </StackPanel>
                                </Border>

                                <!-- Card back -->
                                <Border x:Name="FlashcardBack" Visibility="Collapsed"
                                        Background="{DynamicResource AccentBrush}" CornerRadius="8"
                                        Padding="16" MinHeight="100" Cursor="Hand"
                                        MouseLeftButtonDown="OnFlipCard">
                                    <StackPanel>
                                        <TextBlock Text="ANTWORT" Foreground="#CCFFFFFF"
                                                   FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
                                        <TextBlock x:Name="TxtFlashcardAnswer" Text=""
                                                   Foreground="White" FontSize="14" TextWrapping="Wrap"/>
                                        <TextBlock Text="Klicken zum Umdrehen" Foreground="#BBFFFFFF"
                                                   FontSize="10" Margin="0,12,0,0" HorizontalAlignment="Right"/>
                                    </StackPanel>
                                </Border>

                                <!-- SM-2 SRS rating (visible after flip) -->
                                <Border x:Name="SrsRatingPanel" Visibility="Collapsed" Margin="0,8,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Wie gut kannst du es?" Foreground="{DynamicResource TextMutedBrush}"
                                                   FontSize="10" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" Content="❌" FontSize="18"
                                                    Background="#F44336" Foreground="White" BorderThickness="0"
                                                    Height="36" ToolTip="Nochmal (sofort)"
                                                    Click="OnSrsRate1" Margin="0,0,2,0"/>
                                            <Button Grid.Column="1" Content="😐" FontSize="18"
                                                    Background="#FF9800" Foreground="White" BorderThickness="0"
                                                    Height="36" ToolTip="Schwer (6 Tage)"
                                                    Click="OnSrsRate2" Margin="2,0,2,0"/>
                                            <Button Grid.Column="2" Content="👍" FontSize="18"
                                                    Background="#4CAF50" Foreground="White" BorderThickness="0"
                                                    Height="36" ToolTip="Gut"
                                                    Click="OnSrsRate3" Margin="2,0,2,0"/>
                                            <Button Grid.Column="3" Content="⚡" FontSize="18"
                                                    Background="#2196F3" Foreground="White" BorderThickness="0"
                                                    Height="36" ToolTip="Einfach (viele Tage)"
                                                    Click="OnSrsRate4" Margin="2,0,0,0"/>
                                        </Grid>
                                        <TextBlock x:Name="TxtSrsNextReview" Text=""
                                                   Foreground="{DynamicResource AccentBrush}" FontSize="10"
                                                   HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- Navigation -->
                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Style="{StaticResource GhostBtn}"
                                            Height="34" Padding="0" Content="← Zurück"
                                            Click="OnPrevCard" Margin="0,0,4,0"/>
                                    <Button Grid.Column="1" Style="{StaticResource GhostBtn}"
                                            Height="34" Padding="0" Content="Weiter →"
                                            Click="OnNextCard" Margin="4,0,0,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                        <!-- Formula panel -->
                        <Border x:Name="FormulaPanel" Visibility="Collapsed"
                                Background="{DynamicResource BgSecondaryBrush}"
                                CornerRadius="10" Padding="14" Margin="0,14,0,0">
                            <StackPanel>
                                <Grid Margin="0,0,0,10">
                                    <TextBlock Text="∑ Extrahierte Formeln"
                                               Foreground="{DynamicResource AccentBrush}"
                                               FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TxtFormulaCount" Text=""
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                <ScrollViewer MaxHeight="320" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl x:Name="FormulaList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource BgBrush}" CornerRadius="6"
                                                        Padding="10,8" Margin="0,0,0,6">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding LaTeX}"
                                                                   FontFamily="Courier New"
                                                                   Foreground="{DynamicResource AccentBrush}"
                                                                   FontSize="13" FontWeight="Bold"
                                                                   TextWrapping="Wrap"/>
                                                        <TextBlock Text="{Binding Description}"
                                                                   Foreground="{DynamicResource TextBrush}"
                                                                   FontSize="11" Margin="0,4,0,0"
                                                                   TextWrapping="Wrap"/>
                                                        <TextBlock Text="{Binding Category}"
                                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                                   FontSize="10" Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
                </Grid><!-- /right tool grid -->
            </Grid>
        </Grid>

        <!-- ══════════════════════════════════════════════════════════════════
             NEUES NOTIZBUCH modal
             ══════════════════════════════════════════════════════════════════ -->
        <Border x:Name="NewNotebookModal" Background="#BB000000" Visibility="Collapsed"
                PreviewKeyDown="OnNewNotebookKeyDown">
            <Border Background="{DynamicResource BgSecondaryBrush}" CornerRadius="14" Width="420"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" BlurRadius="40" ShadowDepth="0" Opacity="0.5"/>
                </Border.Effect>
                <StackPanel Margin="28,24,28,28">
                    <Grid Margin="0,0,0,16">
                        <TextBlock Text="Neues Notizbuch" Foreground="White" FontSize="18" FontWeight="Bold"/>
                        <Button Style="{StaticResource CloseBtn}" HorizontalAlignment="Right"
                                Content="✕" Click="OnCancelNewNotebook"/>
                    </Grid>
                    <TextBlock Text="NAME" Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                    <TextBox x:Name="TxtNewNotebookName" Style="{StaticResource ModernTextBox}" Margin="0,0,0,4"/>
                    <TextBlock x:Name="TxtNewNotebookError" Text="Bitte gib einen Namen ein."
                               Foreground="#FF4C61" FontSize="11" Margin="2,0,0,16" Visibility="Collapsed"/>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Style="{StaticResource GhostBtn}" Content="Abbrechen" Click="OnCancelNewNotebook"/>
                        <Button Grid.Column="2" Style="{StaticResource PrimaryBtn}" Content="Erstellen" Click="OnSaveNewNotebook"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Border>

        <!-- ══════════════════════════════════════════════════════════════════
             TEXT EINFÜGEN modal
             ══════════════════════════════════════════════════════════════════ -->
        <Border x:Name="PasteTextModal" Background="#BB000000" Visibility="Collapsed"
                PreviewKeyDown="OnPasteTextKeyDown">
            <Border Background="{DynamicResource BgSecondaryBrush}" CornerRadius="14" Width="560"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" BlurRadius="40" ShadowDepth="0" Opacity="0.5"/>
                </Border.Effect>
                <StackPanel Margin="28,24,28,28">
                    <Grid Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Text einfügen" Foreground="White" FontSize="18" FontWeight="Bold"/>
                            <TextBlock Text="Füge Notizen, Texte oder Zusammenfassungen als Kontext hinzu"
                                       Foreground="{DynamicResource TextMutedBrush}" FontSize="12" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Button Style="{StaticResource CloseBtn}" HorizontalAlignment="Right" VerticalAlignment="Top"
                                Content="✕" Click="OnCancelPasteText"/>
                    </Grid>
                    <TextBlock Text="BEZEICHNUNG" Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                    <TextBox x:Name="TxtPasteName" Style="{StaticResource ModernTextBox}" Margin="0,0,0,16"/>
                    <TextBlock Text="INHALT" Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                    <TextBox x:Name="TxtPasteContent" Style="{StaticResource ModernTextBoxMulti}"
                             MinHeight="160" MaxHeight="300" Margin="0,0,0,20"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Style="{StaticResource GhostBtn}" Content="Abbrechen" Click="OnCancelPasteText"/>
                        <Button Grid.Column="2" Style="{StaticResource PrimaryBtn}" Content="Hinzufügen" Click="OnSavePasteText"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Border>

    </Grid>
</UserControl>
