<UserControl x:Class="MindForge.Views.SubjectsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="Transparent">
    
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <StackPanel HorizontalAlignment="Left">
                <TextBlock Text="Deine Fächer" Foreground="White" FontSize="28" FontWeight="Bold"/>
                <TextBlock Text="Verwalte deine Lernbereiche und Module" Foreground="#8892B0" FontSize="14" Margin="0,4,0,0"/>
            </StackPanel>
            
            <Button HorizontalAlignment="Right" VerticalAlignment="Top" 
                    Content="+ Neues Fach" Height="40" Padding="16,0"
                    Background="#6C63FF" Foreground="White" BorderThickness="0" Cursor="Hand" FontWeight="SemiBold">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <WrapPanel>
                <!-- Subject Card 1 -->
                <Border Background="#161B2E" CornerRadius="12" Padding="20" Margin="0,0,20,20" Width="280">
                    <StackPanel>
                        <Border Background="#1E2640" CornerRadius="8" Width="48" Height="48" HorizontalAlignment="Left" Margin="0,0,0,16">
                            <TextBlock Text="💻" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Informatik" Foreground="White" FontSize="20" FontWeight="SemiBold"/>
                        <TextBlock Text="Algorithmen &amp; Datenstrukturen" Foreground="#8892B0" FontSize="12" Margin="0,4,0,16"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Fortschritt" Foreground="#8892B0" FontSize="11"/>
                                <ProgressBar Value="65" Maximum="100" Height="6" Margin="0,4,16,0" Foreground="#6C63FF" Background="#1E2640" BorderThickness="0"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="65%" Foreground="White" FontSize="12" VerticalAlignment="Bottom" FontWeight="SemiBold"/>
                        </Grid>
                    </StackPanel>
                </Border>
                
                <!-- Subject Card 2 -->
                <Border Background="#161B2E" CornerRadius="12" Padding="20" Margin="0,0,20,20" Width="280">
                    <StackPanel>
                        <Border Background="#1E2640" CornerRadius="8" Width="48" Height="48" HorizontalAlignment="Left" Margin="0,0,0,16">
                            <TextBlock Text="🧬" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Biologie" Foreground="White" FontSize="20" FontWeight="SemiBold"/>
                        <TextBlock Text="Zellbiologie &amp; Genetik" Foreground="#8892B0" FontSize="12" Margin="0,4,0,16"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Fortschritt" Foreground="#8892B0" FontSize="11"/>
                                <ProgressBar Value="30" Maximum="100" Height="6" Margin="0,4,16,0" Foreground="#FF4C61" Background="#1E2640" BorderThickness="0"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="30%" Foreground="White" FontSize="12" VerticalAlignment="Bottom" FontWeight="SemiBold"/>
                        </Grid>
                    </StackPanel>
                </Border>
                
                <!-- Subject Card 3 -->
                <Border Background="#161B2E" CornerRadius="12" Padding="20" Margin="0,0,20,20" Width="280">
                    <StackPanel>
                        <Border Background="#1E2640" CornerRadius="8" Width="48" Height="48" HorizontalAlignment="Left" Margin="0,0,0,16">
                            <TextBlock Text="📈" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Mathematik" Foreground="White" FontSize="20" FontWeight="SemiBold"/>
                        <TextBlock Text="Analysis &amp; Lineare Algebra" Foreground="#8892B0" FontSize="12" Margin="0,4,0,16"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Fortschritt" Foreground="#8892B0" FontSize="11"/>
                                <ProgressBar Value="85" Maximum="100" Height="6" Margin="0,4,16,0" Foreground="Lime" Background="#1E2640" BorderThickness="0"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="85%" Foreground="White" FontSize="12" VerticalAlignment="Bottom" FontWeight="SemiBold"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </WrapPanel>
        </ScrollViewer>
    </Grid>
</UserControl>