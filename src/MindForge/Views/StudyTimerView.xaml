<UserControl x:Class="MindForge.Views.StudyTimerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,32">
            <TextBlock Text="⏱ Lern-Timer (Pomodoro)" Foreground="{DynamicResource TextBrush}"
                       FontSize="28" FontWeight="Bold"/>
            <TextBlock Text="Fokussiert lernen, dann Pause — 25 / 5 / 15 Minuten"
                       Foreground="{DynamicResource TextMutedBrush}" FontSize="14" Margin="0,4,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- ── Main timer display ────────────────────────────────────────── -->
            <Border Grid.Column="0" Background="{DynamicResource BgSecondaryBrush}"
                    CornerRadius="16" Padding="48" Margin="0,0,24,0">
                <StackPanel HorizontalAlignment="Center">

                    <!-- Phase label -->
                    <TextBlock x:Name="TxtPhase" Text="🎯 Arbeitsphase"
                               Foreground="{DynamicResource AccentBrush}"
                               FontSize="18" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,0,0,32"/>

                    <!-- Big clock ring -->
                    <Grid Width="260" Height="260" HorizontalAlignment="Center">
                        <!-- Background ring -->
                        <Ellipse Stroke="{DynamicResource BgTertiaryBrush}"
                                 StrokeThickness="16" Width="260" Height="260"/>
                        <!-- Progress ring (drawn in code-behind via arc) -->
                        <Canvas x:Name="ProgressCanvas" Width="260" Height="260"/>
                        <!-- Time display -->
                        <TextBlock x:Name="TxtTime" Text="25:00"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="56" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Pomodoro dots -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,24,0,40">
                        <Ellipse x:Name="Dot1" Width="14" Height="14" Margin="6,0"
                                 Fill="{DynamicResource BgTertiaryBrush}"/>
                        <Ellipse x:Name="Dot2" Width="14" Height="14" Margin="6,0"
                                 Fill="{DynamicResource BgTertiaryBrush}"/>
                        <Ellipse x:Name="Dot3" Width="14" Height="14" Margin="6,0"
                                 Fill="{DynamicResource BgTertiaryBrush}"/>
                        <Ellipse x:Name="Dot4" Width="14" Height="14" Margin="6,0"
                                 Fill="{DynamicResource BgTertiaryBrush}"/>
                    </StackPanel>

                    <!-- Controls -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="BtnStartPause" Content="▶ Start"
                                Click="OnStartPause"
                                Background="{DynamicResource AccentBrush}" Foreground="White"
                                BorderThickness="0" Height="52" Width="140"
                                FontSize="16" FontWeight="SemiBold"
                                Margin="0,0,12,0"/>
                        <Button Content="⏭ Überspringen" Click="OnSkip"
                                Background="{DynamicResource BgTertiaryBrush}"
                                Foreground="{DynamicResource TextMutedBrush}"
                                BorderThickness="0" Height="52" Padding="16,0"
                                FontSize="14" Margin="0,0,12,0"/>
                        <Button Content="↺ Reset" Click="OnReset"
                                Background="{DynamicResource BgTertiaryBrush}"
                                Foreground="{DynamicResource TextMutedBrush}"
                                BorderThickness="0" Height="52" Padding="16,0"
                                FontSize="14"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ── Settings + Stats panel ────────────────────────────────────── -->
            <StackPanel Grid.Column="1">

                <!-- Duration settings -->
                <Border Background="{DynamicResource BgSecondaryBrush}" CornerRadius="12" Padding="20" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="⚙️ Einstellungen" Foreground="{DynamicResource TextBrush}"
                                   FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>

                        <TextBlock Text="Arbeitsphase (Min.)" Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="12" Margin="0,0,0,4"/>
                        <Slider x:Name="SlWork" Minimum="5" Maximum="60" Value="25"
                                TickFrequency="5" IsSnapToTickEnabled="True"
                                ValueChanged="OnSettingChanged"
                                Foreground="{DynamicResource AccentBrush}"/>
                        <TextBlock x:Name="TxtWorkVal" Text="25 Min."
                                   Foreground="{DynamicResource AccentBrush}"
                                   FontSize="12" HorizontalAlignment="Right" Margin="0,0,0,12"/>

                        <TextBlock Text="Kurze Pause (Min.)" Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="12" Margin="0,0,0,4"/>
                        <Slider x:Name="SlShort" Minimum="1" Maximum="15" Value="5"
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                ValueChanged="OnSettingChanged"
                                Foreground="{DynamicResource AccentBrush}"/>
                        <TextBlock x:Name="TxtShortVal" Text="5 Min."
                                   Foreground="{DynamicResource AccentBrush}"
                                   FontSize="12" HorizontalAlignment="Right" Margin="0,0,0,12"/>

                        <TextBlock Text="Lange Pause (Min.)" Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="12" Margin="0,0,0,4"/>
                        <Slider x:Name="SlLong" Minimum="10" Maximum="30" Value="15"
                                TickFrequency="5" IsSnapToTickEnabled="True"
                                ValueChanged="OnSettingChanged"
                                Foreground="{DynamicResource AccentBrush}"/>
                        <TextBlock x:Name="TxtLongVal" Text="15 Min."
                                   Foreground="{DynamicResource AccentBrush}"
                                   FontSize="12" HorizontalAlignment="Right"/>
                    </StackPanel>
                </Border>

                <!-- Session stats -->
                <Border Background="{DynamicResource BgSecondaryBrush}" CornerRadius="12" Padding="20">
                    <StackPanel>
                        <TextBlock Text="📊 Sitzungsstatistik" Foreground="{DynamicResource TextBrush}"
                                   FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Abgeschlossene Pomodoros"
                                       Foreground="{DynamicResource TextMutedBrush}" FontSize="13"/>
                            <TextBlock x:Name="TxtPomodoros" Text="0" Grid.Column="1"
                                       Foreground="{DynamicResource AccentBrush}"
                                       FontSize="20" FontWeight="Bold"/>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Gelernte Minuten (heute)"
                                       Foreground="{DynamicResource TextMutedBrush}" FontSize="13"/>
                            <TextBlock x:Name="TxtMinutes" Text="0" Grid.Column="1"
                                       Foreground="{DynamicResource AccentBrush}"
                                       FontSize="20" FontWeight="Bold"/>
                        </Grid>

                        <Button Content="💾 Session speichern" Click="OnSaveSession"
                                Background="{DynamicResource AccentBrush}" Foreground="White"
                                BorderThickness="0" Height="40" Margin="0,8,0,0"
                                HorizontalAlignment="Stretch" FontSize="14"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
