<UserControl x:Class="MindForge.Views.ChatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="Transparent">

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="KI-Tutor" Foreground="White" FontSize="28" FontWeight="Bold"/>
            <TextBlock Text="Dein persönlicher Begleiter für tieferes Verständnis (Ollama LLaMA 3)" Foreground="{DynamicResource TextMutedBrush}" FontSize="14"/>
        </StackPanel>

        <!-- Chat Area -->
        <Border Grid.Row="1" Background="{DynamicResource BgSecondaryBrush}" CornerRadius="12" Padding="16" Margin="0,0,0,16">
            <ScrollViewer x:Name="ChatScrollViewer" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="ChatHistoryPanel">
                    
                    <!-- Bot Welcome Message -->
                    <Border Background="{DynamicResource BgTertiaryBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,12" HorizontalAlignment="Left" MaxWidth="600">
                        <StackPanel>
                            <TextBlock Text="🤖 KI-Tutor" Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <TextBlock Text="Hallo! Wie kann ich dir heute beim Lernen helfen? Wir können über Dokumente sprechen oder neue Konzepte erarbeiten." 
                                       Foreground="White" TextWrapping="Wrap" LineHeight="20"/>
                        </StackPanel>
                    </Border>
                    
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Input Area -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="TxtInput" Grid.Column="0" 
                     materialDesign:HintAssist.Hint="Stelle eine Frage..." 
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Foreground="White" BorderBrush="{DynamicResource BorderBrush}"
                     materialDesign:HintAssist.Foreground="{DynamicResource TextMutedBrush}"
                     Height="56" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" AcceptsReturn="True"
                     Margin="0,0,16,0"/>

            <Button x:Name="BtnSend" Grid.Column="1" Content="Senden" Click="OnSendClick"
                    Width="100" Height="56" FontSize="16" FontWeight="Bold"
                    Background="{DynamicResource AccentBrush}" Foreground="White" BorderThickness="0" Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#7B74FF"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
    </Grid>
</UserControl>
