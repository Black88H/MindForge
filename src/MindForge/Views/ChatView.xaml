<UserControl x:Class="MindForge.Views.ChatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="Transparent"
             Loaded="OnLoaded">

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- 0: header + controls bar -->
            <RowDefinition Height="*"/>      <!-- 1: chat area -->
            <RowDefinition Height="Auto"/>   <!-- 2: progress + input -->
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="220"/>
        </Grid.ColumnDefinitions>

        <!-- ── Row 0 · Header + controls bar ──────────────────────────────── -->
        <Grid Grid.Row="0" Grid.Column="0" Margin="0,0,12,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <StackPanel Grid.Row="0" Margin="0,0,0,10">
                <TextBlock Text="🤖 AI Tutor"
                           Foreground="{DynamicResource TextBrush}" FontSize="28" FontWeight="Bold"/>
                <TextBlock Text="Chat mit deinem KI-Tutor, gestützt auf deine Lernmaterialien"
                           Foreground="{DynamicResource TextMutedBrush}" FontSize="14"/>
            </StackPanel>

            <!-- Controls bar: model selector + separator + token/time display -->
            <Border Grid.Row="1"
                    Background="{DynamicResource BgSecondaryBrush}"
                    CornerRadius="8" Padding="12,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="1"/>      <!-- divider -->
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Model picker -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Modell:" FontSize="12"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox ItemsSource="{Binding AvailableModels}"
                                  SelectedItem="{Binding SelectedModel, Mode=TwoWay}"
                                  Foreground="{DynamicResource TextBrush}"
                                  Width="170" Height="32"
                                  VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Divider -->
                    <Rectangle Grid.Column="1"
                               Fill="{DynamicResource BorderBrush}"
                               Width="1" Margin="14,2"/>

                    <!-- Spacer -->
                    <StackPanel Grid.Column="2"/>

                    <!-- Live token + elapsed display (right-aligned) -->
                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding TokenDisplay}"
                                   Foreground="{DynamicResource AccentBrush}"
                                   FontSize="12" VerticalAlignment="Center"
                                   Margin="0,0,14,0"/>
                        <TextBlock Text="{Binding ElapsedTime}"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ── Row 1 · Chat scroll area ───────────────────────────────────── -->
        <Border Grid.Row="1" Grid.Column="0"
                Background="{DynamicResource BgSecondaryBrush}"
                CornerRadius="12" Padding="8" Margin="0,0,12,16">
            <ScrollViewer x:Name="ChatScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          CanContentScroll="False">
                <StackPanel>

                    <!-- Welcome bubble (static) -->
                    <Border Background="{DynamicResource BgTertiaryBrush}"
                            CornerRadius="12,12,12,4"
                            Padding="14,10" Margin="8,4,60,4"
                            HorizontalAlignment="Left" MaxWidth="600">
                        <StackPanel>
                            <TextBlock Text="🤖 AI Tutor"
                                       Foreground="{DynamicResource AccentBrush}"
                                       FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                            <TextBlock Text="Hallo! Ich bin dein KI-Tutor. Stelle mir eine Frage — oder wähle rechts Lernmaterialien aus, um meine Antworten daran zu verankern."
                                       Foreground="{DynamicResource TextBrush}"
                                       TextWrapping="Wrap" FontSize="14" LineHeight="22"
                                       LineStackingStrategy="BlockLineHeight"/>
                        </StackPanel>
                    </Border>

                    <!-- ── Persisted message history (ItemsControl) ─────── -->
                    <ItemsControl ItemsSource="{Binding Messages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- Outer Grid: fade-in + slide-up on load -->
                                <Grid Margin="0,3" Opacity="0">
                                    <Grid.RenderTransform>
                                        <TranslateTransform Y="10"/>
                                    </Grid.RenderTransform>
                                    <Grid.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation
                                                        Storyboard.TargetProperty="Opacity"
                                                        From="0" To="1" Duration="0:0:0.25">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                    <DoubleAnimation
                                                        Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                        From="10" To="0" Duration="0:0:0.25">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Grid.Triggers>
                                    <Border MaxWidth="600" Padding="12,10">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <!-- AI bubble: left-aligned, flat bottom-left corner -->
                                                <Setter Property="Background"
                                                        Value="{DynamicResource BgTertiaryBrush}"/>
                                                <Setter Property="CornerRadius"  Value="12,12,12,4"/>
                                                <Setter Property="HorizontalAlignment" Value="Left"/>
                                                <Setter Property="Margin"        Value="8,0,60,0"/>
                                                <Style.Triggers>
                                                    <!-- User bubble: right-aligned purple, flat bottom-right -->
                                                    <DataTrigger Binding="{Binding Role}" Value="User">
                                                        <Setter Property="Background" Value="#6C63FF"/>
                                                        <Setter Property="CornerRadius"  Value="12,12,4,12"/>
                                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                                        <Setter Property="Margin"    Value="60,0,8,0"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <TextBlock Text="{Binding Content}"
                                                   TextWrapping="Wrap"
                                                   LineHeight="22"
                                                   LineStackingStrategy="BlockLineHeight"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   FontSize="14"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>


                    <!-- ── Live streaming bubble (visible while IsStreaming) ── -->
                    <Border MaxWidth="600" Padding="12,10"
                            Margin="8,4,60,4" CornerRadius="12,12,12,4"
                            Background="{DynamicResource BgTertiaryBrush}"
                            HorizontalAlignment="Left"
                            Visibility="{Binding IsStreaming,
                                Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="🤖 AI Tutor"
                                       Foreground="{DynamicResource AccentBrush}"
                                       FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding StreamingResponse}"
                                       TextWrapping="Wrap"
                                       LineHeight="22"
                                       LineStackingStrategy="BlockLineHeight"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="14"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ── Row 0..1 · Right sidebar ───────────────────────────────────── -->
        <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                Background="{DynamicResource BgSecondaryBrush}"
                CornerRadius="12" Padding="14" Margin="0,0,0,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- labels -->
                    <RowDefinition Height="*"/>     <!-- materials list -->
                    <RowDefinition Height="Auto"/>  <!-- count + personality -->
                </Grid.RowDefinitions>

                <!-- Source materials header -->
                <StackPanel Grid.Row="0" Margin="0,0,0,8">
                    <TextBlock Text="Quellmaterialien"
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBlock Text="Dokumente für den Kontext auswählen:"
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="11" TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Materials list (fills remaining space) -->
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding AvailableMaterials}"
                         Background="Transparent" BorderThickness="0"
                         SelectionMode="Multiple"
                         x:Name="LstContextMaterials"
                         SelectionChanged="OnContextMaterialChanged"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding OriginalFileName}"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="11" TextWrapping="Wrap"
                                       Padding="4,2"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="2"/>
                            <Setter Property="Background" Value="Transparent"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <!-- Footer: selection count + personality + extended settings -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" MaxHeight="340">
                    <StackPanel>
                        <TextBlock Text="{Binding ContextMaterials.Count, StringFormat='{}{0} ausgewählt'}"
                                   Foreground="{DynamicResource AccentBrush}"
                                   FontSize="11" Margin="0,6,0,0"/>

                        <Separator Background="{DynamicResource BorderBrush}" Margin="0,10"/>

                        <!-- Personality -->
                        <TextBlock Text="KI-Persönlichkeit"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <ComboBox ItemsSource="{Binding PersonalityLabels}"
                                  SelectedIndex="{Binding SelectedPersonalityIndex, Mode=TwoWay}"
                                  Foreground="{DynamicResource TextBrush}"
                                  Height="32" Margin="0,0,0,10"/>

                        <Separator Background="{DynamicResource BorderBrush}" Margin="0,0,0,10"/>

                        <!-- Response style -->
                        <TextBlock Text="Antwort-Stil"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <CheckBox Content="Mit Beispielen"
                                  IsChecked="{Binding UseExamples, Mode=TwoWay}"
                                  Foreground="{DynamicResource TextBrush}"
                                  FontSize="12" Margin="0,0,0,4"/>
                        <CheckBox Content="Schritt-für-Schritt"
                                  IsChecked="{Binding UseStepByStep, Mode=TwoWay}"
                                  Foreground="{DynamicResource TextBrush}"
                                  FontSize="12" Margin="0,0,0,4"/>
                        <CheckBox Content="Mit Quellenangaben"
                                  IsChecked="{Binding UseCitations, Mode=TwoWay}"
                                  Foreground="{DynamicResource TextBrush}"
                                  FontSize="12" Margin="0,0,0,10"/>

                        <Separator Background="{DynamicResource BorderBrush}" Margin="0,0,0,10"/>

                        <!-- Custom prompt override -->
                        <TextBlock Text="Eigener Prompt"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding CustomPrompt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Height="60"
                                 VerticalScrollBarVisibility="Auto"
                                 Foreground="{DynamicResource TextBrush}"
                                 Background="{DynamicResource BgTertiaryBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 FontSize="11"
                                 Padding="6,4"
                                 Margin="0,0,0,10"/>

                        <Separator Background="{DynamicResource BorderBrush}" Margin="0,0,0,10"/>

                        <!-- Temperature -->
                        <Grid Margin="0,0,0,4">
                            <TextBlock Text="Kreativität"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       FontSize="12" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Temperature, StringFormat={}{0:F1}}"
                                       Foreground="{DynamicResource AccentBrush}"
                                       FontSize="11" HorizontalAlignment="Right"
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <Slider Minimum="0" Maximum="2"
                                Value="{Binding Temperature, Mode=TwoWay}"
                                SmallChange="0.1" LargeChange="0.5"
                                Margin="0,0,0,2"/>
                        <TextBlock Text="0 = präzise  ·  1 = kreativ  ·  2 = experimentell"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="9" Margin="0,0,0,6"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ── Row 2 · Progress panel + Input ────────────────────────────── -->
        <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- progress bar (Collapsed unless busy) -->
                <RowDefinition Height="Auto"/>   <!-- text input + send button -->
            </Grid.RowDefinitions>

            <!-- Progress panel -->
            <Border Grid.Row="0"
                    Background="{DynamicResource BgSecondaryBrush}"
                    CornerRadius="8" Padding="12,8" Margin="0,0,0,8"
                    Visibility="{Binding IsBusy,
                        Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="⏳ KI generiert…"
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="12" VerticalAlignment="Center"/>

                    <ProgressBar Grid.Column="1" Height="4" Margin="12,0"
                                 IsIndeterminate="True"
                                 Foreground="{DynamicResource AccentBrush}"
                                 Background="{DynamicResource BgTertiaryBrush}"
                                 VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <TextBlock Text="{Binding ElapsedTime}"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="11" Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding TokenDisplay}"
                                   Foreground="{DynamicResource AccentBrush}"
                                   FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Input row -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="TxtInput" Grid.Column="0"
                         Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="Frage stellen…"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Foreground="{DynamicResource TextBrush}"
                         BorderBrush="{DynamicResource BorderBrush}"
                         materialDesign:HintAssist.Foreground="{DynamicResource TextMutedBrush}"
                         Height="56" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         AcceptsReturn="False" Margin="0,0,12,0"
                         KeyDown="OnInputKeyDown"/>

                <Button x:Name="BtnStop" Grid.Column="1"
                        Content="⏹" Click="OnStopClick"
                        Width="56" Height="56" FontSize="18"
                        Background="#FF4C4C" Foreground="White" BorderThickness="0"
                        Visibility="{Binding IsBusy,
                            Converter={StaticResource BoolToVisibilityConverter}}"
                        Margin="0,0,8,0" ToolTip="Generierung stoppen">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <Button x:Name="BtnSend" Grid.Column="2"
                        Content="Senden" Click="OnSendClick"
                        Width="100" Height="56" FontSize="15" FontWeight="Bold"
                        Background="{DynamicResource AccentBrush}" Foreground="White"
                        BorderThickness="0"
                        IsEnabled="{Binding IsBusy,
                            Converter={StaticResource InverseBoolConverter}}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#7B74FF"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
