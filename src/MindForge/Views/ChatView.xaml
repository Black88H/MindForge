<UserControl x:Class="MindForge.Views.ChatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="Transparent"
             Loaded="OnLoaded">

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="220"/>
        </Grid.ColumnDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,16">
            <TextBlock Text="🤖 AI Tutor" Foreground="{DynamicResource TextBrush}" FontSize="28" FontWeight="Bold"/>
            <TextBlock Text="Chat with your AI tutor, grounded in your uploaded materials"
                       Foreground="{DynamicResource TextMutedBrush}" FontSize="14"/>
        </StackPanel>

        <!-- Chat Area -->
        <Border Grid.Row="1" Grid.Column="0" Background="{DynamicResource BgSecondaryBrush}"
                CornerRadius="12" Padding="16" Margin="0,0,12,16">

            <!-- Single ScrollViewer: history + live streaming bubble inside the same scroll area -->
            <ScrollViewer x:Name="ChatScrollViewer" VerticalScrollBarVisibility="Auto"
                          CanContentScroll="False">
                <StackPanel x:Name="ChatHistoryPanel">

                    <!-- ── Welcome bubble ──────────────────────────────── -->
                    <Border Background="{DynamicResource BgTertiaryBrush}" CornerRadius="12"
                            Padding="14,10" Margin="8,4" HorizontalAlignment="Left" MaxWidth="580">
                        <StackPanel>
                            <TextBlock Text="🤖 AI Tutor" Foreground="{DynamicResource AccentBrush}"
                                       FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                            <TextBlock Text="Hello! I'm your AI tutor. Ask me anything — or select source materials on the right to ground my answers in your documents."
                                       Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap"
                                       FontSize="13" LineHeight="20"/>
                        </StackPanel>
                    </Border>

                    <!-- ── Persisted message history ───────────────────── -->
                    <ItemsControl ItemsSource="{Binding Messages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2">
                                    <!-- User bubble: right-aligned purple
                                         Assistant bubble: left-aligned dark card -->
                                    <Border MaxWidth="580" Padding="12,10" Margin="8,2" CornerRadius="12">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background"
                                                        Value="{DynamicResource BgTertiaryBrush}"/>
                                                <Setter Property="HorizontalAlignment" Value="Left"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Role}" Value="User">
                                                        <Setter Property="Background" Value="#6C63FF"/>
                                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Content}" TextWrapping="Wrap"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   FontSize="13" LineHeight="20"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- ── Live streaming bubble (visible while AI is typing) ── -->
                    <Border MaxWidth="580" Padding="12,10" Margin="8,4" CornerRadius="12"
                            Background="{DynamicResource BgTertiaryBrush}" HorizontalAlignment="Left"
                            Visibility="{Binding IsStreaming,
                                Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="🤖 AI Tutor" Foreground="{DynamicResource AccentBrush}"
                                       FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding StreamingResponse}" TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="13" LineHeight="20"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Source-materials context panel -->
        <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                Background="{DynamicResource BgSecondaryBrush}" CornerRadius="12"
                Padding="14" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Source Materials" Foreground="{DynamicResource TextMutedBrush}"
                           FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBlock Text="Select documents to include as context:"
                           Foreground="{DynamicResource TextMutedBrush}" FontSize="11"
                           TextWrapping="Wrap" Margin="0,0,0,8"/>

                <ListBox ItemsSource="{Binding AvailableMaterials}"
                         Background="Transparent" BorderThickness="0"
                         SelectionMode="Multiple"
                         x:Name="LstContextMaterials"
                         SelectionChanged="OnContextMaterialChanged"
                         MaxHeight="400" ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding OriginalFileName}"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="11" TextWrapping="Wrap"
                                       Padding="4,2"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="2"/>
                            <Setter Property="Background" Value="Transparent"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <TextBlock Text="{Binding ContextMaterials.Count, StringFormat='{}{0} selected'}"
                           Foreground="{DynamicResource AccentBrush}" FontSize="11" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <!-- Input Area -->
        <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="TxtInput" Grid.Column="0"
                     Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                     materialDesign:HintAssist.Hint="Ask a question..."
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Foreground="{DynamicResource TextBrush}" BorderBrush="{DynamicResource BorderBrush}"
                     materialDesign:HintAssist.Foreground="{DynamicResource TextMutedBrush}"
                     Height="56" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                     AcceptsReturn="False" Margin="0,0,12,0"
                     KeyDown="OnInputKeyDown"/>

            <Button x:Name="BtnStop" Grid.Column="1" Content="⏹" Click="OnStopClick"
                    Width="56" Height="56" FontSize="18"
                    Background="#FF4C4C" Foreground="White" BorderThickness="0"
                    Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"
                    Margin="0,0,8,0"
                    ToolTip="Stop generation">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>

            <Button x:Name="BtnSend" Grid.Column="2" Content="Send" Click="OnSendClick"
                    Width="100" Height="56" FontSize="15" FontWeight="Bold"
                    Background="{DynamicResource AccentBrush}" Foreground="White" BorderThickness="0"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#7B74FF"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
    </Grid>
</UserControl>
