<UserControl x:Class="MindForge.Views.KIToolsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="Transparent"
             Loaded="OnLoaded">

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="🧠 AI Tools" Foreground="{DynamicResource TextBrush}"
                       FontSize="28" FontWeight="Bold"/>
            <TextBlock Text="NotebookLM-style AI analysis, Q&amp;A with citations, and audio overviews"
                       Foreground="{DynamicResource TextMutedBrush}" FontSize="14" Margin="0,4,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Controls -->
            <StackPanel Grid.Column="0" Margin="0,0,16,0">

                <!-- Subject selector -->
                <Border Background="{DynamicResource BgSecondaryBrush}" CornerRadius="12" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Subject" Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <ComboBox ItemsSource="{Binding Subjects}"
                                  SelectedItem="{Binding SelectedSubject}"
                                  DisplayMemberPath="Name"
                                  Style="{StaticResource MaterialDesignComboBox}"
                                  Foreground="{DynamicResource TextBrush}"
                                  Height="40"/>
                    </StackPanel>
                </Border>

                <!-- Tools -->
                <Border Background="{DynamicResource BgSecondaryBrush}" CornerRadius="12" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Tools" Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>

                        <Button Content="📝  Subject Summary" Click="OnSummarizeSubjectClick"
                                Background="{DynamicResource AccentBrush}" Foreground="White"
                                BorderThickness="0" Height="40" Margin="0,0,0,8">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#7B74FF"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="📖  Study Guide" Click="OnStudyGuideClick"
                                Background="{DynamicResource BgTertiaryBrush}" Foreground="{DynamicResource TextBrush}"
                                BorderThickness="0" Height="40" Margin="0,0,0,8">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="🔊  Audio Overview" Click="OnAudioOverviewClick"
                                Background="{DynamicResource BgTertiaryBrush}" Foreground="{DynamicResource TextBrush}"
                                BorderThickness="0" Height="40" Margin="0,0,0,8">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Q&A with Sources -->
                <Border Background="{DynamicResource BgSecondaryBrush}" CornerRadius="12" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Q&amp;A with Sources" Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>

                        <TextBox x:Name="TxtQuestion"
                                 materialDesign:HintAssist.Hint="Ask a question about your materials..."
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding QuestionInput, UpdateSourceTrigger=PropertyChanged}"
                                 Foreground="{DynamicResource TextBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 Height="80" TextWrapping="Wrap" AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto" Margin="0,0,0,8"/>

                        <TextBlock Text="Source materials (optional):" Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="11" Margin="0,0,0,4"/>
                        <ListBox ItemsSource="{Binding SubjectMaterials}"
                                 Background="Transparent" BorderThickness="0"
                                 MaxHeight="120" SelectionMode="Multiple"
                                 x:Name="LstSourceMaterials"
                                 SelectionChanged="OnSourceMaterialSelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding OriginalFileName}"
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="11" TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding OriginalFileName}"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Button Content="❓  Ask" Click="OnAskClick"
                                Background="{DynamicResource AccentBrush}" Foreground="White"
                                BorderThickness="0" Height="40" Margin="0,8,0,0">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Right: Output -->
            <Border Grid.Column="1" Background="{DynamicResource BgSecondaryBrush}" CornerRadius="12" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{Binding ActiveToolName, StringFormat='Output: {0}'}"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>

                        <Button Grid.Column="1" Content="🔊 Speak" Click="OnSpeakClick"
                                Visibility="{Binding IsAudioPlaying, Converter={StaticResource InverseBoolConverter},
                                    ConverterParameter=Visibility}"
                                Background="{DynamicResource BgTertiaryBrush}" Foreground="{DynamicResource TextBrush}"
                                BorderThickness="0" Height="32" Padding="12,0" Margin="0,0,8,0">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Grid.Column="2" Content="⏹ Stop" Click="OnStopSpeakClick"
                                Visibility="{Binding IsAudioPlaying, Converter={StaticResource BoolToVisibilityConverter}}"
                                Background="#FF4C4C" Foreground="White"
                                BorderThickness="0" Height="32" Padding="12,0">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>

                    <Border Grid.Row="1" Background="{DynamicResource BgBrush}" CornerRadius="8" Padding="16">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <TextBlock Text="{Binding Output}"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="13" TextWrapping="Wrap" LineHeight="22"
                                       FontFamily="Segoe UI"/>
                        </ScrollViewer>
                    </Border>

                    <StackPanel Grid.Row="2" Margin="0,8,0,0">
                        <ProgressBar IsIndeterminate="True" Height="3"
                                     Foreground="{DynamicResource AccentBrush}"
                                     Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
