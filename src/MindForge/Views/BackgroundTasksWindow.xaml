<Window x:Class="MindForge.Views.BackgroundTasksWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MindForge – Hintergrundaufgaben"
        Width="680" Height="420"
        MinWidth="500" MinHeight="280"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgBrush}"
        Foreground="{DynamicResource TextBrush}"
        ResizeMode="CanResize">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource BgSecondaryBrush}" Padding="20,14">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🔄" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Hintergrundaufgaben" FontSize="17" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="TxtRunningCount" Text="0 aktiv" FontSize="12"
                               Foreground="{DynamicResource TextMutedBrush}"
                               VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <Button Content="Alle abbrechen" Click="OnCancelAll"
                            Background="#EF4444" Foreground="White"
                            BorderThickness="0" Padding="10,5" FontSize="12">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#DC2626"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Task list -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16,12">
            <ItemsControl x:Name="TasksList" ItemsSource="{Binding Tasks}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource BgSecondaryBrush}"
                                CornerRadius="8" Padding="14,10" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>

                                <!-- Name (+ error on second line, shown by code-behind) -->
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="13" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Error}" Foreground="#EF4444"
                                               FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}"
                                                                 Value="Failed">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>

                                <!-- Status -->
                                <TextBlock Grid.Column="1" Text="{Binding StatusLabel}"
                                           FontSize="12" Foreground="{DynamicResource AccentBrush}"
                                           VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                <!-- Duration -->
                                <TextBlock Grid.Column="2" Text="{Binding Duration}"
                                           FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                                           VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                <!-- Cancel -->
                                <Button Grid.Column="3" Content="⏹ Stop"
                                        Tag="{Binding TaskId}" Click="OnCancelTask"
                                        IsEnabled="{Binding IsRunning}"
                                        Background="#EF4444" Foreground="White"
                                        BorderThickness="0" Padding="8,4" FontSize="11"
                                        HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Opacity" Value="0.35"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Empty state (shown by code-behind when Tasks is empty) -->
        <TextBlock Grid.Row="1" x:Name="TxtEmpty"
                   Text="Keine aktiven Aufgaben.&#10;Starte ein KI-Werkzeug, um Aufgaben im Hintergrund zu queuen."
                   Foreground="{DynamicResource TextMutedBrush}"
                   FontSize="13" TextWrapping="Wrap" TextAlignment="Center"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Margin="40" Visibility="Collapsed"/>

        <!-- Footer -->
        <Border Grid.Row="2" Background="{DynamicResource BgSecondaryBrush}" Padding="16,10">
            <TextBlock Text="Aufgaben laufen weiter, auch wenn die App minimiert ist."
                       Foreground="{DynamicResource TextMutedBrush}"
                       FontSize="11" HorizontalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
