<UserControl x:Class="MindForge.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="Transparent" Loaded="OnLoaded">
    
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <TextBlock x:Name="TxtWelcome" Text="Willkommen zurück, MindForger!" Foreground="White" FontSize="28" FontWeight="Bold" Margin="0,0,0,24"/>
        
        <!-- Stats Cards -->
        <Grid Grid.Row="1" Margin="0,0,0,32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- XP Card -->
            <Border Grid.Column="0" Background="#161B2E" CornerRadius="12" Padding="20" Margin="0,0,16,0">
                <StackPanel>
                    <TextBlock Text="Gesamt XP" Foreground="#8892B0" FontSize="14"/>
                    <TextBlock x:Name="TxtTotalXP" Text="0" Foreground="#6C63FF" FontSize="32" FontWeight="Bold" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
            
            <!-- Streak Card -->
            <Border Grid.Column="1" Background="#161B2E" CornerRadius="12" Padding="20" Margin="0,0,16,0">
                <StackPanel>
                    <TextBlock Text="Lern-Streak" Foreground="#8892B0" FontSize="14"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="🔥" FontSize="28" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock x:Name="TxtStreak" Text="0 Tage" Foreground="White" FontSize="32" FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            
            <!-- Due Items Card -->
            <Border Grid.Column="2" Background="#161B2E" CornerRadius="12" Padding="20" Margin="0,0,16,0">
                <StackPanel>
                    <TextBlock Text="Fällige Karten" Foreground="#8892B0" FontSize="14"/>
                    <TextBlock x:Name="TxtDueItems" Text="0" Foreground="#FF4C61" FontSize="32" FontWeight="Bold" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
            
            <!-- Level Card -->
            <Border Grid.Column="3" Background="#161B2E" CornerRadius="12" Padding="20">
                <StackPanel>
                    <TextBlock Text="Aktuelles Level" Foreground="#8892B0" FontSize="14"/>
                    <TextBlock x:Name="TxtLevel" Text="Level 1" Foreground="Lime" FontSize="32" FontWeight="Bold" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
        
        <!-- Main Content Area -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Learning Plan -->
            <Border Grid.Column="0" Background="#161B2E" CornerRadius="12" Padding="24" Margin="0,0,16,0">
                <StackPanel>
                    <TextBlock Text="Dein Lernplan für heute" Foreground="White" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16"/>
                    <TextBlock Text="Du bist auf dem besten Weg! Hier sind deine nächsten Schritte:" Foreground="#8892B0" FontSize="14" Margin="0,0,0,16"/>
                    
                    <Border Background="#1E2640" CornerRadius="8" Padding="16" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📚" FontSize="20" VerticalAlignment="Center" Margin="0,0,16,0"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Neues Material lesen" Foreground="White" FontWeight="SemiBold"/>
                                <TextBlock Text="Künstliche Intelligenz - Grundlagen" Foreground="#8892B0" FontSize="12"/>
                            </StackPanel>
                            <Button Content="Starten" HorizontalAlignment="Right" Margin="100,0,0,0" Style="{StaticResource MaterialDesignOutlinedButton}"/>
                        </StackPanel>
                    </Border>
                    
                    <Border Background="#1E2640" CornerRadius="8" Padding="16">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔄" FontSize="20" VerticalAlignment="Center" Margin="0,0,16,0"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Spaced Repetition" Foreground="White" FontWeight="SemiBold"/>
                                <TextBlock x:Name="TxtRepetitionStatus" Text="Keine Karten fällig" Foreground="#8892B0" FontSize="12"/>
                            </StackPanel>
                            <Button Content="Wiederholen" HorizontalAlignment="Right" Margin="100,0,0,0" Style="{StaticResource MaterialDesignOutlinedButton}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
            
            <StackPanel Grid.Column="1">
                <!-- Kalender Widget -->
                <Border Background="#161B2E" CornerRadius="12" Padding="24" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Kalender &amp; Fristen" Foreground="White" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16"/>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="🗓️ Heute:" Foreground="#8892B0" Width="80"/>
                            <TextBlock Text="Info Übungsblatt 4" Foreground="White"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="🗓️ Morgen:" Foreground="#8892B0" Width="80"/>
                            <TextBlock Text="Bio Essay Abgabe" Foreground="White"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                
                <!-- Quick Access -->
                <Border Background="#161B2E" CornerRadius="12" Padding="24">
                    <StackPanel>
                        <TextBlock Text="Zuletzt geöffnet" Foreground="White" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16"/>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12" Cursor="Hand">
                            <TextBlock Text="📄" Margin="0,0,8,0"/>
                            <TextBlock Text="Skript_Info_1.pdf" Foreground="White" TextDecorations="Underline"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12" Cursor="Hand">
                            <TextBlock Text="📄" Margin="0,0,8,0"/>
                            <TextBlock Text="Zellbiologie.pdf" Foreground="White" TextDecorations="Underline"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>