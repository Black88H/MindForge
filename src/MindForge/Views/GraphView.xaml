<UserControl x:Class="MindForge.Views.GraphView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Wissensgraph" Foreground="White" FontSize="28" FontWeight="Bold"/>
            <TextBlock Text="Visuelle Repräsentation deiner gelernten Konzepte und ihrer Verbindungen" Foreground="#8892B0" FontSize="14" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Graph Placeholder -->
        <Border Grid.Row="1" Background="#161B2E" CornerRadius="12" ClipToBounds="True">
            <Grid>
                <!-- Decorative network nodes -->
                <Ellipse Width="120" Height="120" Fill="#1E2640" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Text="Maschinelles Lernen" Foreground="White" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold"/>
                
                <Path Stroke="#3A4060" StrokeThickness="2" Data="M 600 350 L 400 200"/>
                <Ellipse Width="90" Height="90" Fill="#1E2640" Margin="350,150,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                <TextBlock Text="Neuronale Netze" Foreground="White" FontSize="11" Margin="350,150,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Width="90" TextAlignment="Center" Padding="0,35,0,0"/>
                
                <Path Stroke="#3A4060" StrokeThickness="2" Data="M 600 350 L 800 250"/>
                <Ellipse Width="90" Height="90" Fill="#1E2640" Margin="0,200,300,0" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                <TextBlock Text="Data Science" Foreground="White" FontSize="11" Margin="0,200,300,0" HorizontalAlignment="Right" VerticalAlignment="Top" Width="90" TextAlignment="Center" Padding="0,35,0,0"/>

                <Border Background="#0D1117" Opacity="0.8"/>
                <TextBlock Text="Interaktiver Graph: Coming Soon" Foreground="#6C63FF" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>