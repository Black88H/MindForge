<UserControl x:Class="MindForge.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="Transparent">
    <Grid>
        <Grid Margin="32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,24">
                <TextBlock Text="Einstellungen" Foreground="{DynamicResource TextBrush}" FontSize="28" FontWeight="Bold"/>
                <TextBlock Text="Passe MindForge an deine Präferenzen an" Foreground="{DynamicResource TextMutedBrush}" FontSize="14" Margin="0,4,0,0"/>
            </StackPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- System & Updates -->
                    <Border Background="{DynamicResource BgSecondaryBrush}" CornerRadius="12" Padding="24" Margin="0,0,0,24">
                        <StackPanel>
                            <TextBlock Text="System &amp; Updates" Foreground="{DynamicResource TextBrush}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <TextBlock Text="Version:" Foreground="{DynamicResource TextMutedBrush}" FontWeight="SemiBold" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtCurrentVersion" Text="v5.0.0 (Release)" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <TextBlock Text="Automatische Updates (Beta)" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                                <ToggleButton IsChecked="True" Style="{StaticResource MaterialDesignSwitchToggleButton}"/>
                            </StackPanel>

                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button x:Name="BtnCheckUpdates" Grid.Column="0" Content="Auf Updates prüfen"
                                        Click="OnCheckUpdatesClick" Background="{DynamicResource AccentBrush}" Foreground="{DynamicResource TextBrush}"
                                        BorderThickness="0" Height="40" Padding="16,0"/>
                                <Button x:Name="BtnDownloadUpdate" Grid.Column="1" Content="⬇ Jetzt installieren"
                                        Click="OnDownloadUpdateClick" Visibility="Collapsed"
                                        Background="#00C896" Foreground="{DynamicResource BgBrush}" FontWeight="Bold"
                                        BorderThickness="0" Height="40" Padding="16,0" Margin="12,0,0,0"/>
                                <TextBlock x:Name="TxtUpdateStatus" Grid.Column="2" Text=""
                                           Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"
                                           Margin="16,0,0,0" TextWrapping="Wrap"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- KI & API Keys -->
                    <Border Background="{DynamicResource BgSecondaryBrush}" CornerRadius="12" Padding="24" Margin="0,0,0,24">
                        <StackPanel>
                            <TextBlock Text="KI &amp; API Keys" Foreground="{DynamicResource TextBrush}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16"/>

                            <TextBlock Text="Lokales LLM (Ollama)" Foreground="{DynamicResource TextMutedBrush}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="TxtOllamaUrl" materialDesign:HintAssist.Hint="Ollama Endpoint URL"
                                         Text="http://localhost:11434"
                                         Foreground="{DynamicResource TextBrush}" BorderBrush="{DynamicResource BorderBrush}" Height="40" Margin="0,0,12,0"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                                <Button Grid.Column="1" Content="Verbindung testen" Click="OnTestOllamaClick"
                                        Background="{DynamicResource BgTertiaryBrush}" Foreground="{DynamicResource TextBrush}" BorderThickness="0" Height="40" Padding="12,0"/>
                                <TextBlock x:Name="TxtOllamaStatus" Grid.Column="2" Text="" VerticalAlignment="Center" Margin="10,0,0,0" FontSize="18"/>
                            </Grid>

                            <Separator Background="{DynamicResource BorderBrush}" Margin="0,16,0,16"/>

                            <TextBlock Text="OpenAI API Key (Optional)" Foreground="{DynamicResource TextMutedBrush}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <PasswordBox x:Name="PwdOpenAIKey" materialDesign:HintAssist.Hint="sk-..."
                                             Foreground="{DynamicResource TextBrush}" BorderBrush="{DynamicResource BorderBrush}" Height="40" Margin="0,0,12,0"
                                             Style="{StaticResource MaterialDesignOutlinedPasswordBox}"/>
                                <Button Grid.Column="1" Content="👁" Click="OnToggleKeyVisibility"
                                        Background="Transparent" Foreground="{DynamicResource TextMutedBrush}" BorderThickness="0"
                                        Height="40" Width="40" ToolTip="Key anzeigen"/>
                                <Button Grid.Column="2" Content="Speichern" Click="OnSaveApiKeyClick"
                                        Background="{DynamicResource AccentBrush}" Foreground="{DynamicResource TextBrush}" BorderThickness="0"
                                        Height="40" Padding="12,0" Margin="8,0,0,0"/>
                                <TextBlock x:Name="TxtApiKeyStatus" Grid.Column="3" Text="" VerticalAlignment="Center" Margin="10,0,0,0" FontSize="18"/>
                            </Grid>
                            <TextBox x:Name="TxtOpenAIKeyVisible" materialDesign:HintAssist.Hint="sk-..."
                                     Foreground="{DynamicResource TextBrush}" BorderBrush="{DynamicResource BorderBrush}" Height="40" Margin="0,0,0,0"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>

                    <!-- Ollama Model Selection -->
                    <Border Background="{DynamicResource BgSecondaryBrush}" CornerRadius="12" Padding="24" Margin="0,0,0,24">
                        <StackPanel>
                            <TextBlock Text="Ollama Model Selection" Foreground="{DynamicResource TextBrush}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16"/>
                            <TextBlock Text="Choose preferred models for each task type. Click 'Refresh' to load installed models." Foreground="{DynamicResource TextMutedBrush}" FontSize="13" Margin="0,0,0,16"/>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="🔄 Refresh Models" x:Name="BtnRefreshModels"
                                        Click="OnRefreshModelsClick"
                                        Background="{DynamicResource AccentBrush}" Foreground="White"
                                        BorderThickness="0" Height="40" Padding="16,0"/>
                                <TextBlock x:Name="TxtModelStatus" Grid.Column="2" Text=""
                                           Foreground="{DynamicResource AccentBrush}"
                                           VerticalAlignment="Center" Margin="16,0,0,0" TextWrapping="Wrap"/>
                            </Grid>

                            <TextBlock Text="Chat / Q&amp;A model:" Foreground="{DynamicResource TextMutedBrush}" FontSize="13" Margin="0,8,0,4"/>
                            <ComboBox x:Name="CboChatModel"
                                      Style="{StaticResource MaterialDesignComboBox}"
                                      Foreground="{DynamicResource TextBrush}"
                                      Height="40" Margin="0,0,0,12"/>

                            <TextBlock Text="Summarization model:" Foreground="{DynamicResource TextMutedBrush}" FontSize="13" Margin="0,0,0,4"/>
                            <ComboBox x:Name="CboSumModel"
                                      Style="{StaticResource MaterialDesignComboBox}"
                                      Foreground="{DynamicResource TextBrush}"
                                      Height="40" Margin="0,0,0,16"/>

                            <Button Content="💾 Save Model Preferences" x:Name="BtnSaveModels"
                                    Click="OnSaveModelsClick"
                                    Background="{DynamicResource AccentBrush}" Foreground="White"
                                    BorderThickness="0" Height="40" Padding="16,0" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>

                    <!-- Theme / Erscheinungsbild -->
                    <Border Background="{DynamicResource BgSecondaryBrush}" CornerRadius="12" Padding="24" Margin="0,0,0,24">
                        <StackPanel>
                            <TextBlock Text="Erscheinungsbild &amp; Themes" Foreground="{DynamicResource TextBrush}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16"/>
                            <TextBlock Text="Theme sofort wechseln — kein Neustart erforderlich" Foreground="{DynamicResource TextMutedBrush}" FontSize="13" Margin="0,0,0,20"/>

                            <WrapPanel>
                                <Button Content="🌑 Dark" Tag="Dark" Click="OnThemeClick"
                                        x:Name="BtnThemeDark"
                                        Background="{DynamicResource AccentBrush}" Foreground="{DynamicResource TextBrush}" BorderThickness="0"
                                        Height="40" Padding="16,0" Margin="0,0,12,12" FontWeight="SemiBold"/>
                                <Button Content="☀️ Light" Tag="Light" Click="OnThemeClick"
                                        Background="{DynamicResource BgTertiaryBrush}" Foreground="{DynamicResource TextMutedBrush}" BorderThickness="0"
                                        Height="40" Padding="16,0" Margin="0,0,12,12"/>
                                <Button Content="🧊 Nord" Tag="Nord" Click="OnThemeClick"
                                        Background="{DynamicResource BgTertiaryBrush}" Foreground="{DynamicResource TextMutedBrush}" BorderThickness="0"
                                        Height="40" Padding="16,0" Margin="0,0,12,12"/>
                                <Button Content="🌅 Solarized" Tag="Solarized" Click="OnThemeClick"
                                        Background="{DynamicResource BgTertiaryBrush}" Foreground="{DynamicResource TextMutedBrush}" BorderThickness="0"
                                        Height="40" Padding="16,0" Margin="0,0,12,12"/>
                                <Button Content="⚡ High Contrast" Tag="HighContrast" Click="OnThemeClick"
                                        Background="{DynamicResource BgTertiaryBrush}" Foreground="{DynamicResource TextMutedBrush}" BorderThickness="0"
                                        Height="40" Padding="16,0" Margin="0,0,12,12"/>
                            </WrapPanel>

                            <TextBlock x:Name="TxtActiveTheme" Text="Aktives Theme: Dark" Foreground="{DynamicResource AccentBrush}" FontSize="12" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Update Modal Overlay -->
        <Border x:Name="UpdateModal" Background="#CC000000" Visibility="Collapsed">
            <Border Background="{DynamicResource BgSecondaryBrush}" CornerRadius="16" Padding="36" Width="560"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="🚀 Update verfügbar!" Foreground="{DynamicResource TextBrush}" FontSize="24" FontWeight="Bold" Margin="0,0,0,8"/>
                    <TextBlock x:Name="TxtModalVersion" Text="" Foreground="{DynamicResource AccentBrush}" FontSize="14" Margin="0,0,0,20"/>

                    <Border Background="{DynamicResource BgBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,20" MaxHeight="200">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="TxtChangelog" Text="" Foreground="{DynamicResource TextMutedBrush}" FontSize="13"
                                       TextWrapping="Wrap" FontFamily="Consolas"/>
                        </ScrollViewer>
                    </Border>

                    <ProgressBar x:Name="PrgDownload" Height="6" Value="0" Maximum="100"
                                 Foreground="#00C896" Background="{DynamicResource BorderBrush}" BorderThickness="0"
                                 Margin="0,0,0,12" Visibility="Collapsed"/>
                    <TextBlock x:Name="TxtDownloadProgress" Text="" Foreground="{DynamicResource TextMutedBrush}" FontSize="12"
                               Margin="0,0,0,20" Visibility="Collapsed"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Schließen" Click="OnCloseModal"
                                Background="Transparent" Foreground="{DynamicResource TextMutedBrush}" BorderThickness="0"
                                Height="44" FontSize="14"/>
                        <Button x:Name="BtnModalInstall" Grid.Column="1" Content="⬇ Jetzt installieren"
                                Click="OnModalInstallClick"
                                Background="#00C896" Foreground="{DynamicResource BgBrush}" BorderThickness="0"
                                Height="44" FontSize="14" FontWeight="Bold" Margin="12,0,0,0">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>

