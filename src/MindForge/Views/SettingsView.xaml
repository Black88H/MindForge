<UserControl x:Class="MindForge.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="Transparent">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Einstellungen" Foreground="White" FontSize="28" FontWeight="Bold"/>
            <TextBlock Text="Passe MindForge an deine Präferenzen an" Foreground="#8892B0" FontSize="14" Margin="0,4,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                
                <!-- System & Updates -->
                <Border Background="#161B2E" CornerRadius="12" Padding="24" Margin="0,0,0,24">
                    <StackPanel>
                        <TextBlock Text="System &amp; Updates" Foreground="White" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16"/>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="Version:" Foreground="#B0B8D1" FontWeight="SemiBold" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="v2.0.0 (Release)" Foreground="White" VerticalAlignment="Center" Margin="0,0,16,0"/>
                        </StackPanel>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="Automatische Updates (Beta)" Foreground="White" VerticalAlignment="Center" Margin="0,0,16,0"/>
                            <ToggleButton IsChecked="True" Style="{StaticResource MaterialDesignSwitchToggleButton}" ToolTip="Updates automatisch über GitHub beziehen"/>
                        </StackPanel>
                        
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="BtnCheckUpdates" Grid.Column="0" Content="Auf Updates prüfen" Click="OnCheckUpdatesClick" Background="#6C63FF" Foreground="White" BorderThickness="0" Height="40" Padding="16,0"/>
                            <Button x:Name="BtnDownloadUpdate" Grid.Column="1" Content="Jetzt aktualisieren" Click="OnDownloadUpdateClick" Visibility="Collapsed" Background="Lime" Foreground="#0D1117" FontWeight="Bold" BorderThickness="0" Height="40" Padding="16,0" Margin="16,0,0,0"/>
                            <TextBlock x:Name="TxtUpdateStatus" Grid.Column="2" Text="" Foreground="Lime" VerticalAlignment="Center" Margin="16,0,0,0" TextWrapping="Wrap"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- KI & API -->
                <Border Background="#161B2E" CornerRadius="12" Padding="24" Margin="0,0,0,24">
                    <StackPanel>
                        <TextBlock Text="KI &amp; API Keys" Foreground="White" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16"/>
                        
                        <!-- Ollama Configuration -->
                        <TextBlock Text="Lokales LLM (Ollama)" Foreground="#B0B8D1" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox materialDesign:HintAssist.Hint="Ollama Endpoint URL" Text="http://localhost:11434" Foreground="White" BorderBrush="#3A4060" Height="40" Margin="0,0,16,0" Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                            <Button Grid.Column="1" Content="Verbindung testen" Background="#1E2640" Foreground="White" BorderThickness="0" Height="40"/>
                        </Grid>

                        <Separator Background="#252D45" Margin="0,16,0,24"/>

                        <!-- OpenAI Configuration -->
                        <TextBlock Text="OpenAI API Key (Optional)" Foreground="#B0B8D1" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <PasswordBox materialDesign:HintAssist.Hint="sk-..." Foreground="White" BorderBrush="#3A4060" Height="40" Margin="0,0,16,0" Style="{StaticResource MaterialDesignOutlinedPasswordBox}"/>
                            <Button Grid.Column="1" Content="Speichern" Background="#6C63FF" Foreground="White" BorderThickness="0" Height="40"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- UI -->
                <Border Background="#161B2E" CornerRadius="12" Padding="24" Margin="0,0,0,24">
                    <StackPanel>
                        <TextBlock Text="Erscheinungsbild" Foreground="White" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Dark Mode" Foreground="White" VerticalAlignment="Center" Margin="0,0,16,0"/>
                            <ToggleButton IsChecked="True" Style="{StaticResource MaterialDesignSwitchToggleButton}" ToolTip="Dark Mode umschalten"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>