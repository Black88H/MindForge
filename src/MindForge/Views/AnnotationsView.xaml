<UserControl x:Class="MindForge.Views.AnnotationsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="🖊 Markierungen &amp; Notizen" Foreground="{DynamicResource TextBrush}"
                       FontSize="28" FontWeight="Bold"/>
            <TextBlock Text="Alle deine intelligenten Hervorhebungen mit KI-Notizen"
                       Foreground="{DynamicResource TextMutedBrush}" FontSize="14" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Filter bar -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Filter:" Foreground="{DynamicResource TextMutedBrush}"
                       FontSize="13" VerticalAlignment="Center" Margin="0,0,12,0"/>
            <ComboBox x:Name="CboFilter" Grid.Column="1"
                      Style="{StaticResource MaterialDesignComboBox}"
                      Foreground="{DynamicResource TextBrush}"
                      Height="40" SelectionChanged="OnFilterChanged">
                <ComboBoxItem Content="Alle" IsSelected="True"/>
                <ComboBoxItem Content="Highlight"/>
                <ComboBoxItem Content="Wichtig"/>
                <ComboBoxItem Content="Frage"/>
                <ComboBoxItem Content="Konzept"/>
                <ComboBoxItem Content="Beispiel"/>
                <ComboBoxItem Content="Todo"/>
                <ComboBoxItem Content="Verwirrend"/>
            </ComboBox>
            <TextBlock x:Name="TxtCount" Grid.Column="2"
                       Foreground="{DynamicResource TextMutedBrush}"
                       FontSize="13" VerticalAlignment="Center" Margin="16,0,0,0"/>
        </Grid>

        <!-- List -->
        <Border Grid.Row="2" Background="{DynamicResource BgSecondaryBrush}" CornerRadius="12" Padding="8">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="AnnotationsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="8" Padding="16" CornerRadius="8"
                                    Background="{DynamicResource BgTertiaryBrush}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Color stripe -->
                                    <Border Grid.Column="0" CornerRadius="3" Margin="0,0,12,0"
                                            Background="{Binding Color, Converter={StaticResource StringToBrushConverter}}"/>

                                    <!-- Content -->
                                    <StackPanel Grid.Column="1">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <Border Background="{Binding Color, Converter={StaticResource StringToBrushConverter}}"
                                                    CornerRadius="4" Padding="6,2" Margin="0,0,8,0">
                                                <TextBlock Text="{Binding Type, Converter={StaticResource AnnotationTypeConverter}}"
                                                           FontSize="10" FontWeight="Bold" Foreground="White"/>
                                            </Border>
                                            <TextBlock Text="{Binding CreatedAt, StringFormat=dd.MM.yyyy}"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       FontSize="11" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <TextBlock Text="{Binding SelectedText}"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   FontSize="13" TextWrapping="Wrap"
                                                   FontStyle="Italic" Margin="0,0,0,8"
                                                   MaxHeight="60" ClipToBounds="True"/>

                                        <TextBlock Text="{Binding AINote}"
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   FontSize="12" TextWrapping="Wrap"/>

                                        <TextBlock Text="{Binding UserNote}"
                                                   Foreground="{DynamicResource AccentBrush}"
                                                   FontSize="12" TextWrapping="Wrap"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>

                                    <!-- Delete -->
                                    <Button Grid.Column="2" Content="🗑" VerticalAlignment="Top"
                                            Tag="{Binding Id}"
                                            Click="OnDelete"
                                            Background="Transparent" BorderThickness="0"
                                            Foreground="{DynamicResource TextMutedBrush}"
                                            FontSize="16" Width="32" Height="32"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
