<UserControl x:Class="MindForge.Views.LearningView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Spaced Repetition" Foreground="White" FontSize="28" FontWeight="Bold"/>
            <TextBlock Text="Lerne smart, nicht hart. Deine tägliche Wiederholungssession." Foreground="#8892B0" FontSize="14" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Card Container -->
        <Border Grid.Row="1" Background="#161B2E" CornerRadius="16" MaxWidth="800" Margin="0,20,0,40">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Card Content -->
                <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40">
                    <TextBlock Text="Was versteht man unter Polymorphie in der objektorientierten Programmierung?" 
                               Foreground="White" FontSize="24" TextWrapping="Wrap" TextAlignment="Center" FontWeight="SemiBold"/>
                    
                    <Separator Background="#3A4060" Margin="0,40,0,40"/>
                    
                    <TextBlock Text="Die Eigenschaft, dass Objekte unterschiedlicher Klassen auf dieselbe Methode unterschiedlich reagieren können. Methoden können überschrieben oder überladen werden." 
                               Foreground="#B0B8D1" FontSize="18" TextWrapping="Wrap" TextAlignment="Center"/>
                </StackPanel>
                
                <!-- Actions -->
                <Grid Grid.Row="1" Margin="32">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Button Grid.Column="0" Content="Blackout" Background="#2A1B2E" Foreground="#FF4C61" BorderThickness="0" Height="48" Margin="0,0,10,0"/>
                    <Button Grid.Column="1" Content="Schwer" Background="#2E241B" Foreground="#FFB04C" BorderThickness="0" Height="48" Margin="0,0,10,0"/>
                    <Button Grid.Column="2" Content="Gut" Background="#1B2E24" Foreground="Lime" BorderThickness="0" Height="48" Margin="0,0,10,0"/>
                    <Button Grid.Column="3" Content="Leicht" Background="#1B2230" Foreground="#6C63FF" BorderThickness="0" Height="48"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>