<UserControl x:Class="MindForge.Views.TestsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <StackPanel HorizontalAlignment="Left">
                <TextBlock Text="Tests &amp; Klausuren" Foreground="White" FontSize="28" FontWeight="Bold"/>
                <TextBlock Text="Lass dir von der KI Prüfungen generieren und teste dein Wissen" Foreground="#8892B0" FontSize="14" Margin="0,4,0,0"/>
            </StackPanel>
            
            <Button HorizontalAlignment="Right" VerticalAlignment="Top" 
                    Content="✨ Neuen Test generieren" Height="40" Padding="16,0"
                    Background="#6C63FF" Foreground="White" BorderThickness="0" Cursor="Hand" FontWeight="SemiBold"/>
        </Grid>

        <!-- Content -->
        <Border Grid.Row="1" Background="#161B2E" CornerRadius="12" Padding="20">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="TEST NAME" Foreground="#8892B0" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1" Text="FACH" Foreground="#8892B0" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="2" Text="ERGEBNIS" Foreground="#8892B0" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="3" Text="DATUM" Foreground="#8892B0" FontSize="12" FontWeight="SemiBold" Width="100"/>
                    </Grid>
                    
                    <Separator Background="#252D45" Margin="0,0,0,16"/>

                    <!-- Test 1 -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="OOP Konzepte Deep Dive" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="Informatik" Foreground="#B0B8D1" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <TextBlock Text="85%" Foreground="Lime" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="(Bestanden)" Foreground="#8892B0" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Grid.Column="3" Text="Vor 2 Tagen" Foreground="#B0B8D1" VerticalAlignment="Center" Width="100"/>
                    </Grid>

                    <Separator Background="#252D45" Margin="0,0,0,16"/>
                    
                    <!-- Test 2 -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Zellatmung und Photosynthese" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="Biologie" Foreground="#B0B8D1" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <TextBlock Text="42%" Foreground="#FF4C61" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="(Nicht bestanden)" Foreground="#8892B0" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Grid.Column="3" Text="Vor 5 Tagen" Foreground="#B0B8D1" VerticalAlignment="Center" Width="100"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>