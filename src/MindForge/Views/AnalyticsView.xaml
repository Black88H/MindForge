<UserControl x:Class="MindForge.Views.AnalyticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Statistiken &amp; Fortschritt" Foreground="White" FontSize="28" FontWeight="Bold"/>
            <TextBlock Text="Verfolge deine Lernkurve und analysiere deine Stärken" Foreground="{DynamicResource TextMutedBrush}" FontSize="14" Margin="0,4,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <Border Grid.Column="0" Background="{DynamicResource BgSecondaryBrush}" CornerRadius="12" Padding="24" Margin="0,0,16,0" VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock Text="Aktivitätshistorie" Foreground="White" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,24"/>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Border Background="{DynamicResource BgTertiaryBrush}" CornerRadius="4" Width="8" Height="40" Margin="0,0,16,0"/>
                        <StackPanel>
                            <TextBlock Text="Lernsession abgeschlossen" Foreground="White" FontWeight="SemiBold"/>
                            <TextBlock Text="Heute, 10:45 Uhr · +50 XP" Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                        </StackPanel>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Border Background="{DynamicResource AccentBrush}" CornerRadius="4" Width="8" Height="40" Margin="0,0,16,0"/>
                        <StackPanel>
                            <TextBlock Text="Neues Fach erstellt: Biologie" Foreground="White" FontWeight="SemiBold"/>
                            <TextBlock Text="Gestern, 18:20 Uhr" Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                        </StackPanel>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Border Background="#FF4C61" CornerRadius="4" Width="8" Height="40" Margin="0,0,16,0"/>
                        <StackPanel>
                            <TextBlock Text="Test: OOP Konzepte" Foreground="White" FontWeight="SemiBold"/>
                            <TextBlock Text="Vor 2 Tagen · 85% erreicht" Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>
            
            <Border Grid.Column="1" Background="{DynamicResource BgSecondaryBrush}" CornerRadius="12" Padding="24" VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock Text="XP Verteilung nach Fach" Foreground="White" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,24"/>
                    
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Informatik" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
                        <ProgressBar Grid.Column="1" Value="60" Maximum="100" Height="12" Foreground="{DynamicResource AccentBrush}" Background="{DynamicResource BgTertiaryBrush}" BorderThickness="0" />
                    </Grid>
                    
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Mathematik" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
                        <ProgressBar Grid.Column="1" Value="80" Maximum="100" Height="12" Foreground="Lime" Background="{DynamicResource BgTertiaryBrush}" BorderThickness="0" />
                    </Grid>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Biologie" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
                        <ProgressBar Grid.Column="1" Value="30" Maximum="100" Height="12" Foreground="#FF4C61" Background="{DynamicResource BgTertiaryBrush}" BorderThickness="0" />
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
