<UserControl x:Class="MindForge.Views.AnalyticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="📊 Lernanalyse" Foreground="{DynamicResource TextBrush}"
                       FontSize="28" FontWeight="Bold"/>
            <TextBlock Text="Verfolge deine Lernkurve und analysiere deinen Fortschritt"
                       Foreground="{DynamicResource TextMutedBrush}" FontSize="14" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- KPI row -->
        <UniformGrid Grid.Row="1" Columns="5" Margin="0,0,0,24">
            <!-- Total Minutes -->
            <Border Background="{DynamicResource BgSecondaryBrush}" CornerRadius="12" Padding="20" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="⏱" FontSize="24" Margin="0,0,0,8"/>
                    <TextBlock x:Name="KpiMinutes" Text="—"
                               Foreground="{DynamicResource AccentBrush}"
                               FontSize="28" FontWeight="Bold"/>
                    <TextBlock Text="Minuten gelernt" Foreground="{DynamicResource TextMutedBrush}" FontSize="11"/>
                </StackPanel>
            </Border>
            <!-- Sessions -->
            <Border Background="{DynamicResource BgSecondaryBrush}" CornerRadius="12" Padding="20" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="🎯" FontSize="24" Margin="0,0,0,8"/>
                    <TextBlock x:Name="KpiSessions" Text="—"
                               Foreground="{DynamicResource AccentBrush}"
                               FontSize="28" FontWeight="Bold"/>
                    <TextBlock Text="Lernsessions" Foreground="{DynamicResource TextMutedBrush}" FontSize="11"/>
                </StackPanel>
            </Border>
            <!-- XP -->
            <Border Background="{DynamicResource BgSecondaryBrush}" CornerRadius="12" Padding="20" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="⚡" FontSize="24" Margin="0,0,0,8"/>
                    <TextBlock x:Name="KpiXP" Text="—"
                               Foreground="{DynamicResource AccentBrush}"
                               FontSize="28" FontWeight="Bold"/>
                    <TextBlock Text="XP verdient" Foreground="{DynamicResource TextMutedBrush}" FontSize="11"/>
                </StackPanel>
            </Border>
            <!-- Streak -->
            <Border Background="{DynamicResource BgSecondaryBrush}" CornerRadius="12" Padding="20" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="🔥" FontSize="24" Margin="0,0,0,8"/>
                    <TextBlock x:Name="KpiStreak" Text="—"
                               Foreground="{DynamicResource AccentBrush}"
                               FontSize="28" FontWeight="Bold"/>
                    <TextBlock Text="Tage Streak" Foreground="{DynamicResource TextMutedBrush}" FontSize="11"/>
                </StackPanel>
            </Border>
            <!-- Tokens -->
            <Border Background="{DynamicResource BgSecondaryBrush}" CornerRadius="12" Padding="20">
                <StackPanel>
                    <TextBlock Text="🤖" FontSize="24" Margin="0,0,0,8"/>
                    <TextBlock x:Name="KpiTokens" Text="—"
                               Foreground="{DynamicResource AccentBrush}"
                               FontSize="28" FontWeight="Bold"/>
                    <TextBlock Text="KI-Tokens" Foreground="{DynamicResource TextMutedBrush}" FontSize="11"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Charts row -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- 7-day bar chart -->
            <Border Grid.Column="0" Background="{DynamicResource BgSecondaryBrush}"
                    CornerRadius="12" Padding="24" Margin="0,0,20,0">
                <StackPanel>
                    <TextBlock Text="Aktivität — letzte 7 Tage"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="18" FontWeight="SemiBold" Margin="0,0,0,20"/>

                    <!-- Bar chart canvas -->
                    <Canvas x:Name="BarChart" Height="200" Margin="0,0,0,8"/>

                    <!-- Day labels -->
                    <UniformGrid x:Name="DayLabels" Rows="1" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Per-subject breakdown -->
            <Border Grid.Column="1" Background="{DynamicResource BgSecondaryBrush}"
                    CornerRadius="12" Padding="24" VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock Text="XP nach Fach"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="18" FontWeight="SemiBold" Margin="0,0,0,20"/>

                    <StackPanel x:Name="SubjectBars"/>

                    <TextBlock x:Name="TxtNoSubject"
                               Text="Noch keine Fach-Aktivität vorhanden."
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="12" Visibility="Collapsed" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
