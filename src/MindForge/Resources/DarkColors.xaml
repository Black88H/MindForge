<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Backgrounds -->
    <SolidColorBrush x:Key="BgBrush" Color="#1E1E2E"/>
    <SolidColorBrush x:Key="BgSecondaryBrush" Color="#2D2D3D"/>
    <SolidColorBrush x:Key="BgTertiaryBrush" Color="#3E3E4E"/>
    
    <!-- Accents -->
    <SolidColorBrush x:Key="AccentBrush" Color="#A78BFA"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#8B5CF6"/>
    <SolidColorBrush x:Key="AccentSecondaryBrush" Color="#F59E0B"/>
    
    <!-- Text -->
    <SolidColorBrush x:Key="TextBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#9CA3AF"/>
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="#6B7280"/>
    
    <!-- Borders -->
    <SolidColorBrush x:Key="BorderBrush" Color="#4B5563"/>
    
    <!-- Semantic -->
    <SolidColorBrush x:Key="SuccessBrush" Color="#10B981"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#EF4444"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#F59E0B"/>
</ResourceDictionary>
