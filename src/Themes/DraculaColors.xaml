<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dracula -->
    <Color x:Key="BgColor">#FF282A36</Color>
    <Color x:Key="Bg1Color">#FF2F3146</Color>
    <Color x:Key="Bg2Color">#FF383A4D</Color>
    <Color x:Key="Bg3Color">#FF44475A</Color>
    <Color x:Key="LineColor">#FF44475A</Color>
    <Color x:Key="LineSoftColor">#FF383A4D</Color>
    <Color x:Key="TextColor">#FFF8F8F2</Color>
    <Color x:Key="Text2Color">#FFCFCFE2</Color>
    <Color x:Key="Text3Color">#FF6272A4</Color>
    <Color x:Key="AccentColor">#FFBD93F9</Color>
    <Color x:Key="Accent2Color">#FFD6ACFF</Color>
    <Color x:Key="AccentSoftColor">#22BD93F9</Color>
    <Color x:Key="SuccessColor">#FF50FA7B</Color>
    <Color x:Key="SuccessSoftColor">#2450FA7B</Color>
    <Color x:Key="DangerColor">#FFFF5555</Color>
    <Color x:Key="DangerSoftColor">#24FF5555</Color>
    <Color x:Key="WarnColor">#FFFFB86C</Color>
    <Color x:Key="WarnSoftColor">#28FFB86C</Color>
    <Color x:Key="StreakColor">#FFFF6E6E</Color>
    <Color x:Key="GoldColor">#FFFFF1A8</Color>

    <SolidColorBrush x:Key="BgBrush"          Color="{StaticResource BgColor}"/>
    <SolidColorBrush x:Key="Bg1Brush"         Color="{StaticResource Bg1Color}"/>
    <SolidColorBrush x:Key="Bg2Brush"         Color="{StaticResource Bg2Color}"/>
    <SolidColorBrush x:Key="Bg3Brush"         Color="{StaticResource Bg3Color}"/>
    <SolidColorBrush x:Key="LineBrush"        Color="{StaticResource LineColor}"/>
    <SolidColorBrush x:Key="TextBrush"        Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="Text2Brush"       Color="{StaticResource Text2Color}"/>
    <SolidColorBrush x:Key="Text3Brush"       Color="{StaticResource Text3Color}"/>
    <SolidColorBrush x:Key="AccentBrush"      Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="Accent2Brush"     Color="{StaticResource Accent2Color}"/>
    <SolidColorBrush x:Key="AccentSoftBrush"  Color="{StaticResource AccentSoftColor}"/>
    <SolidColorBrush x:Key="SuccessBrush"     Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="SuccessSoftBrush" Color="{StaticResource SuccessSoftColor}"/>
    <SolidColorBrush x:Key="DangerBrush"      Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="DangerSoftBrush"  Color="{StaticResource DangerSoftColor}"/>
    <SolidColorBrush x:Key="WarnBrush"        Color="{StaticResource WarnColor}"/>
    <SolidColorBrush x:Key="WarnSoftBrush"    Color="{StaticResource WarnSoftColor}"/>
    <SolidColorBrush x:Key="StreakBrush"      Color="{StaticResource StreakColor}"/>
    <SolidColorBrush x:Key="GoldBrush"        Color="{StaticResource GoldColor}"/>

    <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource AccentColor}" Offset="0"/>
        <GradientStop Color="{StaticResource Accent2Color}" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="StreakGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFFF6E6E" Offset="0"/>
        <GradientStop Color="#FFFFB86C" Offset="1"/>
    </LinearGradientBrush>

</ResourceDictionary>
