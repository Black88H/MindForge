<UserControl x:Class="MindForge.Views.TestsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MindForge.ViewModels"
             Background="{StaticResource BgBrush}">

    <UserControl.DataContext>
        <vm:TestsViewModel/>
    </UserControl.DataContext>

    <Grid>
        <!-- SETUP PANEL -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibility}, ConverterParameter=invert}">
            <Grid MaxWidth="1100" Margin="40,32,40,40" HorizontalAlignment="Left">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Margin="0,0,0,24">
                    <TextBlock Text="Tests" FontFamily="Georgia" FontSize="26"
                               Foreground="{StaticResource TextBrush}" Margin="0,0,0,6"/>
                    <TextBlock Text="Erstelle und verwalte deine Lernkontrollen"
                               FontSize="13" Foreground="{StaticResource Text3Brush}"/>
                </StackPanel>

                <!-- Creator Tabs -->
                <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,24">
                    <StackPanel>
                        <!-- Tab Bar -->
                        <Border Background="{StaticResource Bg2Brush}" CornerRadius="8" Padding="4" Margin="0,0,0,20">
                            <UniformGrid Rows="1" Columns="4">
                                <Button Height="34" Command="{Binding SelectCreatorTabCommand}" CommandParameter="0">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CreatorTab}" Value="0">
                                                    <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <TextBlock Text="Neuer Test" FontSize="12"/>
                                </Button>
                                <Button Height="34" Command="{Binding SelectCreatorTabCommand}" CommandParameter="1">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CreatorTab}" Value="1">
                                                    <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <TextBlock Text="Aus Lernplan" FontSize="12"/>
                                </Button>
                                <Button Height="34" Command="{Binding SelectCreatorTabCommand}" CommandParameter="2">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CreatorTab}" Value="2">
                                                    <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <TextBlock Text="Aus Vorlage" FontSize="12"/>
                                </Button>
                                <Button Height="34" Command="{Binding SelectCreatorTabCommand}" CommandParameter="3">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CreatorTab}" Value="3">
                                                    <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <TextBlock Text="OCR Upload" FontSize="12"/>
                                </Button>
                            </UniformGrid>
                        </Border>

                        <!-- Tab 0: New Test -->
                        <StackPanel Visibility="{Binding CreatorTab, Converter={StaticResource IntToVisibility}, ConverterParameter=0}">
                            <UniformGrid Columns="2" Margin="0,0,0,16">
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="FACH" Style="{StaticResource SectionLabel}" Margin="0,0,0,6"/>
                                    <Border Background="{StaticResource Bg2Brush}" BorderBrush="{StaticResource LineBrush}"
                                            BorderThickness="1" CornerRadius="7" Padding="12,10">
                                        <TextBox Text="{Binding TestSubject, UpdateSourceTrigger=PropertyChanged}"
                                                 Background="Transparent" BorderThickness="0"
                                                 Foreground="{StaticResource TextBrush}" FontSize="13"
                                                 CaretBrush="{StaticResource AccentBrush}"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel Margin="8,0,0,0">
                                    <TextBlock Text="ANZAHL FRAGEN" Style="{StaticResource SectionLabel}" Margin="0,0,0,6"/>
                                    <Border Background="{StaticResource Bg2Brush}" BorderBrush="{StaticResource LineBrush}"
                                            BorderThickness="1" CornerRadius="7" Padding="12,10">
                                        <TextBox Text="{Binding QuestionCount, UpdateSourceTrigger=PropertyChanged}"
                                                 Background="Transparent" BorderThickness="0"
                                                 Foreground="{StaticResource TextBrush}" FontSize="13"
                                                 CaretBrush="{StaticResource AccentBrush}"/>
                                    </Border>
                                </StackPanel>
                            </UniformGrid>
                            <TextBlock Text="SCHWIERIGKEIT" Style="{StaticResource SectionLabel}" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <RadioButton Content="Leicht" GroupName="Diff" IsChecked="{Binding IsEasy}"
                                             Margin="0,0,16,0" Foreground="{StaticResource Text2Brush}"/>
                                <RadioButton Content="Mittel" GroupName="Diff" IsChecked="{Binding IsMedium}"
                                             Margin="0,0,16,0" Foreground="{StaticResource Text2Brush}"/>
                                <RadioButton Content="Schwer" GroupName="Diff" IsChecked="{Binding IsHard}"
                                             Foreground="{StaticResource Text2Brush}"/>
                            </StackPanel>
                            <TextBlock Text="MODUS" Style="{StaticResource SectionLabel}" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                <RadioButton Content="Normal" GroupName="Mode" IsChecked="{Binding IsNormalMode}"
                                             Margin="0,0,16,0" Foreground="{StaticResource Text2Brush}"/>
                                <RadioButton Content="Prüfung" GroupName="Mode" IsChecked="{Binding IsExamMode}"
                                             Margin="0,0,16,0" Foreground="{StaticResource Text2Brush}"/>
                                <RadioButton Content="Übung" GroupName="Mode" IsChecked="{Binding IsPracticeMode}"
                                             Foreground="{StaticResource Text2Brush}"/>
                            </StackPanel>
                            <CheckBox Content="Zeitlimit aktivieren" IsChecked="{Binding TimeLimitEnabled}"
                                      Foreground="{StaticResource Text2Brush}" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal"
                                        Visibility="{Binding TimeLimitEnabled, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="Sekunden pro Frage:" Foreground="{StaticResource Text3Brush}"
                                           FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <Border Background="{StaticResource Bg2Brush}" BorderBrush="{StaticResource LineBrush}"
                                        BorderThickness="1" CornerRadius="6" Padding="10,6" Width="80">
                                    <TextBox Text="{Binding TimeLimitSeconds, UpdateSourceTrigger=PropertyChanged}"
                                             Background="Transparent" BorderThickness="0"
                                             Foreground="{StaticResource TextBrush}" FontSize="13"
                                             CaretBrush="{StaticResource AccentBrush}"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <!-- Tab 1: From Plan -->
                        <StackPanel Visibility="{Binding CreatorTab, Converter={StaticResource IntToVisibility}, ConverterParameter=1}">
                            <TextBlock Text="Wähle einen aktiven Lernplan als Testgrundlage."
                                       FontSize="13" Foreground="{StaticResource Text3Brush}" Margin="0,0,0,16"/>
                            <Border Background="{StaticResource Bg2Brush}" CornerRadius="10" Padding="16" Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📚" FontSize="20" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                    <StackPanel>
                                        <TextBlock Text="Analysis II – Lernplan" FontSize="14"
                                                   Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"/>
                                        <TextBlock Text="Aktiv · 42 Tage verbleibend" FontSize="12"
                                                   Foreground="{StaticResource Text3Brush}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Tab 2: From Template -->
                        <StackPanel Visibility="{Binding CreatorTab, Converter={StaticResource IntToVisibility}, ConverterParameter=2}">
                            <TextBlock Text="Wähle eine vorgefertigte Testvorlage."
                                       FontSize="13" Foreground="{StaticResource Text3Brush}" Margin="0,0,0,16"/>
                            <UniformGrid Columns="2">
                                <Border Style="{StaticResource Card}" Margin="0,0,4,8" Padding="16,12" Cursor="Hand">
                                    <StackPanel>
                                        <TextBlock Text="Schnelltest" FontSize="14" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"/>
                                        <TextBlock Text="10 Fragen · 5 Min" FontSize="12" Foreground="{StaticResource Text3Brush}"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}" Margin="4,0,0,8" Padding="16,12" Cursor="Hand">
                                    <StackPanel>
                                        <TextBlock Text="Standardtest" FontSize="14" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"/>
                                        <TextBlock Text="20 Fragen · 15 Min" FontSize="12" Foreground="{StaticResource Text3Brush}"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}" Margin="0,0,4,0" Padding="16,12" Cursor="Hand">
                                    <StackPanel>
                                        <TextBlock Text="Prüfungssimulation" FontSize="14" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"/>
                                        <TextBlock Text="40 Fragen · 45 Min" FontSize="12" Foreground="{StaticResource Text3Brush}"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}" Margin="4,0,0,0" Padding="16,12" Cursor="Hand">
                                    <StackPanel>
                                        <TextBlock Text="Schwächenanalyse" FontSize="14" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"/>
                                        <TextBlock Text="Adaptiv · AI-gestützt" FontSize="12" Foreground="{StaticResource Text3Brush}"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                        </StackPanel>

                        <!-- Tab 3: OCR Upload -->
                        <StackPanel Visibility="{Binding CreatorTab, Converter={StaticResource IntToVisibility}, ConverterParameter=3}">
                            <Border Background="{StaticResource Bg2Brush}" BorderBrush="{StaticResource LineBrush}"
                                    BorderThickness="2" CornerRadius="10" Padding="32" Margin="0,0,0,16">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="📄" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                                    <TextBlock Text="Bild oder PDF hierher ziehen" FontSize="14"
                                               Foreground="{StaticResource Text2Brush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="oder" FontSize="12" Foreground="{StaticResource Text3Brush}"
                                               HorizontalAlignment="Center" Margin="0,8,0,8"/>
                                    <Button Style="{StaticResource SecondaryButton}" HorizontalAlignment="Center"
                                            Command="{Binding UploadFileCommand}" Padding="20,8">
                                        <TextBlock Text="Datei auswählen" FontSize="13"/>
                                    </Button>
                                    <TextBlock Text="{Binding UploadedFileName}"
                                               Foreground="{StaticResource AccentBrush}" FontSize="12"
                                               HorizontalAlignment="Center" Margin="0,8,0,0"
                                               Visibility="{Binding UploadedFileName, Converter={StaticResource StringToVisibility}}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Start Button -->
                        <Button Style="{StaticResource PrimaryButton}" Height="44" Margin="0,20,0,0"
                                Command="{Binding StartTestCommand}">
                            <TextBlock Text="Test starten →" FontSize="14"/>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Test History -->
                <Border Grid.Row="2" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Testhistorie" FontFamily="Georgia" FontSize="18"
                                   Foreground="{StaticResource TextBrush}" Margin="0,0,0,16"/>
                        <ItemsControl ItemsSource="{Binding TestHistory}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource Bg2Brush}" CornerRadius="8"
                                            Padding="16,12" Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding Subject}" FontSize="14"
                                                           Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding Date}" FontSize="11"
                                                           Foreground="{StaticResource Text3Brush}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" HorizontalAlignment="Right" Margin="16,0">
                                                <TextBlock Text="{Binding Score}" FontSize="18" FontWeight="Bold"
                                                           Foreground="{Binding ScoreColor}" HorizontalAlignment="Right"/>
                                                <TextBlock Text="{Binding QuestionsText}" FontSize="11"
                                                           Foreground="{StaticResource Text3Brush}" HorizontalAlignment="Right"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" Text="{Binding Mode}" FontSize="11"
                                                       Foreground="{StaticResource Text3Brush}" VerticalAlignment="Center"
                                                       Margin="0,0,4,0"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="Keine Tests bisher." FontSize="13" Foreground="{StaticResource Text3Brush}"
                                   HorizontalAlignment="Center" Margin="0,16,0,0"
                                   Visibility="{Binding HasNoHistory, Converter={StaticResource BoolToVisibility}}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>

        <!-- RUNNING TEST PANEL -->
        <Grid Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibility}}"
              Margin="40,32,40,40">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Test Header -->
            <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,16" Padding="20,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding CurrentSubjectName}" FontFamily="Georgia" FontSize="18"
                                   Foreground="{StaticResource TextBrush}"/>
                        <TextBlock FontSize="12" Foreground="{StaticResource Text3Brush}">
                            <Run Text="Frage"/>
                            <Run Text="{Binding CurrentQuestionIndex}"/>
                            <Run Text="von"/>
                            <Run Text="{Binding TotalQuestions}"/>
                        </TextBlock>
                    </StackPanel>
                    <Border Grid.Column="1" Background="{StaticResource Bg2Brush}" CornerRadius="8"
                            Padding="16,8" Margin="0,0,16,0"
                            Visibility="{Binding IsExamMode, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="{Binding TimeRemaining}" FontSize="20" FontWeight="Bold"
                                   Foreground="{StaticResource DangerBrush}" FontFamily="Consolas"/>
                    </Border>
                    <ProgressBar Grid.Column="2" Value="{Binding TestProgress}" Minimum="0" Maximum="1"
                                 Style="{StaticResource SuccessProgressBar}" Width="160" Height="6"/>
                </Grid>
            </Border>

            <!-- Question Card -->
            <Border Grid.Row="1" Style="{StaticResource Card}" VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock Text="{Binding CurrentQuestion}" FontSize="16" Foreground="{StaticResource TextBrush}"
                               TextWrapping="Wrap" Margin="0,0,0,24" LineHeight="26"/>
                    <ItemsControl ItemsSource="{Binding CurrentAnswers}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Margin="0,0,0,10" Height="46" HorizontalContentAlignment="Left"
                                        Padding="16,0"
                                        Command="{Binding DataContext.SelectAnswerCommand,
                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource AccentSoftBrush}"/>
                                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsCorrect}" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource SuccessSoftBrush}"/>
                                                    <Setter Property="BorderBrush" Value="{StaticResource SuccessBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsWrong}" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource DangerSoftBrush}"/>
                                                    <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <TextBlock Text="{Binding Text}" FontSize="13" TextWrapping="Wrap"
                                               Foreground="{StaticResource Text2Brush}"/>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Navigation -->
            <Grid Grid.Row="2" Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Style="{StaticResource SecondaryButton}" Height="40" Padding="20,0"
                        Command="{Binding AbortTestCommand}">
                    <TextBlock Text="Abbrechen"/>
                </Button>
                <Button Grid.Column="2" Style="{StaticResource PrimaryButton}" Height="40" Padding="24,0"
                        Command="{Binding NextQuestionCommand}">
                    <TextBlock Text="{Binding IsLastQuestion, Converter={StaticResource BoolToNextLabel}}"/>
                </Button>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
