<UserControl x:Class="MindForge.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MindForge.ViewModels"
             Background="{StaticResource BgBrush}">
    <!-- DataContext is injected via DI by ViewLocatorConverter -->

    <ScrollViewer VerticalScrollBarVisibility="Auto" Style="{StaticResource MfScrollViewer}">
        <Grid MaxWidth="1280" Margin="32,28,32,80" HorizontalAlignment="Left">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Greeting -->
                <RowDefinition Height="Auto"/>
                <!-- Hero + Stats -->
                <RowDefinition Height="Auto"/>
                <!-- Streak / XP / Achievements -->
                <RowDefinition Height="Auto"/>
                <!-- Quick Actions -->
                <RowDefinition Height="Auto"/>
                <!-- Subjects Title -->
                <RowDefinition Height="Auto"/>
                <!-- Subjects Grid -->
                <RowDefinition Height="Auto"/>
                <!-- Recent + Reviews -->
            </Grid.RowDefinitions>

            <!-- ══════════ GREETING ══════════ -->
            <Grid Grid.Row="0" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding DateLine}"
                               FontSize="11" Foreground="{StaticResource Text3Brush}"
                               FontFamily="Consolas" Margin="0,0,0,4"/>
                    <TextBlock FontFamily="Georgia" FontSize="30" FontWeight="Normal"
                               Foreground="{StaticResource TextBrush}">
                        <Run Text="Willkommen zurück, "/>
                        <Run Text="Jonas" Foreground="{StaticResource AccentBrush}" FontStyle="Italic"/>
                        <Run Text="."/>
                    </TextBlock>
                    <TextBlock Text="{Binding StatsSubline}" FontSize="13"
                               Foreground="{StaticResource Text2Brush}" Margin="0,6,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,0,0,4">
                    <Button Style="{StaticResource SecondaryButton}" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="↩ " FontSize="13"/>
                            <TextBlock Text="Verlauf"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource PrimaryButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚡ " FontSize="13"/>
                            <TextBlock Text="Weiterlernen"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ══════════ HERO: Heute Lernen + Stats ══════════ -->
            <Grid Grid.Row="1" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.8*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- Today Learn Card -->
                <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0" ClipToBounds="True">
                    <Grid>
                        <!-- Accent glow -->
                        <Ellipse Width="280" Height="280" HorizontalAlignment="Right" VerticalAlignment="Top"
                                 Margin="0,-40,-40,0" Opacity="0.07">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="#FF5B8CFF" Offset="0"/>
                                    <GradientStop Color="Transparent" Offset="1"/>
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>

                        <StackPanel Margin="24,22,24,20">
                            <!-- Tags row -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <Border Style="{StaticResource BadgeAccent}" Margin="0,0,6,0">
                                    <TextBlock Text="{Binding CurrentSubjectTag}"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontSize="11.5" FontWeight="Medium"/>
                                </Border>
                                <Border Style="{StaticResource BadgeNeutral}" Margin="0,0,6,0">
                                    <TextBlock Text="{Binding CurrentQuestionTag}"
                                               Foreground="{StaticResource Text2Brush}" FontSize="11.5"/>
                                </Border>
                                <Border Style="{StaticResource BadgeNeutral}">
                                    <TextBlock Text="{Binding CurrentDifficultyTag}"
                                               Foreground="{StaticResource Text2Brush}" FontSize="11.5"/>
                                </Border>
                                <TextBlock HorizontalAlignment="Right" Margin="12,0,0,0" VerticalAlignment="Center"
                                           Text="{Binding QuestionNumber}" FontSize="11"
                                           Foreground="{StaticResource Text3Brush}" FontFamily="Consolas"/>
                            </StackPanel>

                            <TextBlock Text="HEUTE LERNEN" FontSize="10.5" FontWeight="SemiBold"
                                       Foreground="{StaticResource Text3Brush}" Margin="0,0,0,8"
                                       FontFamily="Consolas"/>

                            <!-- Question -->
                            <TextBlock Text="{Binding QuestionText}"
                                       FontFamily="Georgia" FontSize="22" LineHeight="30"
                                       Foreground="{StaticResource TextBrush}"
                                       TextWrapping="Wrap" Margin="0,0,0,20" MaxWidth="580"/>

                            <!-- Answer Options -->
                            <UniformGrid Rows="2" Columns="2" Margin="0,0,0,18">
                                <Button Style="{StaticResource AnswerOptionButton}" Margin="0,0,4,4">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Background="{StaticResource Bg3Brush}" CornerRadius="4" Padding="5,2" Margin="0,0,10,0">
                                            <TextBlock Text="A" FontSize="11" Foreground="{StaticResource Text2Brush}" FontFamily="Consolas"/>
                                        </Border>
                                        <TextBlock Text="∑ 1/n²" FontFamily="Consolas" FontSize="13" Foreground="{StaticResource Text2Brush}"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource AnswerOptionButton}" Margin="4,0,0,4">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Background="{StaticResource Bg3Brush}" CornerRadius="4" Padding="5,2" Margin="0,0,10,0">
                                            <TextBlock Text="B" FontSize="11" Foreground="{StaticResource Text2Brush}" FontFamily="Consolas"/>
                                        </Border>
                                        <TextBlock Text="∑ (-1)ⁿ / n" FontFamily="Consolas" FontSize="13" Foreground="{StaticResource Text2Brush}"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource AnswerOptionButton}" Margin="0,4,4,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Background="{StaticResource Bg3Brush}" CornerRadius="4" Padding="5,2" Margin="0,0,10,0">
                                            <TextBlock Text="C" FontSize="11" Foreground="{StaticResource Text2Brush}" FontFamily="Consolas"/>
                                        </Border>
                                        <TextBlock Text="∑ (-1)ⁿ / n²" FontFamily="Consolas" FontSize="13" Foreground="{StaticResource Text2Brush}"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource AnswerOptionButton}" Margin="4,4,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Background="{StaticResource Bg3Brush}" CornerRadius="4" Padding="5,2" Margin="0,0,10,0">
                                            <TextBlock Text="D" FontSize="11" Foreground="{StaticResource Text2Brush}" FontFamily="Consolas"/>
                                        </Border>
                                        <TextBlock Text="∑ 1/√n" FontFamily="Consolas" FontSize="13" Foreground="{StaticResource Text2Brush}"/>
                                    </StackPanel>
                                </Button>
                            </UniformGrid>

                            <!-- Action Buttons -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Style="{StaticResource PrimaryButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="✨ " FontSize="13"/>
                                        <TextBlock Text="KI-Erklärung"/>
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="2" Style="{StaticResource SecondaryButton}">
                                    <TextBlock Text="Beantworten"/>
                                </Button>
                                <Button Grid.Column="4" Style="{StaticResource GhostButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⇄ " FontSize="12"/>
                                        <TextBlock Text="Andere Frage"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Stats Card -->
                <Border Grid.Column="2" Style="{StaticResource Card}">
                    <StackPanel>
                        <!-- Today -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="HEUTE" FontSize="10.5" FontWeight="SemiBold"
                                           Foreground="{StaticResource Text3Brush}" Margin="0,0,0,4"/>
                                <TextBlock FontFamily="Georgia" FontSize="34" FontWeight="Normal"
                                           Foreground="{StaticResource TextBrush}">
                                    <Run Text="{Binding CorrectToday}"/>
                                    <Run Text="/" FontSize="20" Foreground="{StaticResource Text3Brush}"/>
                                    <Run Text="{Binding TotalToday}" FontSize="20" Foreground="{StaticResource Text3Brush}"/>
                                </TextBlock>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Text="▲ " FontSize="11" Foreground="{StaticResource SuccessBrush}"/>
                                    <TextBlock Text="14% vs. gestern" FontSize="11" Foreground="{StaticResource Text3Brush}"/>
                                </StackPanel>
                            </StackPanel>
                            <!-- Circular Progress (simplified) -->
                            <Border Grid.Column="1" Width="56" Height="56">
                                <Grid>
                                    <Ellipse Stroke="{StaticResource Bg3Brush}" StrokeThickness="4" Width="52" Height="52"/>
                                    <Ellipse Stroke="{StaticResource AccentBrush}" StrokeThickness="4" Width="52" Height="52"
                                             StrokeDashArray="32.7" StrokeDashOffset="8.2"
                                             RenderTransformOrigin="0.5,0.5">
                                        <Ellipse.RenderTransform>
                                            <RotateTransform Angle="-90"/>
                                        </Ellipse.RenderTransform>
                                    </Ellipse>
                                    <TextBlock Text="{Binding TodayPercentText}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextBrush}"/>
                                </Grid>
                            </Border>
                        </Grid>

                        <Border Height="1" Background="{StaticResource LineBrush}" Margin="0,0,0,12"/>

                        <!-- Zeit gelernt -->
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="ZEIT GELERNT" FontSize="10.5" FontWeight="SemiBold"
                                       Foreground="{StaticResource Text3Brush}" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding TimeLearnedText}"
                                       FontFamily="Georgia" FontSize="24"
                                       Foreground="{StaticResource TextBrush}"/>
                            <TextBlock Text="↑ 18min vs. gestern" FontSize="11" Foreground="{StaticResource Text3Brush}" Margin="0,2,0,0"/>
                        </StackPanel>

                        <Border Height="1" Background="{StaticResource LineBrush}" Margin="0,0,0,12"/>

                        <!-- Serie -->
                        <StackPanel>
                            <TextBlock Text="SERIE" FontSize="10.5" FontWeight="SemiBold"
                                       Foreground="{StaticResource Text3Brush}" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="🔥 " FontSize="20" VerticalAlignment="Center"/>
                                <TextBlock FontFamily="Georgia" FontSize="24" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center">
                                    <Run Text="{Binding Streak}"/>
                                    <Run Text=" Tage" FontSize="16" Foreground="{StaticResource Text3Brush}"/>
                                </TextBlock>
                            </StackPanel>
                            <TextBlock FontSize="11" Foreground="{StaticResource Text3Brush}" Margin="0,2,0,0">
                                <Run Text="Rekord: "/>
                                <Run Text="{Binding BestStreak}"/>
                                <Run Text=" Tage"/>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ══════════ GAMIFICATION ROW: Streak + XP + Achievements ══════════ -->
            <Grid Grid.Row="2" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="1.3*"/>
                </Grid.ColumnDefinitions>

                <!-- Streak Box -->
                <Border Grid.Column="0" CornerRadius="10" ClipToBounds="True">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FF1A120A" Offset="0"/>
                            <GradientStop Color="#FF1F150C" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border BorderBrush="#33FF6B35" BorderThickness="1" CornerRadius="10" Padding="20">
                        <StackPanel>
                            <TextBlock Text="🔥" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock HorizontalAlignment="Center" FontFamily="Georgia" FontSize="28"
                                       Foreground="{StaticResource StreakBrush}" FontWeight="Normal">
                                <Run Text="{Binding Streak}"/>
                                <Run Text=" Tage" FontSize="18" Foreground="#FFFF9A5C"/>
                            </TextBlock>
                            <TextBlock Text="Streak" HorizontalAlignment="Center" FontSize="12"
                                       Foreground="#FFFF9A5C" Margin="0,2,0,8"/>
                            <TextBlock HorizontalAlignment="Center" FontSize="11" Foreground="#CCFF9A5C">
                                <Run Text="Rekord: "/>
                                <Run Text="{Binding BestStreak}"/>
                                <Run Text=" Tage"/>
                            </TextBlock>
                            <Border Background="#22FF6B35" CornerRadius="6" Padding="8,4" Margin="0,10,0,0">
                                <TextBlock HorizontalAlignment="Center" FontSize="11" Foreground="{StaticResource WarnBrush}">
                                    <Run Text="⏱ "/>
                                    <Run Text="{Binding HoursUntilStreakEnd}"/>
                                    <Run Text=" Std. bis Streak endet"/>
                                </TextBlock>
                            </Border>
                        </StackPanel>
                    </Border>
                </Border>

                <!-- XP Card -->
                <Border Grid.Column="2" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="XP &amp; LEVEL" FontSize="10.5" FontWeight="SemiBold"
                                   Foreground="{StaticResource Text3Brush}" Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource Text2Brush}">
                                <Run Text="Level "/>
                                <Run Text="{Binding Level}"/>
                            </TextBlock>
                            <TextBlock Grid.Column="2" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource Text2Brush}">
                                <Run Text="Level "/>
                                <Run Text="{Binding Level, Converter={StaticResource PlusOne}}"/>
                            </TextBlock>
                        </Grid>

                        <ProgressBar Minimum="0" Maximum="1" Value="{Binding XPProgress, Mode=OneWay}"
                                     Style="{StaticResource SuccessProgressBar}"
                                     Height="8" Margin="0,0,0,8"/>

                        <TextBlock Text="{Binding XPProgressText}" FontSize="12"
                                   Foreground="{StaticResource Text2Brush}" HorizontalAlignment="Center"/>

                        <TextBlock Margin="0,8,0,0" HorizontalAlignment="Center" FontSize="12">
                            <Run Text="+" Foreground="{StaticResource SuccessBrush}"/>
                            <Run Text="{Binding XpGainedToday}" Foreground="{StaticResource SuccessBrush}" FontWeight="SemiBold"/>
                            <Run Text=" XP heute" Foreground="{StaticResource Text3Brush}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Recent Achievements -->
                <Border Grid.Column="4" Style="{StaticResource Card}">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <TextBlock Text="LETZTE ACHIEVEMENTS" FontSize="10.5" FontWeight="SemiBold"
                                       Foreground="{StaticResource Text3Brush}"/>
                            <TextBlock Text="Alle anzeigen →" HorizontalAlignment="Right" FontSize="11"
                                       Foreground="{StaticResource AccentBrush}" Cursor="Hand"/>
                        </Grid>

                        <ItemsControl ItemsSource="{Binding RecentAchievements}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="1" Columns="4"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel HorizontalAlignment="Center" Margin="4,0">
                                        <Border Width="44" Height="44" CornerRadius="10"
                                                Background="{StaticResource Bg2Brush}"
                                                BorderBrush="{StaticResource LineBrush}"
                                                BorderThickness="1" Margin="0,0,0,6">
                                            <TextBlock Text="{Binding Icon}" FontSize="20"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="{Binding Name}" FontSize="10" TextAlignment="Center"
                                                   Foreground="{StaticResource Text2Brush}" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding Rarity}" FontSize="9.5" TextAlignment="Center"
                                                   Foreground="{StaticResource Text3Brush}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ══════════ QUICK ACTIONS ══════════ -->
            <UniformGrid Grid.Row="3" Columns="3" Margin="0,0,0,24">
                <Border Style="{StaticResource Card}" Margin="0,0,6,0" Cursor="Hand">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Border Width="32" Height="32" CornerRadius="8"
                                    Background="{StaticResource AccentSoftBrush}" HorizontalAlignment="Left">
                                <TextBlock Text="✨" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border Background="{StaticResource Bg3Brush}" CornerRadius="4" Padding="6,2"
                                    HorizontalAlignment="Right" VerticalAlignment="Top">
                                <TextBlock Text="⌘2" FontSize="10.5" Foreground="{StaticResource Text3Brush}" FontFamily="Consolas"/>
                            </Border>
                        </Grid>
                        <TextBlock Text="KI Content generieren" FontSize="14" FontWeight="Medium"
                                   Foreground="{StaticResource TextBrush}" Margin="0,0,0,6"/>
                        <TextBlock Text="PDF hochladen · automatisch Karten, MCQs oder Zusammenfassungen erzeugen"
                                   FontSize="12" Foreground="{StaticResource Text3Brush}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                        <TextBlock Text="Öffnen →" FontSize="12" Foreground="{StaticResource AccentBrush}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Margin="6,0,6,0" Cursor="Hand">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Border Width="32" Height="32" CornerRadius="8"
                                    Background="{StaticResource AccentSoftBrush}" HorizontalAlignment="Left">
                                <TextBlock Text="📝" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border Background="{StaticResource Bg3Brush}" CornerRadius="4" Padding="6,2"
                                    HorizontalAlignment="Right" VerticalAlignment="Top">
                                <TextBlock Text="⌘3" FontSize="10.5" Foreground="{StaticResource Text3Brush}" FontFamily="Consolas"/>
                            </Border>
                        </Grid>
                        <TextBlock Text="Test erstellen" FontSize="14" FontWeight="Medium"
                                   Foreground="{StaticResource TextBrush}" Margin="0,0,0,6"/>
                        <TextBlock Text="Prüfungssimulation · Quick Check · Schwachstellen-Training"
                                   FontSize="12" Foreground="{StaticResource Text3Brush}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                        <TextBlock Text="Öffnen →" FontSize="12" Foreground="{StaticResource AccentBrush}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Margin="6,0,0,0" Cursor="Hand">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Border Width="32" Height="32" CornerRadius="8"
                                    Background="{StaticResource AccentSoftBrush}" HorizontalAlignment="Left">
                                <TextBlock Text="📊" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border Background="{StaticResource Bg3Brush}" CornerRadius="4" Padding="6,2"
                                    HorizontalAlignment="Right" VerticalAlignment="Top">
                                <TextBlock Text="⌘4" FontSize="10.5" Foreground="{StaticResource Text3Brush}" FontFamily="Consolas"/>
                            </Border>
                        </Grid>
                        <TextBlock Text="Analytics" FontSize="14" FontWeight="Medium"
                                   Foreground="{StaticResource TextBrush}" Margin="0,0,0,6"/>
                        <TextBlock Text="Fortschritt, Heatmap und Schwächen im Überblick"
                                   FontSize="12" Foreground="{StaticResource Text3Brush}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                        <TextBlock Text="Öffnen →" FontSize="12" Foreground="{StaticResource AccentBrush}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- ══════════ SUBJECTS TITLE ══════════ -->
            <Grid Grid.Row="4" Margin="0,0,0,12">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock FontFamily="Georgia" FontSize="22" FontWeight="Normal"
                               Foreground="{StaticResource TextBrush}" VerticalAlignment="Center">
                        Deine Fächer
                    </TextBlock>
                    <TextBlock Text="6 aktiv" FontSize="12" Foreground="{StaticResource Text3Brush}"
                               FontFamily="Consolas" Margin="10,0,0,0" VerticalAlignment="Bottom"/>
                </StackPanel>
                <Button HorizontalAlignment="Right" Style="{StaticResource GhostButton}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="+ " FontSize="14"/>
                        <TextBlock Text="Fach hinzufügen"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- ══════════ SUBJECTS GRID ══════════ -->
            <ItemsControl Grid.Row="5" Margin="0,0,0,28"
                          ItemsSource="{Binding Subjects}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Card}" Width="300" Margin="0,0,12,12" Cursor="Hand">
                            <StackPanel>
                                <!-- Subject header -->
                                <Grid Margin="0,0,0,12">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="36" Height="36" CornerRadius="9" Margin="0,0,12,0">
                                            <Border.Background>
                                                <SolidColorBrush Color="#225B8CFF"/>
                                            </Border.Background>
                                            <TextBlock Text="{Binding Icon}" FontSize="18"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       FontFamily="Georgia" FontWeight="SemiBold"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="Medium"
                                                       Foreground="{StaticResource TextBrush}"/>
                                            <TextBlock FontSize="11.5" Foreground="{StaticResource Text3Brush}">
                                                <Run Text="{Binding LastStudied}"/>
                                                <Run Text=" · "/>
                                                <Run Text="{Binding Difficulty}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>
                                    <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                                            Visibility="{Binding HasQuestionsToday, Converter={StaticResource BoolToVisibility}}">
                                        <Border Style="{StaticResource BadgeAccent}">
                                            <TextBlock FontSize="11" FontWeight="Medium"
                                                       Foreground="{StaticResource AccentBrush}">
                                                <Run Text="{Binding QuestionsToday}"/>
                                                <Run Text=" heute"/>
                                            </TextBlock>
                                        </Border>
                                    </Border>
                                </Grid>

                                <!-- Progress -->
                                <ProgressBar Minimum="0" Maximum="1" Value="{Binding Progress, Mode=OneWay}"
                                             Style="{StaticResource MfProgressBar}"
                                             Height="3" Margin="0,0,0,10"/>

                                <!-- Stats -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="FRAGEN" FontSize="9.5" Foreground="{StaticResource Text3Brush}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding QuestionCount}" FontSize="14" FontWeight="Medium"
                                                   Foreground="{StaticResource TextBrush}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="ERFOLG" FontSize="9.5" Foreground="{StaticResource Text3Brush}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding SuccessRatePercent}" FontSize="14" FontWeight="Medium"
                                                   Foreground="{StaticResource SuccessBrush}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="NIVEAU" FontSize="9.5" Foreground="{StaticResource Text3Brush}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Difficulty}" FontSize="14" FontWeight="Medium"
                                                   Foreground="{StaticResource TextBrush}"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- ══════════ RECENT ACTIVITY + UPCOMING REVIEWS ══════════ -->
            <Grid Grid.Row="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- Recent Activity -->
                <Border Grid.Column="0" Style="{StaticResource Card}">
                    <StackPanel>
                        <Grid Margin="0,0,0,14">
                            <TextBlock Text="Letzte Aktivität" FontSize="14" FontWeight="Medium"
                                       Foreground="{StaticResource TextBrush}"/>
                            <TextBlock Text="Verlauf →" HorizontalAlignment="Right" FontSize="11"
                                       Foreground="{StaticResource AccentBrush}" Cursor="Hand"/>
                        </Grid>

                        <ItemsControl ItemsSource="{Binding RecentActivity}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="28" Height="28" CornerRadius="6"
                                                Background="{StaticResource Bg2Brush}" Margin="0,0,10,0">
                                            <TextBlock Text="✓" FontSize="12" HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="{StaticResource SuccessBrush}"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Action}" FontSize="12"
                                                       Foreground="{StaticResource TextBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Subject}" FontSize="11"
                                                       Foreground="{StaticResource Text3Brush}"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{Binding Time}" FontSize="11"
                                                   Foreground="{StaticResource Text3Brush}" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Upcoming Reviews -->
                <Border Grid.Column="2" Style="{StaticResource Card}">
                    <StackPanel>
                        <Grid Margin="0,0,0,14">
                            <TextBlock Text="Anstehende Wiederholungen" FontSize="14" FontWeight="Medium"
                                       Foreground="{StaticResource TextBrush}"/>
                        </Grid>
                        <TextBlock FontSize="11" Foreground="{StaticResource Text3Brush}" Margin="0,0,0,10">
                            <Run Text="Spaced Repetition · nächste 7 Tage"/>
                        </TextBlock>

                        <ItemsControl ItemsSource="{Binding UpcomingReviews}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="30"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Day}" FontSize="12"
                                                   Foreground="{StaticResource Text2Brush}" VerticalAlignment="Center"/>
                                        <ProgressBar Grid.Column="1" Minimum="0" Maximum="50" Value="{Binding Count, Mode=OneWay}"
                                                     Style="{StaticResource MfProgressBar}"
                                                     Height="4" VerticalAlignment="Center" Margin="8,0"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Count}" FontSize="12"
                                                   Foreground="{StaticResource TextBrush}"
                                                   FontWeight="Medium" VerticalAlignment="Center"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Button Style="{StaticResource PrimaryButton}" HorizontalAlignment="Stretch"
                                Margin="0,12,0,0" Height="36">
                            <TextBlock Text="Heute starten"/>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
