<UserControl x:Class="MindForge.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MindForge.ViewModels"
             Background="{StaticResource BgBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Style="{StaticResource MfScrollViewer}">
        <Grid MaxWidth="1280" Margin="32,28,32,80" HorizontalAlignment="Left">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="Auto"/> <!-- Modul 6: System Status (Top Bar) -->
                <RowDefinition Height="Auto"/> <!-- Modul 1: Gamification -->
                <RowDefinition Height="Auto"/> <!-- Grid for Modules 2, 3 & 5 -->
                <RowDefinition Height="Auto"/> <!-- Modul 4: Fächer -->
            </Grid.RowDefinitions>

            <!-- ══════════ HEADER ══════════ -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding DateLine}" FontSize="11" Foreground="{StaticResource Text3Brush}" FontFamily="Consolas" Margin="0,0,0,4"/>
                    <TextBlock FontFamily="Georgia" FontSize="30" FontWeight="Normal" Foreground="{StaticResource TextBrush}">
                        <Run Text="Willkommen zurück, "/>
                        <Run Text="{Binding UserName, Mode=OneWay}" Foreground="{StaticResource AccentBrush}" FontStyle="Italic"/>
                        <Run Text="."/>
                    </TextBlock>
                    <TextBlock Text="{Binding StatsSubline}" FontSize="13" Foreground="{StaticResource Text2Brush}" Margin="0,6,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button Style="{StaticResource PrimaryButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚡ " FontSize="13"/>
                            <TextBlock Text="Lern-Session starten"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ══════════ MODUL 6: SYSTEM STATUS & SYNC ══════════ -->
            <Grid Grid.Row="1" Margin="0,0,0,24">
                <Border Style="{StaticResource Card}" Padding="12,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBlock Text="🔄" Foreground="{StaticResource AccentBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="System bereit" FontSize="12" Foreground="{StaticResource Text2Brush}" VerticalAlignment="Center"/>
                        </StackPanel>
                        
                        <!-- API Monitor -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,24,0">
                            <TextBlock Text="OpenAI: " FontSize="11" Foreground="{StaticResource Text3Brush}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding OpenAIStatus}" FontSize="11" Foreground="{StaticResource Text2Brush}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="0,0,24,0">
                            <TextBlock Text="Anthropic: " FontSize="11" Foreground="{StaticResource Text3Brush}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding AnthropicStatus}" FontSize="11" Foreground="{StaticResource Text2Brush}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4" Orientation="Horizontal">
                            <TextBlock Text="Ollama: " FontSize="11" Foreground="{StaticResource Text3Brush}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding OllamaStatus}" FontSize="11" Foreground="{StaticResource Text2Brush}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- ══════════ MODUL 1: GAMIFICATION ZENTRALE ══════════ -->
            <Grid Grid.Row="2" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- Level & Progress -->
                <Border Grid.Column="0" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="LEVEL &amp; FORTSCHRITT" FontSize="10.5" FontWeight="SemiBold" Foreground="{StaticResource Text3Brush}" Margin="0,0,0,12"/>
                        
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="{StaticResource Bg3Brush}" CornerRadius="6" Padding="8,4">
                                <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}">
                                    <Run Text="Lvl "/>
                                    <Run Text="{Binding Level}"/>
                                </TextBlock>
                            </Border>
                            <Border Grid.Column="2" Background="{StaticResource Bg3Brush}" CornerRadius="6" Padding="8,4">
                                <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource Text2Brush}">
                                    <Run Text="Lvl "/>
                                    <Run Text="{Binding Level, Converter={StaticResource PlusOne}}"/>
                                </TextBlock>
                            </Border>
                        </Grid>

                        <ProgressBar Minimum="0" Maximum="1" Value="{Binding LevelProgress, Mode=OneWay}" 
                                     Style="{StaticResource SuccessProgressBar}" Height="12" Margin="0,0,0,8"
                                     ToolTip="{Binding LevelProgressTooltip}"/>

                        <Grid>
                            <TextBlock Text="{Binding XPProgressText}" FontSize="12" Foreground="{StaticResource Text2Brush}" HorizontalAlignment="Left"/>
                            <TextBlock HorizontalAlignment="Right" FontSize="12">
                                <Run Text="+" Foreground="{StaticResource SuccessBrush}"/>
                                <Run Text="{Binding XpGainedToday}" Foreground="{StaticResource SuccessBrush}" FontWeight="SemiBold"/>
                                <Run Text=" XP heute" Foreground="{StaticResource Text3Brush}"/>
                            </TextBlock>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Streak 7-Tage-Übersicht -->
                <Border Grid.Column="2" Style="{StaticResource CardElevated}">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FF1A120A" Offset="0"/>
                            <GradientStop Color="#FF1F150C" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border BorderBrush="#33FF6B35" BorderThickness="1" CornerRadius="10" Padding="16">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <TextBlock Text="LERN-STREAK" FontSize="10.5" FontWeight="SemiBold" Foreground="#CCFF9A5C"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <TextBlock Text="🔥" FontSize="14" Margin="0,0,4,0"/>
                                    <TextBlock Text="{Binding Streak}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource StreakBrush}"/>
                                </StackPanel>
                            </Grid>
                            
                            <ItemsControl ItemsSource="{Binding StreakDays}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Rows="1" Columns="7"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel HorizontalAlignment="Center">
                                            <Border Width="24" Height="24" CornerRadius="12" Margin="0,0,0,4">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#22FFFFFF"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                <Setter Property="Background" Value="{StaticResource StreakBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                                <Setter Property="BorderThickness" Value="1"/>
                                                                <Setter Property="BorderBrush" Value="#FFFFFFFF"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="✓" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#AA000000">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                            <TextBlock Text="{Binding DayName}" FontSize="9" Foreground="#99FF9A5C" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Border>

                <!-- XP Log -->
                <Border Grid.Column="4" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="LETZTE BELOHNUNGEN" FontSize="10.5" FontWeight="SemiBold" Foreground="{StaticResource Text3Brush}" Margin="0,0,0,8"/>
                        
                        <ScrollViewer MaxHeight="80" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding XpLog}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding AmountText}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource SuccessBrush}" Width="40"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Description}" FontSize="11" Foreground="{StaticResource Text2Brush}" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Time}" FontSize="10" Foreground="{StaticResource Text3Brush}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ══════════ MID SECTION ══════════ -->
            <Grid Grid.Row="3" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- MODUL 2: TAGES-LERNPLAN -->
                <Border Grid.Column="0" Style="{StaticResource Card}">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <TextBlock Text="HEUTIGER LERNPLAN" FontSize="14" FontWeight="Medium" Foreground="{StaticResource TextBrush}"/>
                            <TextBlock Text="{Binding TaskSummary}" FontSize="11" Foreground="{StaticResource Text3Brush}" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                        </Grid>

                        <ItemsControl ItemsSource="{Binding TodayTasks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource Bg2Brush}" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <CheckBox Grid.Column="0" IsChecked="{Binding IsCompleted}" 
                                                      Command="{Binding DataContext.CompleteTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      CommandParameter="{Binding}"
                                                      VerticalAlignment="Center" Margin="0,0,12,0"/>
                                                      
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                                    <TextBlock Text="{Binding TypeIcon}" FontSize="12" Margin="0,0,6,0"/>
                                                    <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="Medium" Foreground="{StaticResource TextBrush}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                                        <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                                        <Setter Property="Foreground" Value="{StaticResource Text3Brush}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Description}" FontSize="11" Foreground="{StaticResource Text3Brush}" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                            
                                            <StackPanel Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                <Border Background="{StaticResource AccentSoftBrush}" CornerRadius="4" Padding="6,2" Margin="0,0,0,4" HorizontalAlignment="Right">
                                                    <TextBlock Text="{Binding PriorityTag}" FontSize="10" Foreground="{StaticResource AccentBrush}" FontWeight="Medium"/>
                                                </Border>
                                                <TextBlock Text="{Binding DurationText}" FontSize="11" Foreground="{StaticResource Text3Brush}" HorizontalAlignment="Right"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="2">
                    <!-- MODUL 3: SPACED REPETITION -->
                    <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <TextBlock Text="SPACED REPETITION" FontSize="10.5" FontWeight="SemiBold" Foreground="{StaticResource Text3Brush}"/>
                                <TextBlock Text="Graph →" FontSize="10" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Right" Cursor="Hand"/>
                            </Grid>
                            
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
                                <TextBlock Text="{Binding DueReviewCount}" FontFamily="Georgia" FontSize="36" Foreground="{StaticResource TextBrush}"/>
                                <TextBlock Text="Karten" FontSize="14" Foreground="{StaticResource Text2Brush}" VerticalAlignment="Bottom" Margin="6,0,0,6"/>
                            </StackPanel>
                            
                            <Button Style="{StaticResource PrimaryButton}" HorizontalAlignment="Stretch"
                                    Command="{Binding DataContext.NavigateToCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                    CommandParameter="QA">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔄 "/>
                                    <TextBlock Text="Jetzt Wiederholen"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                    
                    <!-- MODUL 5: KI-TUTOR SCHNELLZUGRIFF -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="KI-TUTOR" FontSize="10.5" FontWeight="SemiBold" Foreground="{StaticResource Text3Brush}" Margin="0,0,0,8"/>
                            
                            <Border Background="{StaticResource Bg2Brush}" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <TextBlock Text="💡 Vorschlag: Soll ich dir die Maxwell-Gleichungen für deine heutige Aufgabe zusammenfassen?" 
                                           FontSize="11" Foreground="{StaticResource Text2Brush}" TextWrapping="Wrap"/>
                            </Border>
                            
                            <Grid>
                                <TextBox Style="{StaticResource MfTextBox}" Padding="10,6,36,6" FontSize="12" 
                                         Tag="Frage etwas..."/>
                                <Button Style="{StaticResource IconButton}" HorizontalAlignment="Right" Margin="4">
                                    <TextBlock Text="➤" FontSize="10"/>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- ══════════ MODUL 4: FÄCHER & KURSÜBERSICHT ══════════ -->
            <Grid Grid.Row="4" Margin="0,0,0,12">
                <StackPanel>
                    <Grid Margin="0,0,0,16">
                        <TextBlock FontFamily="Georgia" FontSize="20" Foreground="{StaticResource TextBrush}">Deine Fächer</TextBlock>
                        <Button Style="{StaticResource GhostButton}" HorizontalAlignment="Right"
                                Command="{Binding DataContext.NavigateToCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                CommandParameter="Subjects">
                            <TextBlock Text="Alle anzeigen →" FontSize="12"/>
                        </Button>
                    </Grid>

                    <ItemsControl ItemsSource="{Binding Subjects}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource Card}" Width="300" Margin="0,0,12,12">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,12">
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="36" Height="36" CornerRadius="9" Margin="0,0,12,0" Background="{StaticResource AccentSoftBrush}">
                                                    <TextBlock Text="{Binding Icon}" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="Medium" Foreground="{StaticResource TextBrush}"/>
                                                    <TextBlock FontSize="11.5" Foreground="{StaticResource Text3Brush}">
                                                        <Run Text="{Binding QuestionCount}"/>
                                                        <Run Text=" Elemente"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </StackPanel>
                                            
                                            <!-- Quick Actions -->
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                                                <Button Style="{StaticResource IconButton}" Margin="0,0,4,0" ToolTip="Lernen">
                                                    <TextBlock Text="▶" FontSize="10"/>
                                                </Button>
                                                <Button Style="{StaticResource IconButton}" ToolTip="Upload">
                                                    <TextBlock Text="+" FontSize="14" Margin="0,-2,0,0"/>
                                                </Button>
                                            </StackPanel>
                                        </Grid>

                                        <ProgressBar Minimum="0" Maximum="1" Value="{Binding Progress, Mode=OneWay}" 
                                                     Style="{StaticResource MfProgressBar}" Height="3" Margin="0,0,0,8"/>
                                                     
                                        <TextBlock HorizontalAlignment="Right" FontSize="10" Foreground="{StaticResource Text3Brush}">
                                            <Run Text="Fortschritt: "/>
                                            <Run Text="{Binding ProgressPercent}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Grid>

        </Grid>
    </ScrollViewer>
</UserControl>
