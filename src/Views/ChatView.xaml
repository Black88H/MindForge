<UserControl x:Class="MindForge.Views.ChatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:MindForge.Models"
             Background="{StaticResource BgBrush}">
    <!-- DataContext injected via DI by ViewLocatorConverter -->

    <UserControl.Resources>

        <!-- ── Message bubble: User ──────────────────────────────── -->
        <DataTemplate x:Key="UserMessage" DataType="{x:Type models:ChatMessage}">
            <Grid Margin="0,6">
                <Border HorizontalAlignment="Right" MaxWidth="480"
                        Background="{StaticResource AccentBrush}"
                        CornerRadius="12,12,2,12" Padding="14,10">
                    <TextBlock Text="{Binding Content}"
                               Foreground="White" FontSize="13"
                               TextWrapping="Wrap"/>
                </Border>
            </Grid>
        </DataTemplate>

        <!-- ── Message bubble: AI ────────────────────────────────── -->
        <DataTemplate x:Key="AiMessage" DataType="{x:Type models:ChatMessage}">
            <Grid Margin="0,6">
                <Border HorizontalAlignment="Left" MaxWidth="480"
                        Background="{StaticResource Bg2Brush}"
                        BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
                        CornerRadius="12,12,12,2" Padding="14,10">
                    <TextBlock Text="{Binding Content}"
                               Foreground="{StaticResource TextBrush}" FontSize="13"
                               TextWrapping="Wrap"/>
                </Border>
            </Grid>
        </DataTemplate>

        <!-- ── Message template selector (role-based) ──────────────
             WPF doesn't allow direct DataTemplateSelector in DataTemplate
             so we use a Style + Trigger approach via ItemContainerStyle.
             The actual bubble template is chosen below in ItemsControl.ItemTemplate.  -->

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- header -->
            <RowDefinition Height="*"/>      <!-- messages -->
            <RowDefinition Height="Auto"/>   <!-- input bar -->
        </Grid.RowDefinitions>

        <!-- ── Header ──────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="{StaticResource Bg1Brush}"
                BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,0,1"
                Padding="24,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="KI-Tutor" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"/>
                    <TextBlock Text="Frage alles — ich erkläre, strukturiere, teste dich."
                               FontSize="12" Foreground="{StaticResource Text3Brush}" Margin="0,2,0,0"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding ClearChatCommand}"
                        Content="🗑 Chat leeren"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ── Messages ────────────────────────────────────────────── -->
        <ScrollViewer Grid.Row="1"
                      x:Name="MessagesScroll"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="24,16">
            <StackPanel>
                <!-- Empty state -->
                <StackPanel HorizontalAlignment="Center" Margin="0,60,0,0"
                            Visibility="{Binding Messages.Count, Converter={StaticResource IntToVisibility}, ConverterParameter=0}">
                    <TextBlock Text="🤖" FontSize="48" HorizontalAlignment="Center"/>
                    <TextBlock Text="Starte ein Gespräch"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"
                               HorizontalAlignment="Center" Margin="0,12,0,6"/>
                    <TextBlock Text="Ich erkläre Konzepte, beantworte Fragen und helfe beim Lernen."
                               FontSize="13" Foreground="{StaticResource Text3Brush}"
                               HorizontalAlignment="Center" TextWrapping="Wrap"
                               MaxWidth="320" TextAlignment="Center"/>
                </StackPanel>

                <!-- Message list -->
                <ItemsControl ItemsSource="{Binding Messages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:ChatMessage}">
                            <Grid Margin="0,4">
                                <!-- User message: right-aligned, accent color -->
                                <Border HorizontalAlignment="Right" MaxWidth="480"
                                        Background="{StaticResource AccentBrush}"
                                        CornerRadius="12,12,2,12" Padding="14,10">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Role}" Value="User">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Content}"
                                               Foreground="White" FontSize="13"
                                               TextWrapping="Wrap"/>
                                </Border>

                                <!-- AI message: left-aligned, card color -->
                                <Border HorizontalAlignment="Left" MaxWidth="480"
                                        Background="{StaticResource Bg2Brush}"
                                        BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
                                        CornerRadius="12,12,12,2" Padding="14,10">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Role}" Value="Assistant">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Content}"
                                               Foreground="{StaticResource TextBrush}" FontSize="13"
                                               TextWrapping="Wrap"/>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Typing indicator -->
                <StackPanel Orientation="Horizontal" Margin="0,8"
                            Visibility="{Binding IsTyping, Converter={StaticResource BoolToVisibility}}">
                    <Border Background="{StaticResource Bg2Brush}"
                            BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
                            CornerRadius="12,12,12,2" Padding="14,10">
                        <TextBlock Text="● ● ●" FontSize="12"
                                   Foreground="{StaticResource Text3Brush}"/>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- ── Input bar ────────────────────────────────────────────── -->
        <Border Grid.Row="2"
                Background="{StaticResource Bg1Brush}"
                BorderBrush="{StaticResource LineBrush}" BorderThickness="0,1,0,0"
                Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         x:Name="InputBox"
                         Style="{StaticResource MfTextBox}"
                         Height="40"
                         Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                         KeyDown="InputBox_KeyDown"
                         Margin="0,0,10,0"
                         ToolTip="Nachricht eingeben (Enter zum Senden)"/>

                <Button Grid.Column="1"
                        Style="{StaticResource PrimaryButton}"
                        Width="80" Height="40"
                        Command="{Binding SendCommand}"
                        Content="Senden"
                        IsDefault="True"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
