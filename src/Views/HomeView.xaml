<UserControl x:Class="MindForge.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MindForge.ViewModels"
             Background="{StaticResource BgBrush}">
    <!-- DataContext is injected via DI by ViewLocatorConverter -->

    <Grid>
        <!-- Center the onboarding card -->
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="560">

            <!-- Logo + Title -->
            <StackPanel HorizontalAlignment="Center" Margin="0,0,0,32">
                <Border Width="56" Height="56" CornerRadius="14" HorizontalAlignment="Center"
                        Background="{StaticResource AccentGradient}" Margin="0,0,0,16">
                    <TextBlock Text="M" Foreground="White" FontSize="28"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontFamily="Georgia" FontWeight="SemiBold"/>
                </Border>
                <TextBlock Text="Willkommen bei MindForge" FontFamily="Georgia" FontSize="28"
                           Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding StepLabel}" FontSize="12" Foreground="{StaticResource Text3Brush}"
                           HorizontalAlignment="Center" Margin="0,6,0,0" FontFamily="Consolas"/>
            </StackPanel>

            <!-- Progress bar -->
            <ProgressBar Minimum="0" Maximum="1" Value="{Binding StepProgress, Mode=OneWay}"
                         Style="{StaticResource SuccessProgressBar}" Height="4" Margin="0,0,0,28"/>

            <!-- Steps -->
            <Border Style="{StaticResource Card}" Padding="28,24">
                <StackPanel>
                    <!-- STEP 1: Language -->
                    <StackPanel Visibility="{Binding CurrentStep, Converter={StaticResource StepToVisibility}, ConverterParameter=1}">
                        <TextBlock Text="Sprache / Language" FontFamily="Georgia" FontSize="22"
                                   Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="Wähle deine bevorzugte Sprache" FontSize="13"
                                   Foreground="{StaticResource Text3Brush}" Margin="0,0,0,24"/>
                        <UniformGrid Rows="1" Columns="2" Margin="0,0,0,8">
                            <Button Style="{StaticResource PrimaryButton}" Margin="0,0,6,0" Height="48"
                                    Command="{Binding SelectLanguageCommand}" CommandParameter="Deutsch">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🇩🇪  " FontSize="18"/>
                                    <TextBlock Text="Deutsch" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SecondaryButton}" Margin="6,0,0,0" Height="48"
                                    Command="{Binding SelectLanguageCommand}" CommandParameter="English">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🇬🇧  " FontSize="18"/>
                                    <TextBlock Text="English" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </UniformGrid>
                    </StackPanel>

                    <!-- STEP 2: Account -->
                    <StackPanel Visibility="{Binding CurrentStep, Converter={StaticResource StepToVisibility}, ConverterParameter=2}">
                        <TextBlock Text="Konto einrichten" FontFamily="Georgia" FontSize="22"
                                   Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="Erstelle dein lokales MindForge-Konto" FontSize="13"
                                   Foreground="{StaticResource Text3Brush}" Margin="0,0,0,24"/>
                        <TextBlock Text="BENUTZERNAME" Style="{StaticResource SectionLabel}" Margin="0,0,0,6"/>
                        <Border Background="{StaticResource Bg2Brush}" BorderBrush="{StaticResource LineBrush}"
                                BorderThickness="1" CornerRadius="7" Padding="12,10" Margin="0,0,0,12">
                            <TextBox Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="{StaticResource TextBrush}" FontSize="13.5"
                                     CaretBrush="{StaticResource AccentBrush}"/>
                        </Border>
                        <TextBlock Text="E-MAIL (Optional)" Style="{StaticResource SectionLabel}" Margin="0,0,0,6"/>
                        <Border Background="{StaticResource Bg2Brush}" BorderBrush="{StaticResource LineBrush}"
                                BorderThickness="1" CornerRadius="7" Padding="12,10">
                            <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="{StaticResource TextBrush}" FontSize="13.5"
                                     CaretBrush="{StaticResource AccentBrush}"/>
                        </Border>
                        <TextBlock Text="{Binding AccountError}" Foreground="{StaticResource DangerBrush}"
                                   FontSize="12" Margin="0,8,0,0"
                                   Visibility="{Binding AccountError, Converter={StaticResource StringToVisibility}}"/>
                    </StackPanel>

                    <!-- STEP 3: Learning Style -->
                    <StackPanel Visibility="{Binding CurrentStep, Converter={StaticResource StepToVisibility}, ConverterParameter=3}">
                        <TextBlock Text="Wie lernst du am besten?" FontFamily="Georgia" FontSize="22"
                                   Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="MindForge passt sich deinem Lernstil an"
                                   FontSize="13" Foreground="{StaticResource Text3Brush}" Margin="0,0,0,20"/>
                        <UniformGrid Columns="2">
                            <Border Style="{StaticResource Card}" Margin="0,0,4,8" Cursor="Hand" Padding="14,12">
                                <StackPanel Orientation="Horizontal">
                                    <CheckBox IsChecked="{Binding PreferShortExplanations}"
                                              VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Text="Kurze Erklärungen" FontSize="13"
                                               Foreground="{StaticResource Text2Brush}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Card}" Margin="4,0,0,8" Cursor="Hand" Padding="14,12">
                                <StackPanel Orientation="Horizontal">
                                    <CheckBox IsChecked="{Binding PreferLongExplanations}"
                                              VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Text="Ausführliche Erklärungen" FontSize="13"
                                               Foreground="{StaticResource Text2Brush}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Card}" Margin="0,0,4,8" Cursor="Hand" Padding="14,12">
                                <StackPanel Orientation="Horizontal">
                                    <CheckBox IsChecked="{Binding PreferManyExamples}"
                                              VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Text="Viele Beispiele" FontSize="13"
                                               Foreground="{StaticResource Text2Brush}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Card}" Margin="4,0,0,8" Cursor="Hand" Padding="14,12">
                                <StackPanel Orientation="Horizontal">
                                    <CheckBox IsChecked="{Binding PreferExercises}"
                                              VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Text="Übungsaufgaben" FontSize="13"
                                               Foreground="{StaticResource Text2Brush}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Card}" Margin="0,0,4,0" Cursor="Hand" Padding="14,12">
                                <StackPanel Orientation="Horizontal">
                                    <CheckBox IsChecked="{Binding PreferFormulas}"
                                              VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Text="Formeln &amp; Herleitungen" FontSize="13"
                                               Foreground="{StaticResource Text2Brush}"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </StackPanel>

                    <!-- STEP 4: Subjects -->
                    <StackPanel Visibility="{Binding CurrentStep, Converter={StaticResource StepToVisibility}, ConverterParameter=4}">
                        <TextBlock Text="Fächer auswählen" FontFamily="Georgia" FontSize="22"
                                   Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="Wähle 1–5 Fächer für den Start" FontSize="13"
                                   Foreground="{StaticResource Text3Brush}" Margin="0,0,0,20"/>
                        <ItemsControl ItemsSource="{Binding SuggestedSubjects}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Margin="0,0,8,8" Height="36" Padding="12,0"
                                            Command="{Binding DataContext.ToggleSubjectCommand,
                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Icon}" FontSize="14" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding Name}" FontSize="13"/>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- STEP 5: Confirm -->
                    <StackPanel Visibility="{Binding CurrentStep, Converter={StaticResource StepToVisibility}, ConverterParameter=5}"
                                HorizontalAlignment="Center">
                        <TextBlock Text="🎉" FontSize="56" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                        <TextBlock Text="Alles bereit!" FontFamily="Georgia" FontSize="28"
                                   Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock HorizontalAlignment="Center" FontSize="14"
                                   Foreground="{StaticResource Text2Brush}">
                            <Run Text="Willkommen, "/>
                            <Run Text="{Binding UserName}" Foreground="{StaticResource AccentBrush}"/>
                            <Run Text="! Dein MindForge ist bereit."/>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Navigation Buttons -->
            <Grid Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Style="{StaticResource SecondaryButton}" Height="40" Padding="20,0"
                        Command="{Binding PrevStepCommand}"
                        Visibility="{Binding CurrentStep, Converter={StaticResource StepToVisibility}, ConverterParameter=1+}">
                    <TextBlock Text="← Zurück"/>
                </Button>

                <Button Grid.Column="2" Style="{StaticResource PrimaryButton}" Height="40" Padding="24,0"
                        Command="{Binding NextStepCommand}">
                    <TextBlock Text="{Binding CurrentStep, Converter={StaticResource StepToNextLabel}}"/>
                </Button>
            </Grid>
        </StackPanel>
    </Grid>
</UserControl>
