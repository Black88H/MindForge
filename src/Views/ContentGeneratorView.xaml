<UserControl x:Class="MindForge.Views.ContentGeneratorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MindForge.ViewModels"
             Background="{StaticResource BgBrush}">

    <UserControl.DataContext>
        <vm:ContentGeneratorViewModel/>
    </UserControl.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid MaxWidth="900" Margin="40,32,40,40" HorizontalAlignment="Left">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <StackPanel Grid.Row="0" Margin="0,0,0,24">
                <TextBlock FontFamily="Georgia" FontSize="26" Foreground="{StaticResource TextBrush}">
                    KI Content Generator
                </TextBlock>
                <TextBlock Text="PDF hochladen · automatisch Karten, MCQs oder Zusammenfassungen erzeugen"
                           FontSize="13" Foreground="{StaticResource Text3Brush}" Margin="0,6,0,0"/>
            </StackPanel>

            <!-- Upload Zone -->
            <Border Grid.Row="1" Margin="0,0,0,20" MinHeight="160"
                    Background="{StaticResource Bg1Brush}"
                    CornerRadius="12" Cursor="Hand"
                    AllowDrop="True">
                <Border.BorderBrush>
                    <SolidColorBrush Color="{StaticResource LineSoftColor}"/>
                </Border.BorderBrush>
                <Border.BorderThickness>1</Border.BorderThickness>
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasFile}" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Background" Value="{StaticResource AccentSoftBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,30">
                    <!-- No file state -->
                    <StackPanel Visibility="{Binding HasFile, Converter={StaticResource BoolToVisibility}, ConverterParameter=invert}">
                        <TextBlock Text="📄" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <TextBlock Text="PDF hier ablegen oder klicken zum Hochladen"
                                   FontSize="14" Foreground="{StaticResource Text2Brush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,6"/>
                        <TextBlock Text="Unterstützt: PDF, bis zu 50 MB"
                                   FontSize="12" Foreground="{StaticResource Text3Brush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,16"/>
                        <Button Style="{StaticResource PrimaryButton}" HorizontalAlignment="Center"
                                Padding="24,0" Command="{Binding UploadFileCommand}">
                            <TextBlock Text="Datei auswählen"/>
                        </Button>
                    </StackPanel>

                    <!-- File loaded state -->
                    <StackPanel Visibility="{Binding HasFile, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="✓" FontSize="36" HorizontalAlignment="Center"
                                   Foreground="{StaticResource SuccessBrush}" Margin="0,0,0,10"/>
                        <TextBlock Text="{Binding UploadedFileName}" FontSize="14" FontWeight="Medium"
                                   Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Datei geladen" FontSize="12"
                                   Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Center"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Processing Bar -->
            <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,0,0,20"
                    Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="{Binding ProcessingStatus}"
                                   FontSize="13" Foreground="{StaticResource TextBrush}"/>
                        <TextBlock HorizontalAlignment="Right" FontSize="12"
                                   Foreground="{StaticResource Text3Brush}" FontFamily="Consolas">
                            <Run Text="{Binding ProcessingProgress, StringFormat=P0}"/>
                        </TextBlock>
                    </Grid>
                    <ProgressBar Value="{Binding ProcessingProgress}" Maximum="1"
                                 Style="{StaticResource SuccessProgressBar}" Height="6"/>
                </StackPanel>
            </Border>

            <!-- Tabs + Settings -->
            <Border Grid.Row="3" Style="{StaticResource Card}" Margin="0,0,0,20"
                    Visibility="{Binding HasFile, Converter={StaticResource BoolToVisibility}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="240"/>
                    </Grid.ColumnDefinitions>

                    <!-- Tab buttons -->
                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Button Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"
                                    Command="{Binding ProcessFileCommand}">
                                <TextBlock Text="Fragen generieren"/>
                            </Button>
                            <Button Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"
                                    Command="{Binding ProcessFileCommand}">
                                <TextBlock Text="Zusammenfassung"/>
                            </Button>
                            <Button Style="{StaticResource SecondaryButton}"
                                    Command="{Binding ProcessFileCommand}">
                                <TextBlock Text="Custom Prompt"/>
                            </Button>
                        </StackPanel>

                        <!-- Preview -->
                        <Border Background="{StaticResource Bg2Brush}" CornerRadius="8" Padding="16"
                                MinHeight="200">
                            <TextBlock Text="{Binding PreviewContent}"
                                       FontFamily="Consolas" FontSize="12"
                                       Foreground="{StaticResource Text2Brush}"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>

                    <!-- Settings Panel -->
                    <StackPanel Grid.Column="1" Margin="20,0,0,0">
                        <TextBlock Text="EINSTELLUNGEN" Style="{StaticResource SectionLabel}" Margin="0,0,0,12"/>

                        <TextBlock Text="Anzahl Fragen" FontSize="12" Foreground="{StaticResource Text2Brush}" Margin="0,0,0,4"/>
                        <Slider Value="{Binding QuestionCount}" Minimum="5" Maximum="50"
                                Style="{StaticResource MfSlider}" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding QuestionCount}" FontSize="12"
                                   Foreground="{StaticResource Text3Brush}" HorizontalAlignment="Right"
                                   Margin="0,0,0,14"/>

                        <TextBlock Text="Schwierigkeitsgrad" FontSize="12" Foreground="{StaticResource Text2Brush}" Margin="0,0,0,6"/>
                        <ComboBox SelectedItem="{Binding Difficulty}" Style="{StaticResource MfComboBox}"
                                  Margin="0,0,0,14">
                            <ComboBoxItem>Leicht</ComboBoxItem>
                            <ComboBoxItem>Mittel</ComboBoxItem>
                            <ComboBoxItem>Schwer</ComboBoxItem>
                            <ComboBoxItem>Gemischt</ComboBoxItem>
                        </ComboBox>

                        <TextBlock Text="Ausgabeformat" FontSize="12" Foreground="{StaticResource Text2Brush}" Margin="0,0,0,8"/>
                        <StackPanel>
                            <RadioButton Content="Markdown" IsChecked="True" Foreground="{StaticResource Text2Brush}"
                                         FontSize="12" Margin="0,0,0,4"/>
                            <RadioButton Content="PDF" Foreground="{StaticResource Text2Brush}"
                                         FontSize="12" Margin="0,0,0,4"/>
                            <RadioButton Content="JSON" Foreground="{StaticResource Text2Brush}"
                                         FontSize="12" Margin="0,0,0,14"/>
                        </StackPanel>

                        <Button Style="{StaticResource PrimaryButton}" HorizontalAlignment="Stretch"
                                Margin="0,0,0,8" Command="{Binding DownloadOutputCommand}">
                            <TextBlock Text="⬇ Download"/>
                        </Button>
                        <Button Style="{StaticResource SecondaryButton}" HorizontalAlignment="Stretch">
                            <TextBlock Text="💾 Speichern &amp; Zurück"/>
                        </Button>

                        <!-- XP Popup -->
                        <Border Margin="0,12,0,0" Background="{StaticResource SuccessSoftBrush}"
                                BorderBrush="{StaticResource SuccessBrush}" BorderThickness="1"
                                CornerRadius="8" Padding="12,8"
                                Visibility="{Binding ShowXpPopup, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock HorizontalAlignment="Center" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource SuccessBrush}">
                                <Run Text="✨ +"/>
                                <Run Text="{Binding XpEarned}"/>
                                <Run Text=" XP verdient!"/>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
