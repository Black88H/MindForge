<UserControl x:Class="MindForge.Views.ProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MindForge.ViewModels"
             Background="{StaticResource BgBrush}">

    <UserControl.DataContext>
        <vm:ProfileViewModel/>
    </UserControl.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid MaxWidth="900" Margin="40,32,40,40" HorizontalAlignment="Left">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Profile Card -->
            <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Avatar -->
                    <Border Grid.Column="0" Width="80" Height="80" CornerRadius="40"
                            Background="{StaticResource AccentGradient}" Margin="0,0,24,0">
                        <TextBlock Text="{Binding AvatarLetter}" FontSize="32" FontFamily="Georgia"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <!-- Info -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <!-- View mode -->
                        <StackPanel Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}, ConverterParameter=invert}">
                            <TextBlock Text="{Binding UserName}" FontFamily="Georgia" FontSize="26"
                                       Foreground="{StaticResource TextBrush}"/>
                            <TextBlock Text="{Binding Email}" FontSize="13"
                                       Foreground="{StaticResource Text3Brush}" Margin="0,4,0,0"/>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Border Background="{StaticResource AccentSoftBrush}" CornerRadius="12" Padding="10,4" Margin="0,0,8,0">
                                    <TextBlock FontSize="12" Foreground="{StaticResource AccentBrush}">
                                        <Run Text="Level "/>
                                        <Run Text="{Binding Level}" FontWeight="SemiBold"/>
                                    </TextBlock>
                                </Border>
                                <Border Background="{StaticResource SuccessSoftBrush}" CornerRadius="12" Padding="10,4">
                                    <TextBlock FontSize="12" Foreground="{StaticResource SuccessBrush}">
                                        <Run Text="🔥 "/>
                                        <Run Text="{Binding Streak}" FontWeight="SemiBold"/>
                                        <Run Text=" Tage"/>
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <!-- Edit mode -->
                        <StackPanel Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="BENUTZERNAME" Style="{StaticResource SectionLabel}" Margin="0,0,0,6"/>
                            <Border Background="{StaticResource Bg2Brush}" BorderBrush="{StaticResource LineBrush}"
                                    BorderThickness="1" CornerRadius="7" Padding="12,10" Margin="0,0,0,10" MaxWidth="300">
                                <TextBox Text="{Binding EditUserName, UpdateSourceTrigger=PropertyChanged}"
                                         Background="Transparent" BorderThickness="0"
                                         Foreground="{StaticResource TextBrush}" FontSize="13"
                                         CaretBrush="{StaticResource AccentBrush}"/>
                            </Border>
                            <TextBlock Text="E-MAIL" Style="{StaticResource SectionLabel}" Margin="0,0,0,6"/>
                            <Border Background="{StaticResource Bg2Brush}" BorderBrush="{StaticResource LineBrush}"
                                    BorderThickness="1" CornerRadius="7" Padding="12,10" MaxWidth="300">
                                <TextBox Text="{Binding EditEmail, UpdateSourceTrigger=PropertyChanged}"
                                         Background="Transparent" BorderThickness="0"
                                         Foreground="{StaticResource TextBrush}" FontSize="13"
                                         CaretBrush="{StaticResource AccentBrush}"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <!-- Edit / Save Button -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Top">
                        <Button Style="{StaticResource SecondaryButton}" Padding="16,8"
                                Command="{Binding EditCommand}"
                                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}, ConverterParameter=invert}">
                            <TextBlock Text="Bearbeiten" FontSize="13"/>
                        </Button>
                        <StackPanel Orientation="Horizontal"
                                    Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}">
                            <Button Style="{StaticResource SecondaryButton}" Padding="14,8" Margin="0,0,8,0"
                                    Command="{Binding CancelEditCommand}">
                                <TextBlock Text="Abbrechen" FontSize="13"/>
                            </Button>
                            <Button Style="{StaticResource PrimaryButton}" Padding="14,8"
                                    Command="{Binding SaveCommand}">
                                <TextBlock Text="Speichern" FontSize="13"/>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- XP Progress -->
            <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,20" Padding="20,16">
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" FontSize="13" Foreground="{StaticResource Text2Brush}">
                            <Run Text="Level "/>
                            <Run Text="{Binding Level}" FontWeight="Bold"/>
                            <Run Text=" → Level "/>
                            <Run Text="{Binding NextLevel}"/>
                        </TextBlock>
                        <TextBlock Grid.Column="1" Text="{Binding XPText}" FontSize="12"
                                   Foreground="{StaticResource Text3Brush}"/>
                    </Grid>
                    <ProgressBar Value="{Binding XPProgress}" Minimum="0" Maximum="1"
                                 Style="{StaticResource SuccessProgressBar}" Height="6"/>
                </StackPanel>
            </Border>

            <!-- Stats Grid -->
            <UniformGrid Grid.Row="2" Columns="4" Margin="0,0,0,20">
                <Border Style="{StaticResource Card}" Margin="0,0,10,0" Padding="16,14">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{Binding TotalXP}" FontSize="24" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Gesamt XP" FontSize="11" Foreground="{StaticResource Text3Brush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Margin="0,0,10,0" Padding="16,14">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{Binding Streak}" FontSize="24" FontWeight="Bold"
                                   Foreground="{StaticResource StreakBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Tage Streak" FontSize="11" Foreground="{StaticResource Text3Brush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Margin="0,0,10,0" Padding="16,14">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{Binding TotalQuestions}" FontSize="24" FontWeight="Bold"
                                   Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Beantwortet" FontSize="11" Foreground="{StaticResource Text3Brush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Padding="16,14">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{Binding AchievementsUnlocked}" FontSize="24" FontWeight="Bold"
                                   Foreground="{StaticResource WarnBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Errungenschaften" FontSize="11" Foreground="{StaticResource Text3Brush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Achievements + Best Subjects -->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="280"/>
                </Grid.ColumnDefinitions>

                <!-- Recent Achievements -->
                <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,16,0">
                    <StackPanel>
                        <TextBlock Text="Errungenschaften" FontFamily="Georgia" FontSize="18"
                                   Foreground="{StaticResource TextBrush}" Margin="0,0,0,16"/>
                        <ItemsControl ItemsSource="{Binding Achievements}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,10,10">
                                        <Border.ToolTip>
                                            <ToolTip>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding Description}" FontSize="11"/>
                                                </StackPanel>
                                            </ToolTip>
                                        </Border.ToolTip>
                                        <Border Width="56" Height="56" CornerRadius="12">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{StaticResource Bg2Brush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsUnlocked}" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource AccentSoftBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Icon}" FontSize="24"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Opacity" Value="0.35"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsUnlocked}" Value="True">
                                                                <Setter Property="Opacity" Value="1"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Best Subjects -->
                <Border Grid.Column="1" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Beste Fächer" FontFamily="Georgia" FontSize="18"
                                   Foreground="{StaticResource TextBrush}" Margin="0,0,0,16"/>
                        <ItemsControl ItemsSource="{Binding BestSubjects}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource Bg2Brush}" CornerRadius="8"
                                            Padding="12,10" Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="32" Height="32" CornerRadius="8"
                                                    Margin="0,0,10,0">
                                                <Border.Background>
                                                    <SolidColorBrush Color="{Binding Color}"/>
                                                </Border.Background>
                                                <TextBlock Text="{Binding Icon}" FontSize="14"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Foreground="White"/>
                                            </Border>
                                            <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="13"
                                                       Foreground="{StaticResource Text2Brush}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="{Binding SuccessRatePercent}" FontSize="13"
                                                       Foreground="{StaticResource SuccessBrush}" FontWeight="SemiBold"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
