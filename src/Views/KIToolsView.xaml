<UserControl x:Class="MindForge.Views.KIToolsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MindForge.ViewModels"
             Background="{StaticResource BgBrush}">
    <!-- DataContext is injected via DI by ViewLocatorConverter -->

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid MaxWidth="1100" Margin="40,32,40,40" HorizontalAlignment="Left">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,24">
                <TextBlock Text="KI-Werkzeuge" FontFamily="Georgia" FontSize="26"
                           Foreground="{StaticResource TextBrush}" Margin="0,0,0,6"/>
                <TextBlock Text="Generiere Lernmaterial mit Künstlicher Intelligenz"
                           FontSize="13" Foreground="{StaticResource Text3Brush}"/>
            </StackPanel>

            <!-- Upload + Config Row -->
            <Grid Grid.Row="1" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="280"/>
                </Grid.ColumnDefinitions>

                <!-- Upload Zone -->
                <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,16,0">
                    <StackPanel>
                        <TextBlock Text="Material hochladen" FontFamily="Georgia" FontSize="18"
                                   Foreground="{StaticResource TextBrush}" Margin="0,0,0,16"/>
                        <Border Background="{StaticResource Bg2Brush}" BorderBrush="{StaticResource LineBrush}"
                                BorderThickness="2" CornerRadius="10" Padding="40,28" Margin="0,0,0,16"
                                AllowDrop="True">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="📁" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                                <TextBlock Text="Datei hier ablegen" FontSize="14"
                                           Foreground="{StaticResource Text2Brush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="PDF, Bild, TXT, DOCX" FontSize="11"
                                           Foreground="{StaticResource Text3Brush}" HorizontalAlignment="Center" Margin="0,4,0,12"/>
                                <Button Style="{StaticResource SecondaryButton}" HorizontalAlignment="Center"
                                        Command="{Binding UploadFileCommand}" Padding="20,8">
                                    <TextBlock Text="Datei auswählen" FontSize="13"/>
                                </Button>
                            </StackPanel>
                        </Border>
                        <TextBlock Text="{Binding FileName}" Foreground="{StaticResource AccentBrush}"
                                   FontSize="12" HorizontalAlignment="Center"
                                   Visibility="{Binding FileName, Converter={StaticResource StringToVisibility}}"/>

                        <!-- Text Input -->
                        <TextBlock Text="ODER TEXT EINGEBEN" Style="{StaticResource SectionLabel}" Margin="0,16,0,8"/>
                        <Border Background="{StaticResource Bg2Brush}" BorderBrush="{StaticResource LineBrush}"
                                BorderThickness="1" CornerRadius="7" Padding="12,10">
                            <TextBox Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent" BorderThickness="0" AcceptsReturn="True"
                                     Height="120" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                     Foreground="{StaticResource TextBrush}" FontSize="13"
                                     CaretBrush="{StaticResource AccentBrush}"
                                     VerticalContentAlignment="Top"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Config Panel -->
                <StackPanel Grid.Column="1">
                    <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Einstellungen" FontFamily="Georgia" FontSize="16"
                                       Foreground="{StaticResource TextBrush}" Margin="0,0,0,16"/>
                            <TextBlock Text="AUSGABEFORMAT" Style="{StaticResource SectionLabel}" Margin="0,0,0,8"/>
                            <RadioButton Content="Karteikarten" IsChecked="{Binding IsFlashcardMode}"
                                         Foreground="{StaticResource Text2Brush}" Margin="0,0,0,6"/>
                            <RadioButton Content="Multiple Choice" IsChecked="{Binding IsMcMode}"
                                         Foreground="{StaticResource Text2Brush}" Margin="0,0,0,6"/>
                            <RadioButton Content="Offen" IsChecked="{Binding IsOpenMode}"
                                         Foreground="{StaticResource Text2Brush}" Margin="0,0,0,16"/>
                            <TextBlock Text="ANZAHL FRAGEN" Style="{StaticResource SectionLabel}" Margin="0,0,0,8"/>
                            <Border Background="{StaticResource Bg2Brush}" BorderBrush="{StaticResource LineBrush}"
                                    BorderThickness="1" CornerRadius="7" Padding="12,10" Margin="0,0,0,16">
                                <TextBox Text="{Binding GenerateCount, UpdateSourceTrigger=PropertyChanged}"
                                         Background="Transparent" BorderThickness="0"
                                         Foreground="{StaticResource TextBrush}" FontSize="13"
                                         CaretBrush="{StaticResource AccentBrush}"/>
                            </Border>
                            <TextBlock Text="FACH (Optional)" Style="{StaticResource SectionLabel}" Margin="0,0,0,8"/>
                            <Border Background="{StaticResource Bg2Brush}" BorderBrush="{StaticResource LineBrush}"
                                    BorderThickness="1" CornerRadius="7" Padding="12,10">
                                <TextBox Text="{Binding SubjectHint, UpdateSourceTrigger=PropertyChanged}"
                                         Background="Transparent" BorderThickness="0"
                                         Foreground="{StaticResource TextBrush}" FontSize="13"
                                         CaretBrush="{StaticResource AccentBrush}"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Generate Button -->
                    <Button Style="{StaticResource PrimaryButton}" Height="48"
                            Command="{Binding GenerateCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✨  " FontSize="14"/>
                            <TextBlock Text="Generieren" FontSize="14"/>
                        </StackPanel>
                    </Button>

                    <!-- Progress -->
                    <StackPanel Margin="0,12,0,0"
                                Visibility="{Binding IsGenerating, Converter={StaticResource BoolToVisibility}}">
                        <ProgressBar Value="{Binding GenerateProgress, Mode=OneWay}" Minimum="0" Maximum="1"
                                     Style="{StaticResource SuccessProgressBar}" Height="4" Margin="0,0,0,6"/>
                        <TextBlock Text="{Binding StatusText}" FontSize="11" Foreground="{StaticResource Text3Brush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- Output Tabs -->
            <Border Grid.Row="2" Style="{StaticResource Card}"
                    Visibility="{Binding HasOutput, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <!-- Tab Bar -->
                    <Border Background="{StaticResource Bg2Brush}" CornerRadius="8" Padding="4" Margin="0,0,0,20">
                        <UniformGrid Rows="1" Columns="3">
                            <Button Height="34" Command="{Binding SelectOutputTabCommand}" CommandParameter="0">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding OutputTab}" Value="0">
                                                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <TextBlock Text="Fragen" FontSize="12"/>
                            </Button>
                            <Button Height="34" Command="{Binding SelectOutputTabCommand}" CommandParameter="1">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding OutputTab}" Value="1">
                                                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <TextBlock Text="Zusammenfassung" FontSize="12"/>
                            </Button>
                            <Button Height="34" Command="{Binding SelectOutputTabCommand}" CommandParameter="2">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding OutputTab}" Value="2">
                                                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <TextBlock Text="Custom" FontSize="12"/>
                            </Button>
                        </UniformGrid>
                    </Border>

                    <!-- Questions Tab -->
                    <StackPanel Visibility="{Binding OutputTab, Converter={StaticResource IntToVisibility}, ConverterParameter=0}">
                        <ItemsControl ItemsSource="{Binding GeneratedQuestions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource Bg2Brush}" CornerRadius="8"
                                            Padding="16,12" Margin="0,0,0,8">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Question}" FontSize="13"
                                                       Foreground="{StaticResource TextBrush}" TextWrapping="Wrap"
                                                       Margin="0,0,0,6"/>
                                            <TextBlock Foreground="{StaticResource SuccessBrush}" FontSize="12">
                                                <Run Text="✓ "/>
                                                <Run Text="{Binding Answer}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                            <Button Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Padding="16,8"
                                    Command="{Binding ExportCommand}">
                                <TextBlock Text="Exportieren" FontSize="13"/>
                            </Button>
                            <Button Style="{StaticResource PrimaryButton}" Padding="16,8"
                                    Command="{Binding SaveToLibraryCommand}">
                                <TextBlock Text="In Bibliothek speichern" FontSize="13"/>
                            </Button>
                        </StackPanel>
                    </StackPanel>

                    <!-- Summary Tab -->
                    <StackPanel Visibility="{Binding OutputTab, Converter={StaticResource IntToVisibility}, ConverterParameter=1}">
                        <Border Background="{StaticResource Bg2Brush}" CornerRadius="8" Padding="16">
                            <TextBlock Text="{Binding SummaryText}" FontSize="13"
                                       Foreground="{StaticResource Text2Brush}" TextWrapping="Wrap" LineHeight="22"/>
                        </Border>
                    </StackPanel>

                    <!-- Custom Tab -->
                    <StackPanel Visibility="{Binding OutputTab, Converter={StaticResource IntToVisibility}, ConverterParameter=2}">
                        <TextBlock Text="EIGENE ANFRAGE" Style="{StaticResource SectionLabel}" Margin="0,0,0,8"/>
                        <Border Background="{StaticResource Bg2Brush}" BorderBrush="{StaticResource LineBrush}"
                                BorderThickness="1" CornerRadius="7" Padding="12,10" Margin="0,0,0,12">
                            <TextBox Text="{Binding CustomPrompt, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent" BorderThickness="0" AcceptsReturn="True"
                                     Height="80" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                     Foreground="{StaticResource TextBrush}" FontSize="13"
                                     CaretBrush="{StaticResource AccentBrush}"
                                     VerticalContentAlignment="Top"/>
                        </Border>
                        <Button Style="{StaticResource PrimaryButton}" Height="40" HorizontalAlignment="Left"
                                Padding="20,0" Command="{Binding RunCustomCommand}">
                            <TextBlock Text="Ausführen" FontSize="13"/>
                        </Button>
                        <Border Background="{StaticResource Bg2Brush}" CornerRadius="8" Padding="16" Margin="0,12,0,0"
                                Visibility="{Binding CustomOutput, Converter={StaticResource StringToVisibility}}">
                            <TextBlock Text="{Binding CustomOutput}" FontSize="13"
                                       Foreground="{StaticResource Text2Brush}" TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
