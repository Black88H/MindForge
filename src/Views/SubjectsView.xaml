<UserControl x:Class="MindForge.Views.SubjectsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MindForge.ViewModels"
             Background="{StaticResource BgBrush}">

    <UserControl.DataContext>
        <vm:SubjectsViewModel/>
    </UserControl.DataContext>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid MaxWidth="1100" Margin="40,32,40,40" HorizontalAlignment="Left">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Fächer" FontFamily="Georgia" FontSize="26"
                                   Foreground="{StaticResource TextBrush}" Margin="0,0,0,6"/>
                        <TextBlock Text="Verwalte deine Lernfächer"
                                   FontSize="13" Foreground="{StaticResource Text3Brush}"/>
                    </StackPanel>
                    <Button Grid.Column="1" Style="{StaticResource PrimaryButton}" Height="40" Padding="20,0"
                            Command="{Binding AddSubjectCommand}" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="+" FontSize="18" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Fach hinzufügen" FontSize="13"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Subject Grid -->
                <ItemsControl Grid.Row="1" ItemsSource="{Binding Subjects}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="3"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource Card}" Margin="0,0,12,12" Padding="20,18">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Icon + Name + Actions -->
                                    <Grid Grid.Row="0" Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="40" Height="40" CornerRadius="10" Margin="0,0,12,0">
                                            <Border.Background>
                                                <SolidColorBrush Color="{Binding Color}"/>
                                            </Border.Background>
                                            <TextBlock Text="{Binding Icon}" FontSize="18"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Foreground="White"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontSize="15"
                                                       Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Difficulty}" FontSize="11"
                                                       Foreground="{StaticResource Text3Brush}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                                            <Button Style="{StaticResource SecondaryButton}" Width="30" Height="30" Padding="0"
                                                    Command="{Binding DataContext.EditSubjectCommand,
                                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}" Margin="0,0,4,0">
                                                <TextBlock Text="✏" FontSize="13"/>
                                            </Button>
                                            <Button Style="{StaticResource SecondaryButton}" Width="30" Height="30" Padding="0"
                                                    Command="{Binding DataContext.DeleteSubjectCommand,
                                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <TextBlock Text="🗑" FontSize="13"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Progress -->
                                    <Grid Grid.Row="1" Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Fortschritt" FontSize="11"
                                                   Foreground="{StaticResource Text3Brush}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding ProgressPercent}" FontSize="11"
                                                   Foreground="{StaticResource Text3Brush}"/>
                                    </Grid>
                                    <ProgressBar Grid.Row="2" Value="{Binding Progress}" Minimum="0" Maximum="1"
                                                 Style="{StaticResource SuccessProgressBar}" Height="4" Margin="0,0,0,12"/>

                                    <!-- Stats Row -->
                                    <UniformGrid Grid.Row="3" Columns="3">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding QuestionCount}" FontSize="15"
                                                       Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="Fragen" FontSize="10" Foreground="{StaticResource Text3Brush}"
                                                       HorizontalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding SuccessRatePercent}" FontSize="15"
                                                       Foreground="{StaticResource SuccessBrush}" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="Erfolg" FontSize="10" Foreground="{StaticResource Text3Brush}"
                                                       HorizontalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding LastStudied}" FontSize="11"
                                                       Foreground="{StaticResource Text3Brush}"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="zuletzt" FontSize="10" Foreground="{StaticResource Text3Brush}"
                                                       HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </UniformGrid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Empty State -->
                <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,12,0,0"
                        Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel HorizontalAlignment="Center" Margin="0,40,0,40">
                        <TextBlock Text="📚" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                        <TextBlock Text="Noch keine Fächer" FontFamily="Georgia" FontSize="20"
                                   Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="Füge dein erstes Fach hinzu, um anzufangen."
                                   FontSize="13" Foreground="{StaticResource Text3Brush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>

        <!-- ADD/EDIT DIALOG OVERLAY -->
        <Border Background="#90000000" Visibility="{Binding IsDialogOpen, Converter={StaticResource BoolToVisibility}}">
            <Border Width="460" Background="{StaticResource Bg2Brush}" CornerRadius="14"
                    VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="32" ShadowDepth="0" Color="#000000" Opacity="0.5"/>
                </Border.Effect>
                <StackPanel Margin="28,24">
                    <TextBlock Text="{Binding DialogTitle}" FontFamily="Georgia" FontSize="20"
                               Foreground="{StaticResource TextBrush}" Margin="0,0,0,20"/>

                    <TextBlock Text="NAME" Style="{StaticResource SectionLabel}" Margin="0,0,0,6"/>
                    <Border Background="{StaticResource BgBrush}" BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="1" CornerRadius="7" Padding="12,10" Margin="0,0,0,14">
                        <TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="{StaticResource TextBrush}" FontSize="13"
                                 CaretBrush="{StaticResource AccentBrush}"/>
                    </Border>

                    <TextBlock Text="ICON" Style="{StaticResource SectionLabel}" Margin="0,0,0,8"/>
                    <ItemsControl ItemsSource="{Binding AvailableIcons}" Margin="0,0,0,14">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Width="36" Height="36" Margin="0,0,6,6" Padding="0"
                                        Command="{Binding DataContext.SelectIconCommand,
                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <TextBlock Text="{Binding Value}" FontSize="16"/>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="FARBE" Style="{StaticResource SectionLabel}" Margin="0,0,0,8"/>
                    <ItemsControl ItemsSource="{Binding AvailableColors}" Margin="0,0,0,20">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Width="32" Height="32" Margin="0,0,6,6" Padding="0"
                                        Command="{Binding DataContext.SelectColorCommand,
                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}">
                                    <Button.Background>
                                        <SolidColorBrush Color="{Binding Value}"/>
                                    </Button.Background>
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="BorderBrush" Value="White"/>
                                                    <Setter Property="BorderThickness" Value="2"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource SecondaryButton}" Padding="20,10" Margin="0,0,8,0"
                                Command="{Binding CancelDialogCommand}">
                            <TextBlock Text="Abbrechen"/>
                        </Button>
                        <Button Style="{StaticResource PrimaryButton}" Padding="20,10"
                                Command="{Binding SaveSubjectCommand}">
                            <TextBlock Text="Speichern"/>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
