<Window x:Class="MindForge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MindForge.ViewModels"
        xmlns:views="clr-namespace:MindForge.Views"
        Title="MindForge" Height="900" Width="1440"
        MinHeight="700" MinWidth="1100"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        FontFamily="Segoe UI" FontSize="13.5"
        Foreground="{StaticResource TextBrush}">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Border Background="{StaticResource BgBrush}"
            BorderBrush="{StaticResource LineBrush}"
            BorderThickness="1"
            CornerRadius="10">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Header -->
                <RowDefinition Height="*"/>
                <!-- Content -->
            </Grid.RowDefinitions>

            <!-- ══════════════════════════════════════════
                 HEADER
                 ══════════════════════════════════════════ -->
            <Border Grid.Row="0"
                    Background="{StaticResource BgBrush}"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="0,0,0,1"
                    Height="48">
                <Grid Margin="18,0,14,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <!-- Logo -->
                        <ColumnDefinition Width="Auto"/>
                        <!-- Breadcrumb -->
                        <ColumnDefinition Width="*"/>
                        <!-- Spacer -->
                        <ColumnDefinition Width="Auto"/>
                        <!-- Search -->
                        <ColumnDefinition Width="Auto"/>
                        <!-- Sync -->
                        <ColumnDefinition Width="Auto"/>
                        <!-- Level -->
                        <ColumnDefinition Width="Auto"/>
                        <!-- Actions -->
                    </Grid.ColumnDefinitions>

                    <!-- Logo -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                        <Border Width="26" Height="26" CornerRadius="7"
                                Background="{StaticResource AccentGradient}">
                            <TextBlock Text="M" Foreground="White" FontSize="15"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontFamily="Georgia" FontWeight="SemiBold"/>
                        </Border>
                        <StackPanel Orientation="Horizontal" Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="MindForge" FontSize="14.5" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="v1.0.0" FontSize="10.5" Foreground="{StaticResource Text3Brush}"
                                       Margin="8,0,0,0" VerticalAlignment="Bottom"
                                       FontFamily="Consolas"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Breadcrumb -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                        <TextBlock Text="›" Foreground="{StaticResource Text3Brush}" FontSize="14" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding Breadcrumb}" Foreground="{StaticResource Text3Brush}" FontSize="12.5"/>
                    </StackPanel>

                    <!-- Search -->
                    <Button Grid.Column="3" Margin="0,0,10,0"
                            Style="{StaticResource SecondaryButton}"
                            MinWidth="240" Height="30" Padding="10,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔍" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Suche oder Befehl…" Foreground="{StaticResource Text3Brush}"
                                       FontSize="12.5" VerticalAlignment="Center"/>
                            <TextBlock Text="      " Foreground="Transparent" Width="1"/>
                            <Border Background="{StaticResource Bg3Brush}" CornerRadius="4"
                                    Padding="4,1" Margin="40,0,2,0">
                                <TextBlock Text="⌘" Foreground="{StaticResource Text3Brush}" FontSize="10.5"/>
                            </Border>
                            <Border Background="{StaticResource Bg3Brush}" CornerRadius="4" Padding="4,1">
                                <TextBlock Text="K" Foreground="{StaticResource Text3Brush}" FontSize="10.5"/>
                            </Border>
                        </StackPanel>
                    </Button>

                    <!-- Sync Status -->
                    <Border Grid.Column="4" Margin="0,0,10,0"
                            Background="{StaticResource SuccessSoftBrush}"
                            CornerRadius="999" Padding="10,4">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="6" Height="6" Fill="{StaticResource SuccessBrush}" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding SyncStatus}" Foreground="{StaticResource SuccessBrush}"
                                       FontSize="11.5" FontWeight="Medium" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Level Badge -->
                    <Border Grid.Column="5" Margin="0,0,6,0"
                            Background="{StaticResource Bg2Brush}"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="1" CornerRadius="999" Padding="10,4"
                            Cursor="Hand">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Foreground="{StaticResource Text3Brush}" FontSize="11" Margin="0,0,4,0"
                                       Text="LVL."/>
                            <TextBlock Foreground="{StaticResource TextBrush}" FontSize="11.5" FontWeight="SemiBold"
                                       Text="{Binding Level}"/>
                            <TextBlock Text=" · " Foreground="{StaticResource Text3Brush}" FontSize="11"/>
                            <TextBlock Foreground="{StaticResource Text2Brush}" FontSize="11"
                                       Text="{Binding XPProgressText}"/>
                        </StackPanel>
                    </Border>

                    <!-- Action Buttons -->
                    <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Style="{StaticResource IconButton}" ToolTip="Einstellungen"
                                Command="{Binding NavigateToCommand}" CommandParameter="Settings">
                            <TextBlock Text="⚙" FontSize="14"/>
                        </Button>
                        <!-- Avatar -->
                        <Border Width="28" Height="28" CornerRadius="14" Margin="6,0,0,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FFFF9A9E" Offset="0"/>
                                    <GradientStop Color="#FFFAD0C4" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="JW" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="11" FontWeight="SemiBold" Foreground="#FF5A2424"/>
                        </Border>
                    </StackPanel>

                    <!-- Drag Handle -->
                    <Border Grid.ColumnSpan="7" Background="Transparent"
                            MouseLeftButtonDown="Header_MouseLeftButtonDown"/>
                </Grid>
            </Border>

            <!-- ══════════════════════════════════════════
                 BODY: Sidebar + Main Content
                 ══════════════════════════════════════════ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- SIDEBAR -->
                <Border Grid.Column="0"
                        Background="{StaticResource BgBrush}"
                        BorderBrush="{StaticResource LineBrush}"
                        BorderThickness="0,0,1,0">
                    <Border.Width>
                        <Binding Path="IsSidebarCollapsed">
                            <Binding.Converter>
                                <local:BoolToWidthConverter xmlns:local="clr-namespace:MindForge"/>
                            </Binding.Converter>
                        </Binding>
                    </Border.Width>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <!-- Nav -->
                            <RowDefinition Height="Auto"/>
                            <!-- Separator -->
                            <RowDefinition Height="Auto"/>
                            <!-- Subjects header -->
                            <RowDefinition Height="*"/>
                            <!-- Subjects list -->
                            <RowDefinition Height="Auto"/>
                            <!-- Footer -->
                        </Grid.RowDefinitions>

                        <!-- Nav Items -->
                        <StackPanel Grid.Row="0" Margin="10,14,10,6">
                            <Button Command="{Binding NavigateToCommand}" CommandParameter="Dashboard">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentView}" Value="Dashboard">
                                                <Setter Property="Background" Value="{StaticResource AccentSoftBrush}"/>
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⊞" FontSize="15" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding NavigateToCommand}" CommandParameter="Learning">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentView}" Value="Learning">
                                                <Setter Property="Background" Value="{StaticResource AccentSoftBrush}"/>
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🧠" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Text="Lernen" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding NavigateToCommand}" CommandParameter="Tests">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentView}" Value="Tests">
                                                <Setter Property="Background" Value="{StaticResource AccentSoftBrush}"/>
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📝" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Text="Tests" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding NavigateToCommand}" CommandParameter="Analytics">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentView}" Value="Analytics">
                                                <Setter Property="Background" Value="{StaticResource AccentSoftBrush}"/>
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📊" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Text="Analytics" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding NavigateToCommand}" CommandParameter="KITools">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentView}" Value="KITools">
                                                <Setter Property="Background" Value="{StaticResource AccentSoftBrush}"/>
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="✨" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Text="KI-Werkzeuge" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding NavigateToCommand}" CommandParameter="Subjects">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentView}" Value="Subjects">
                                                <Setter Property="Background" Value="{StaticResource AccentSoftBrush}"/>
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📚" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Text="Fächer" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding NavigateToCommand}" CommandParameter="Profile">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentView}" Value="Profile">
                                                <Setter Property="Background" Value="{StaticResource AccentSoftBrush}"/>
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="👤" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Text="Profil" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- Separator -->
                        <Border Grid.Row="1" Height="1" Background="{StaticResource LineBrush}" Margin="14,8"/>

                        <!-- Subjects Header -->
                        <Grid Grid.Row="2" Margin="10,4,10,2" Height="28">
                            <TextBlock Text="FÄCHER" VerticalAlignment="Center" Margin="6,0,0,0"
                                       FontSize="10.5" FontWeight="SemiBold"
                                       Foreground="{StaticResource Text3Brush}"/>
                            <Button HorizontalAlignment="Right" Style="{StaticResource IconButton}"
                                    ToolTip="Fach hinzufügen">
                                <TextBlock Text="+" FontSize="16" Foreground="{StaticResource Text2Brush}"/>
                            </Button>
                        </Grid>

                        <!-- Subjects List -->
                        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" Margin="10,0,10,10">
                            <ItemsControl ItemsSource="{Binding Subjects}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource SidebarNavButton}"
                                                Margin="0,0,0,1"
                                                Command="{Binding DataContext.SelectSubjectCommand,
                                                    RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Subject Icon -->
                                                <Border Grid.Column="0" Width="22" Height="22" CornerRadius="6"
                                                        Margin="0,0,10,0">
                                                    <Border.Background>
                                                        <SolidColorBrush Color="#225B8CFF"/>
                                                    </Border.Background>
                                                    <TextBlock Text="{Binding Icon}" FontSize="11"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               FontFamily="Georgia" FontWeight="SemiBold"/>
                                                </Border>

                                                <!-- Name + Progress -->
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" FontSize="13"
                                                               Foreground="{StaticResource Text2Brush}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <ProgressBar Value="{Binding Progress}" Maximum="1"
                                                                 Style="{StaticResource MfProgressBar}"
                                                                 Height="2" Margin="0,3,0,0"/>
                                                </StackPanel>

                                                <!-- Badge -->
                                                <Border Grid.Column="2" Margin="6,0,0,0"
                                                        Visibility="{Binding HasQuestionsToday, Converter={StaticResource BoolToVisibility}}">
                                                    <Border Style="{StaticResource BadgeAccent}">
                                                        <TextBlock Text="{Binding QuestionsToday}"
                                                                   Foreground="{StaticResource AccentBrush}"
                                                                   FontSize="11" FontWeight="Medium"/>
                                                    </Border>
                                                </Border>
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Footer: Collapse -->
                        <Border Grid.Row="4" BorderThickness="0,1,0,0" BorderBrush="{StaticResource LineBrush}"
                                Padding="10,8">
                            <Button Style="{StaticResource SidebarNavButton}"
                                    Command="{Binding ToggleSidebarCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="◀" FontSize="12" VerticalAlignment="Center" Margin="0,0,10,0"
                                               Foreground="{StaticResource Text2Brush}"/>
                                    <TextBlock Text="Einklappen" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Border>
                    </Grid>
                </Border>

                <!-- MAIN CONTENT -->
                <Border Grid.Column="1" Background="{StaticResource BgBrush}" ClipToBounds="True">
                    <ContentControl>
                        <ContentControl.Style>
                            <Style TargetType="ContentControl">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentView}" Value="Dashboard">
                                        <Setter Property="Content">
                                            <Setter.Value>
                                                <views:DashboardView/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding CurrentView}" Value="Home">
                                        <Setter Property="Content">
                                            <Setter.Value>
                                                <views:HomeView/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding CurrentView}" Value="QA">
                                        <Setter Property="Content">
                                            <Setter.Value>
                                                <views:QAView/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding CurrentView}" Value="Learning">
                                        <Setter Property="Content">
                                            <Setter.Value>
                                                <views:LearningView/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding CurrentView}" Value="Tests">
                                        <Setter Property="Content">
                                            <Setter.Value>
                                                <views:TestsView/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding CurrentView}" Value="ContentGenerator">
                                        <Setter Property="Content">
                                            <Setter.Value>
                                                <views:ContentGeneratorView/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding CurrentView}" Value="KITools">
                                        <Setter Property="Content">
                                            <Setter.Value>
                                                <views:KIToolsView/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding CurrentView}" Value="TestCreator">
                                        <Setter Property="Content">
                                            <Setter.Value>
                                                <views:TestCreatorView/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding CurrentView}" Value="Analytics">
                                        <Setter Property="Content">
                                            <Setter.Value>
                                                <views:AnalyticsView/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding CurrentView}" Value="Subjects">
                                        <Setter Property="Content">
                                            <Setter.Value>
                                                <views:SubjectsView/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding CurrentView}" Value="Profile">
                                        <Setter Property="Content">
                                            <Setter.Value>
                                                <views:ProfileView/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding CurrentView}" Value="Settings">
                                        <Setter Property="Content">
                                            <Setter.Value>
                                                <views:SettingsView/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ContentControl.Style>
                    </ContentControl>
                </Border>
            </Grid>

            <!-- Window resize grip -->
            <ResizeGrip Grid.Row="1" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                        Margin="0,0,4,4" Opacity="0.3"/>
        </Grid>
    </Border>
</Window>
