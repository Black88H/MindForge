<Application x:Class="MindForge.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:MindForge"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="src/Themes/DarkColors.xaml"/>
                <ResourceDictionary Source="src/Themes/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <local:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
            <local:BoolToWidthConverter      x:Key="BoolToWidth"/>
            <local:PlusOneConverter          x:Key="PlusOne"/>
            <local:XPToHeightConverter       x:Key="XPToHeight"/>
            <local:BoolToSavingTextConverter x:Key="BoolToSavingText"/>
            <local:InvertBoolConverter       x:Key="InvertBool"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
