<Application x:Class="MindForge.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:MindForge">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="src/Themes/DarkColors.xaml"/>
                <ResourceDictionary Source="src/Themes/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <local:BoolToVisibilityConverter  x:Key="BoolToVisibility"/>
            <local:BoolToWidthConverter       x:Key="BoolToWidth"/>
            <local:PlusOneConverter           x:Key="PlusOne"/>
            <local:XPToHeightConverter        x:Key="XPToHeight"/>
            <local:BoolToSavingTextConverter  x:Key="BoolToSavingText"/>
            <local:InvertBoolConverter        x:Key="InvertBool"/>
            <local:StepToVisibilityConverter  x:Key="StepToVisibility"/>
            <local:StepToNextLabelConverter   x:Key="StepToNextLabel"/>
            <local:StringToVisibilityConverter x:Key="StringToVisibility"/>
            <local:IntToVisibilityConverter   x:Key="IntToVisibility"/>
            <local:BoolToNextLabelConverter   x:Key="BoolToNextLabel"/>
            <local:EqualityConverter          x:Key="EqualityConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
